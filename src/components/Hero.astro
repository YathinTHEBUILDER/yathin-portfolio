---
// Hero.astro
---
<!-- HERO -->
<section id="home" class="hero-section">
	<!-- Hero Title -->
	<h1 class="hero-name">
		Yathin G
	</h1>

	<!-- Primary Tagline -->
	<h2 class="hero-tagline">
		I build AI-powered web products and experimental interfaces.
	</h2>

	<!-- Subtitle -->
	<p class="hero-sub">
		CSE student from Mysuru building fintech tools, AI assistants, and practical software with Python, Next.js, Supabase, and modern web technologies.
	</p>

	<!-- Hero Actions -->
	<div class="hero-btns">
		<a href="#projects" class="btn-primary">
			<span>View My Projects</span>
			<span class="btn-arrow">→</span>
		</a>
		<a href="/terminal" class="btn-secondary">
			<svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
			<span>Launch Terminal</span>
		</a>
		<div class="social-group">
			<a href="https://github.com/YathinTHEBUILDER" target="_blank" rel="noopener" class="btn-ghost" aria-label="GitHub">
				<svg viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
			</a>
			<a href="https://www.linkedin.com/in/yathin-gnaneshwar-5133b4367" target="_blank" rel="noopener" class="btn-ghost" aria-label="LinkedIn">
				<svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0h.003z"/></svg>
			</a>
		</div>
	</div>
	
	<!-- Sleek Scroll Indicator -->
	<div class="scroll-indicator-wrap">
		<div class="mouse-frame">
			<div class="mouse-wheel"></div>
		</div>
		<span class="scroll-text">Scroll Down</span>
	</div>
</section>

<style>
	/* HERO */
	.hero-section {
		min-height: 90vh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		flex-direction: column;
		padding: 2rem;
		max-width: 100%;
		position: relative;
	}

	/* Hero Name - Dark Editorial Premium Typography */
	.hero-name {
		font-family: var(--font-display);
		font-size: clamp(3.5rem, 8.5vw, 6.5rem);
		font-weight: 900;
		line-height: 1.05;
		margin-bottom: 1.5rem;
		opacity: 0;
		letter-spacing: -0.04em;
		color: #f5f5f5;
	}

	.hero-tagline {
		font-family: var(--font-display);
		font-size: clamp(1.4rem, 4vw, 2.2rem);
		font-weight: 700;
		line-height: 1.3;
		max-width: 800px;
		margin: 0 auto 2rem;
		color: var(--accent);
		letter-spacing: -0.02em;
		opacity: 0;
	}

	/* Hero Subtitle */
	.hero-sub {
		color: #8a8a8a;
		font-size: 1.15rem;
		line-height: 1.8;
		max-width: 700px;
		margin: 0 auto 3.5rem;
		opacity: 0;
		font-weight: 400;
	}

	/* Hero Buttons */
	.hero-btns {
		display: flex;
		gap: 1.2rem;
		flex-wrap: wrap;
		justify-content: center;
		align-items: center;
		margin-bottom: 3rem;
		opacity: 0;
	}

	/* Sleek Scroll Indicator */
	.scroll-indicator-wrap {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		opacity: 0;
		pointer-events: none;
	}
	.mouse-frame {
		width: 20px;
		height: 32px;
		border: 2px solid rgba(255, 255, 255, 0.15);
		border-radius: 10px;
		display: flex;
		justify-content: center;
		padding-top: 5px;
	}
	.mouse-wheel {
		width: 3px;
		height: 6px;
		background: #8a8a8a;
		border-radius: 1px;
		animation: scroll-wheel 2s cubic-bezier(0.15, 0.41, 0.69, 0.94) infinite;
	}
	.scroll-text {
		font-family: var(--font-tech);
		font-size: 0.6rem;
		letter-spacing: 0.25em;
		color: #8a8a8a;
		text-transform: uppercase;
	}

	@keyframes scroll-wheel {
		0% { transform: translateY(0); opacity: 1; }
		50% { transform: translateY(8px); opacity: 0; }
		51% { transform: translateY(-4px); opacity: 0; }
		100% { transform: translateY(0); opacity: 1; }
	}
</style>
