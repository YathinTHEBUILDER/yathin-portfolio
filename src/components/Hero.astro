					</a>
					<a href="https://www.linkedin.com/in/yathin-gnaneshwar-5133b4367" target="_blank" rel="noopener" class="btn-ghost" aria-label="LinkedIn">
						<svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0h.003z"/></svg>
					</a>
				</div>
			</div>
		</div>

		<!-- Right: Currently Building Side Card -->
		<div class="hero-visual reveal">
			<div class="status-card">
				<div class="status-card-header">
					<span class="status-pulse-dot"></span>
					<h3 class="status-title">Currently building</h3>
				</div>
				<ul class="status-list">
					<li class="status-item">
						<span class="status-dot dot-blue"></span>
						<div class="status-text">
							<span class="project-name">InvoiceFlow</span>
							<span class="project-desc">MSME financing platform</span>
						</div>
					</li>
					<li class="status-item">
						<span class="status-dot dot-green"></span>
						<div class="status-text">
							<span class="project-name">Skillqore</span>
							<span class="project-desc">AI career & resume pathfinder</span>
						</div>
					</li>
					<li class="status-item">
						<span class="status-dot dot-yellow"></span>
						<div class="status-text">
							<span class="project-name">J.A.R.V.I.S</span>
							<span class="project-desc">Real-time local search assistant</span>
						</div>
					</li>
				</ul>
			</div>

			<!-- Floating Accent Card behind the status card -->
			<div class="decorative-blob"></div>
		</div>
	</div>
</section>

<style>
	.hero-section {
		min-height: 80vh;
		display: flex;
		align-items: center;
		padding: 4rem 2rem;
		position: relative;
		overflow: hidden;
		max-width: 1200px;
		margin: 0 auto;
	}

	.hero-backdrop {
		position: absolute;
		inset: 0;
		z-index: -1;
		pointer-events: none;
	}

	.glow-blob {
		position: absolute;
		top: -10%;
		right: 10%;
		width: 40vw;
		height: 40vw;
		background: radial-gradient(circle, rgba(26, 115, 232, 0.05) 0%, rgba(24, 128, 56, 0.02) 50%, transparent 70%);
		border-radius: 50%;
		filter: blur(80px);
	}

	.grid-pattern {
		position: absolute;
		inset: 0;
		background-image: radial-gradient(var(--border) 1px, transparent 1px);
		background-size: 24px 24px;
		opacity: 0.25;
	}

	.hero-container {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: 6rem;
		align-items: center;
		width: 100%;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		text-align: left;
	}

	.hero-title {
		font-family: var(--font-display);
		font-size: clamp(3rem, 6vw, 4.5rem);
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1.1;
		color: var(--text-primary);
		margin-bottom: 1.5rem;
	}

	.hero-tagline {
		font-family: var(--font-display);
		font-size: clamp(1.5rem, 3vw, 2.2rem);
		font-weight: 600;
		line-height: 1.25;
		color: var(--accent-blue);
		letter-spacing: -0.02em;
		margin-bottom: 1.5rem;
	}

	.hero-sub {
		font-family: var(--font-sans);
		font-size: 1.15rem;
		line-height: 1.7;
		color: var(--text-muted);
		max-width: 620px;
		margin-bottom: 3rem;
	}

	.hero-actions {
		display: flex;
		gap: 1.2rem;
		align-items: center;
		flex-wrap: wrap;
	}

	/* Right Side Card */
	.hero-visual {
		position: relative;
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.status-card {
		background: var(--card-surface);
		border: 1px solid var(--border);
		border-radius: 16px;
		padding: 2.2rem;
		width: 100%;
		max-width: 360px;
		box-shadow: var(--shadow-lg);
		position: relative;
		z-index: 2;
	}

	.status-card-header {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 1.8rem;
		border-bottom: 1px solid var(--border);
		padding-bottom: 1rem;
	}

	.status-pulse-dot {
		width: 8px;
		height: 8px;
		background-color: var(--accent-green);
		border-radius: 50%;
		position: relative;
	}

	.status-pulse-dot::after {
		content: '';
		position: absolute;
		width: 100%;
		height: 100%;
		background-color: var(--accent-green);
		border-radius: 50%;
		animation: pulse-ring 2s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
		top: 0;
		left: 0;
	}

	@keyframes pulse-ring {
		0% { transform: scale(1); opacity: 0.8; }
		80%, 100% { transform: scale(3.5); opacity: 0; }
	}

	.status-title {
		font-family: var(--font-tech);
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--text-muted);
	}

	.status-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
	}

	.status-item {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
	}

	.status-dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		margin-top: 5px;
		flex-shrink: 0;
	}

	.dot-blue { background-color: var(--accent-blue); }
	.dot-green { background-color: var(--accent-green); }
	.dot-yellow { background-color: var(--accent-yellow); }

	.status-text {
		display: flex;
		flex-direction: column;
	}

	.status-text .project-name {
		font-family: var(--font-display);
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-primary);
	}

	.status-text .project-desc {
		font-family: var(--font-sans);
		font-size: 0.8rem;
		color: var(--text-muted);
		margin-top: 0.1rem;
	}

	.decorative-blob {
		position: absolute;
		width: 110%;
		height: 110%;
		background: radial-gradient(circle, rgba(26, 115, 232, 0.03) 0%, transparent 60%);
		z-index: 1;
		pointer-events: none;
	}

	/* Responsiveness */
	@media (max-width: 1024px) {
		.hero-container {
			gap: 4rem;
		}
	}

	@media (max-width: 768px) {
		.hero-section {
			padding: 6rem 1rem 4rem;
		}
		
		.hero-container {
			grid-template-columns: 1fr;
			gap: 4rem;
		}

		.hero-content {
			align-items: center;
			text-align: center;
		}

		.hero-sub {
			margin-left: auto;
			margin-right: auto;
		}

		.hero-actions {
			justify-content: center;
		}

		.hero-visual {
			width: 100%;
		}

		.status-card {
			max-width: 100%;
		}
	}
</style>
