---
// Hero.astro
---
<!-- HERO -->
<section id="home" class="hero-section">
	<!-- Floating HUD Decorators inside Hero -->
	<div class="hero-hud-decorator top-left">
		<span>[SYS.ID: YATHIN_CORE]</span>
		<span>LAT. 12.2958° N // LON. 76.6394° E</span>
	</div>
	<div class="hero-hud-decorator top-right">
		<span>STATUS // OPTIMAL</span>
		<span class="hud-pulse-status"><span class="hud-status-dot"></span> AI.ENGINE v4.2</span>
	</div>



	<!-- Hero Title -->
	<h1 class="hero-name">
		<span class="gradient">Yathin</span>
	</h1>

	<!-- Typewriter Tech Box -->
	<div class="hero-typewriter-box">
		<span class="typewriter-prefix">>_</span>
		<span id="typed"></span>
	</div>

	<!-- Subtitle -->
	<p class="hero-sub">
		Full Stack Developer and AI Engineer exploring machine intelligence, scalable backend architectures, and immersive web experiences.
	</p>

	<!-- Hero Actions -->
	<div class="hero-btns">
		<a href="#projects" class="btn-primary">
			<span>View My Projects</span>
			<span class="btn-arrow">→</span>
		</a>
		<a href="/terminal" class="btn-secondary">
			<svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
			<span>Launch Terminal</span>
		</a>
		<div class="social-group">
			<a href="https://github.com/YathinTHEBUILDER" target="_blank" rel="noopener" class="btn-ghost" aria-label="GitHub">
