			</a>
			<a href="https://www.linkedin.com/in/yathin-gnaneshwar-5133b4367" target="_blank" rel="noopener" class="btn-ghost" aria-label="LinkedIn">
				<svg viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
			</a>
			<a href="https://www.instagram.com/yathin_gnaneshwar" target="_blank" rel="noopener" class="btn-ghost" aria-label="Instagram">
				<svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
			</a>
		</div>
	</div>
	
	<!-- Sleek Scroll Indicator -->
	<div class="scroll-indicator-wrap">
		<div class="mouse-frame">
			<div class="mouse-wheel"></div>
		</div>
		<span class="scroll-text">Scroll Down</span>
	</div>
</section>

<script>
	declare var Typed: any;

	const runOnInit = (fn: () => void) => {
		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", fn);
		} else {
			fn();
		}
	};

	runOnInit(() => {
		new Typed("#typed", {
			strings: [
				"Full Stack Developer & AI Engineer.",
				"Building scalable web applications.",
				"Developing intelligent AI solutions.",
			],
			typeSpeed: 50,
			backSpeed: 30,
			backDelay: 2000,
			loop: true,
		});
	});
</script>

<style>
	/* HERO */
	#home {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		flex-direction: column;
		padding: 2rem;
		max-width: 100%;
		position: relative;
	}

	/* Floating HUD Decorators */
	.hero-hud-decorator {
		position: absolute;
		top: 2.5rem;
		display: flex;
		flex-direction: column;
		font-family: var(--font-tech);
		font-size: 0.65rem;
		letter-spacing: 0.2em;
		color: #64748b;
		pointer-events: none;
		opacity: 0;
	}
	.hero-hud-decorator.top-left {
		left: 2.5rem;
		text-align: left;
		border-left: 1px solid rgba(249, 115, 22, 0.3);
		padding-left: 0.8rem;
		gap: 0.3rem;
	}
	.hero-hud-decorator.top-right {
		right: 2.5rem;
		text-align: right;
		border-right: 1px solid rgba(249, 115, 22, 0.3);
		padding-right: 0.8rem;
		gap: 0.3rem;
	}
	.hud-pulse-status {
		display: inline-flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.4rem;
		color: var(--accent);
	}
	.hud-status-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 10px var(--accent);
		animation: dot-pulse-fast-hero 1.5s infinite alternate;
	}

	@keyframes dot-pulse-fast-hero {
		0% { opacity: 0.4; box-shadow: 0 0 4px var(--accent); }
		100% { opacity: 1; box-shadow: 0 0 12px var(--accent), 0 0 20px rgba(249, 115, 22, 0.5); }
	}

	@media (max-width: 1024px) {
		.hero-hud-decorator { display: none; }
	}

	/* Core Avatar Display */
	.hero-avatar-container {
		position: relative;
		width: 200px;
		height: 200px;
		margin: 0 auto 2.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.hero-avatar-wrap {
		position: relative;
		width: 150px;
		height: 150px;
		opacity: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
	}
	.hero-avatar-glow-bg {
		position: absolute;
		inset: -20px;
		background: radial-gradient(circle at center, rgba(249, 115, 22, 0.25) 0%, transparent 70%);
		border-radius: 50%;
		filter: blur(15px);
		transition: all 0.5s ease;
	}
	.hero-avatar-wrap:hover .hero-avatar-glow-bg {
		background: radial-gradient(circle at center, rgba(249, 115, 22, 0.45) 0%, transparent 75%);
		filter: blur(20px);
		transform: scale(1.1);
	}
	.hero-avatar-ring {
		position: absolute;
		inset: -8px;
		border-radius: 50%;
		background: conic-gradient(from 0deg, transparent 0%, rgba(249, 115, 22, 0.8) 25%, transparent 50%);
		animation: spin-slow 4s linear infinite;
		z-index: 0;
		transition: inset 0.4s ease;
	}
	.hero-avatar-ring::before {
		content: '';
		position: absolute;
		inset: 2px;
		border-radius: 50%;
		background: #050505;
	}
	.hero-avatar-ring-2 {
		position: absolute;
		inset: -18px;
		border-radius: 50%;
		border: 1px dashed rgba(249, 115, 22, 0.35);
		animation: spin-slow 15s linear infinite reverse;
		z-index: 0;
		transition: inset 0.4s ease, border-color 0.4s ease;
	}
	.hero-avatar-ring-3 {
		position: absolute;
		inset: -28px;
		border-radius: 50%;
		border: 1px solid rgba(255, 255, 255, 0.05);
		animation: spin-slow 25s linear infinite;
		z-index: 0;
		transition: inset 0.4s ease;
	}
	.hero-avatar-wrap:hover .hero-avatar-ring { inset: -12px; }
	.hero-avatar-wrap:hover .hero-avatar-ring-2 { inset: -24px; border-color: rgba(249, 115, 22, 0.6); }
	.hero-avatar-wrap:hover .hero-avatar-ring-3 { inset: -36px; border-color: rgba(255, 255, 255, 0.15); }

	.hero-avatar {
		position: relative;
		width: 100%;
		height: 100%;
		border-radius: 50%;
		overflow: hidden;
		z-index: 2;
		box-shadow: 0 0 30px rgba(249, 115, 22, 0.3), inset 0 0 20px rgba(0,0,0,0.5);
		border: 2px solid rgba(255, 255, 255, 0.15);
		transition: border-color 0.4s ease, transform 0.4s ease;
	}
	.hero-avatar-wrap:hover .hero-avatar {
		border-color: var(--accent);
		transform: scale(1.03);
	}

	/* Orbital Trackers */
	.orbit-tracker {
		position: absolute;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 10px var(--accent);
		z-index: 3;
	}
	.tracker-1 {
		top: 10px;
		left: 50%;
		transform-origin: 0 90px;
		animation: spin-slow 8s linear infinite;
	}
	.tracker-2 {
		bottom: 10px;
		right: 50%;
		transform-origin: 0 -90px;
		animation: spin-slow 12s linear infinite reverse;
	}

	@keyframes spin-slow {
		100% { transform: rotate(360deg); }
	}

	/* Hero Name */
	.hero-name {
		font-family: var(--font-display);
		font-size: clamp(3.2rem, 8.5vw, 7rem);
		font-weight: 900;
		line-height: 1.1;
		margin-bottom: 1.5rem;
		opacity: 0;
		letter-spacing: -0.03em;
		position: relative;
	}
	.hero-name .gradient {
		background: linear-gradient(135deg, #ffffff 0%, #f97316 50%, #fbbf24 100%);
		background-size: 200% auto;
		animation: textShine 5s linear infinite;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		filter: drop-shadow(0 0 35px rgba(249, 115, 22, 0.3));
	}
	@keyframes textShine {
		to { background-position: 200% center; }
	}

	/* Typewriter Box */
	.hero-typewriter-box {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		background: rgba(0, 0, 0, 0.4);
		border: 1px solid rgba(255, 255, 255, 0.1);
		padding: 0.6rem 1.5rem;
		border-radius: 12px;
		font-family: var(--font-tech);
		font-size: clamp(1.1rem, 3vw, 1.5rem);
		color: #f1f5f9;
		margin-bottom: 1.8rem;
		min-height: 3rem;
		opacity: 0;
		font-weight: 500;
		box-shadow: 0 10px 30px rgba(0,0,0,0.5), inset 0 1px 1px rgba(255,255,255,0.05);
		backdrop-filter: blur(12px);
		letter-spacing: 0.02em;
	}
	.typewriter-prefix {
		color: var(--accent);
		font-weight: 700;
	}

	/* Hero Subtitle */
	.hero-sub {
		color: #94a3b8;
		font-size: 1.15rem;
		line-height: 1.8;
		max-width: 650px;
		margin: 0 auto 3.5rem;
		opacity: 0;
		font-weight: 400;
	}

	/* Hero Buttons */
	.hero-btns {
		display: flex;
		gap: 1.2rem;
		flex-wrap: wrap;
		justify-content: center;
		align-items: center;
		margin-bottom: 3rem;
		opacity: 0;
	}

	/* Sleek Scroll Indicator */
	.scroll-indicator-wrap {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		opacity: 0;
		pointer-events: none;
	}
	.mouse-frame {
		width: 22px;
		height: 36px;
		border: 2px solid rgba(255, 255, 255, 0.2);
		border-radius: 12px;
		display: flex;
		justify-content: center;
		padding-top: 6px;
		box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
	}
	.mouse-wheel {
		width: 4px;
		height: 8px;
		background: var(--accent);
		border-radius: 2px;
		animation: scroll-wheel 2s cubic-bezier(0.15, 0.41, 0.69, 0.94) infinite;
		box-shadow: 0 0 8px var(--accent);
	}
	.scroll-text {
		font-family: var(--font-tech);
		font-size: 0.65rem;
		letter-spacing: 0.25em;
		color: #64748b;
		text-transform: uppercase;
	}

	@keyframes scroll-wheel {
		0% { transform: translateY(0); opacity: 1; }
		50% { transform: translateY(10px); opacity: 0; }
		51% { transform: translateY(-5px); opacity: 0; }
		100% { transform: translateY(0); opacity: 1; }
	}
</style>
