---
// Hero.astro
---
<!-- HERO -->
<section id="home" class="hero-section">
	<!-- Subtle Abstract Backdrop Shapes -->
	<div class="hero-backdrop">
		<div class="glow-blob"></div>
		<div class="grid-pattern"></div>
	</div>

	<div class="hero-container">
		<!-- Left: Heading & Intro -->
		<div class="hero-content">
			<h1 class="hero-title reveal">Hi, I’m Yathin.</h1>
			<h2 class="hero-tagline reveal">I build practical AI-powered web products.</h2>
			<p class="hero-sub reveal">
				CSE student from Mysuru building fintech tools, AI assistants, and useful software with Python, Next.js, Supabase, and modern web technologies.
			</p>
			
			<div class="hero-actions reveal">
				<a href="#projects" class="btn-primary">
					<span>View my work</span>
					<span class="btn-arrow">→</span>
				</a>
				<a href="#contact" class="btn-secondary">
					<span>Contact me</span>
				</a>
				<div class="social-group">
					<a href="https://github.com/YathinTHEBUILDER" target="_blank" rel="noopener" class="btn-ghost" aria-label="GitHub">
