---
// CinematicLoader.astro
---
<!-- Minimal Dark Editorial Preloader Overlay -->
<div id="cinematic-loader" class="loader-active">
	<div class="loader-overlay-gradient"></div>
	
	<!-- Spacious Central Console Card -->
	<div id="loader-ui" class="loader-ui">
		<h1 class="loader-brand">Yathin G</h1>
		<p class="loader-sub">Building useful software.</p>
		
		<!-- Elegant minimal linear progress indicator -->
		<div class="loader-progress-bar">
			<div class="loader-progress-fill" id="loader-progress-fill"></div>
		</div>
	</div>
</div>

<style>
	#cinematic-loader {
		position: fixed;
		inset: 0;
		z-index: 9999;
		background: #070707;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: opacity var(--motion-duration-cinematic) var(--motion-ease-cinematic), visibility var(--motion-duration-cinematic);
		overflow: hidden;
	}

	.loader-overlay-gradient {
		position: absolute;
		inset: 0;
		background: radial-gradient(circle at center, rgba(249, 115, 22, 0.02) 0%, transparent 70%);
		pointer-events: none;
		z-index: 1;
	}

	/* Elegant card styling */
	.loader-ui {
		position: relative;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.8rem;
		z-index: 10;
		opacity: 1;
		transition: all var(--motion-duration-cinematic) var(--motion-ease-cinematic);
	}

	.loader-brand {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 6vw, 4rem);
		font-weight: 800;
		letter-spacing: -0.04em;
		color: #f5f5f5;
		margin: 0;
		animation: pulse-slow 3s ease-in-out infinite alternate;
	}

	.loader-sub {
		font-family: var(--font-tech);
		font-size: 1rem;
		font-weight: 500;
		color: var(--accent);
		letter-spacing: 0.1em;
		margin: 0;
	}

	/* Sleek minimal progress bar */
	.loader-progress-bar {
		width: 120px;
		height: 2px;
		background: rgba(255, 255, 255, 0.05);
		border-radius: 1px;
		overflow: hidden;
		margin-top: 1rem;
	}

	.loader-progress-fill {
		width: 0%;
		height: 100%;
		background: var(--accent);
		transition: width 0.1s ease-out;
	}

	@keyframes pulse-slow {
		0% { opacity: 0.8; transform: scale(0.99); }
		100% { opacity: 1; transform: scale(1); }
	}
</style>
