---
// Playground.astro
---
<!-- PLAYGROUND TEASER -->
<section id="playground" class="playground-section">
	<div class="card-premium playground-card reveal">
		<div class="playground-layout">
			<!-- Text content -->
			<div class="playground-content">
				<h2 class="playground-title">Interactive playground</h2>
				<p class="playground-text">
					A small browser-based terminal experiment for exploring my projects and stack.
				</p>
				<a href="/terminal" class="btn-primary">
					<svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
					<span>Open playground</span>
				</a>
			</div>
			
			<!-- Visual Minimal Terminal Mockup -->
			<div class="playground-visual">
				<div class="mini-terminal">
					<div class="terminal-bar">
						<span class="dot d-r"></span>
						<span class="dot d-y"></span>
						<span class="dot d-g"></span>
					</div>
					<div class="terminal-screen">
						<p class="term-line"><span class="term-prompt">yathin@portfolio:~$</span> help</p>
						<p class="term-result">Available commands: about, skills, projects, contact</p>
						<p class="term-line"><span class="term-prompt">yathin@portfolio:~$</span> <span class="cursor-blink">|</span></p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.playground-section {
		padding: 4rem 2rem;
	}

	.playground-card {
		padding: 3.5rem;
		background: var(--bg-soft);
	}

	.playground-layout {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: 4rem;
		align-items: center;
	}

	.playground-content {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1.5rem;
	}

	.playground-title {
		font-family: var(--font-display);
		font-size: clamp(1.8rem, 3.5vw, 2.4rem);
		font-weight: 700;
		color: var(--text-primary);
		letter-spacing: -0.02em;
	}

	.playground-text {
		font-family: var(--font-sans);
		font-size: 1.05rem;
		color: var(--text-muted);
		line-height: 1.6;
		max-width: 500px;
	}

	/* Mini Terminal Styling */
	.playground-visual {
		display: flex;
		justify-content: center;
	}

	.mini-terminal {
		width: 100%;
		max-width: 380px;
		background: #0f172a;
		border-radius: 10px;
		overflow: hidden;
		box-shadow: var(--shadow-lg);
		border: 1px solid rgba(255, 255, 255, 0.05);
	}

	.terminal-bar {
		background: #1e293b;
		padding: 0.6rem 1rem;
		display: flex;
		gap: 6px;
	}

	.terminal-bar .dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		display: block;
	}

	.d-r { background: #ef4444; }
	.d-y { background: #eab308; }
	.d-g { background: #10b981; }

	.terminal-screen {
		padding: 1.2rem;
		font-family: var(--font-tech);
		font-size: 0.8rem;
		line-height: 1.6;
		color: #cbd5e1;
		min-height: 120px;
	}

	.term-line {
		margin-bottom: 0.4rem;
	}

	.term-prompt {
		color: #38bdf8;
		font-weight: 600;
	}

	.term-result {
		color: #64748b;
		margin-bottom: 0.6rem;
	}

	.cursor-blink {
		color: #38bdf8;
		animation: blink 1s step-end infinite;
	}

	@keyframes blink {
		from, to { color: transparent }
		50% { color: #38bdf8 }
	}

	@media (max-width: 768px) {
		.playground-card {
			padding: 2.2rem;
		}

		.playground-layout {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.playground-visual {
			width: 100%;
		}

		.mini-terminal {
			max-width: 100%;
		}
	}
</style>
