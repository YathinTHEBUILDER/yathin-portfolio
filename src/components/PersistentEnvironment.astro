---
// src/components/PersistentEnvironment.astro
// Unified Cinematic Atmospheric Layer
---

<!-- Cinematic Background System -->
<div id="cinematic-background">
	<div class="bg-base"></div>
	<div class="ambient-glow"></div>
</div>

<style is:global>
	#cinematic-background {
		position: fixed;
		inset: 0;
		z-index: -2;
		overflow: hidden;
		pointer-events: none;
		background: #070707;
	}

	.bg-base {
		position: absolute;
		inset: 0;
		background: #070707;
	}

	.ambient-glow {
		position: absolute;
		width: 60vw;
		height: 60vw;
		background: radial-gradient(circle, rgba(249, 115, 22, 0.015) 0%, transparent 70%);
		top: -15%;
		left: 20%;
		border-radius: 50%;
		filter: blur(100px);
		pointer-events: none;
	}
</style>

<script>
	const initEcosystem = () => {
		const loaderPercentEl = document.getElementById("loader-percent");
		const loaderStatusTitleEl = document.getElementById("loader-status-title");
		const loaderStatusTickerEl = document.getElementById("loader-status-ticker");
		const loaderUiEl = document.getElementById("loader-ui");
		const loaderOverlayEl = document.getElementById("cinematic-loader");
		const mainContentEl = document.getElementById("main-content");
		const progressFillEl = document.getElementById("loader-progress-fill");

		let loaderProgress = 0;
		let lastTimestamp = 0;
		let elapsed = 0;

		function tick(timestamp: number) {
			if (!lastTimestamp) lastTimestamp = timestamp;
			const dt = timestamp - lastTimestamp;
			lastTimestamp = timestamp;

			elapsed += dt;
			loaderProgress = Math.min(100, (elapsed / 1000) * 100); // Snappy 1.0s loader entry

			if (progressFillEl) {
				progressFillEl.style.width = `${loaderProgress}%`;
			}
			if (loaderPercentEl) {
				loaderPercentEl.innerText = Math.floor(loaderProgress).toString().padStart(2, '0');
			}

			if (loaderProgress < 100) {
				requestAnimationFrame(tick);
			} else {
				triggerTransition();
			}
		}

		function triggerTransition() {
			if (loaderUiEl) {
				loaderUiEl.style.opacity = "0";
				loaderUiEl.style.transform = "scale(0.98)";
			}
			
			setTimeout(() => {
				if (loaderOverlayEl) {
					loaderOverlayEl.style.opacity = "0";
					loaderOverlayEl.style.pointerEvents = "none";
				}

				if (mainContentEl) {
					mainContentEl.style.opacity = "1";
					mainContentEl.style.transform = "translateY(0)";
					mainContentEl.style.filter = "blur(0px)";
					mainContentEl.style.pointerEvents = "all";
				}

				document.body.classList.remove("loading");
				document.dispatchEvent(new CustomEvent("nxs-boot-complete"));

				const nav = document.querySelector("nav");
				if (nav) {
					nav.style.transform = "translateY(0)";
					nav.style.opacity = "1";
				}

				setTimeout(() => {
					if (loaderOverlayEl) {
						loaderOverlayEl.style.display = "none";
					}
				}, 800);
			}, 300);
		}

		document.body.classList.add("loading");
		requestAnimationFrame(tick);
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initEcosystem);
	} else {
		initEcosystem();
	}
</script>
