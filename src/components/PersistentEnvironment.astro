---
// src/components/PersistentEnvironment.astro
// Unified Cinematic Atmospheric Layer
---

<!-- Cinematic Background System -->
<div id="cinematic-background">
	<div class="bg-base"></div>
	<div class="ambient-glow glow-1"></div>
	<div class="ambient-glow glow-2"></div>
	<div class="ambient-glow glow-3"></div>
	<div class="cinematic-haze"></div>
	<div class="infrastructure-grid"></div>
	<canvas id="particle-background-canvas" class="particle-background-canvas"></canvas>
</div>

<!-- Modern Futuristic Neon Glowing Custom Cursor System -->
<div id="neon-cursor-system" class="neon-cursor-system">
	<div class="cursor-core"></div>
	<div class="cursor-glow-ring"></div>
	<canvas id="cursor-trail-canvas" class="cursor-trail-canvas"></canvas>
</div>

<style is:global>
	*, *::before, *::after {
		user-select: none !important;
		-webkit-user-select: none !important;
		-webkit-user-drag: none !important;
		-webkit-touch-callout: none !important;
	}
	input, textarea {
		user-select: auto !important;
		-webkit-user-select: auto !important;
		-webkit-user-drag: auto !important;
	}

	#cinematic-background {
		position: fixed;
		inset: 0;
		z-index: -2;
		overflow: hidden;
		pointer-events: none;
		background: #030303;
	}

	.bg-base {
		position: absolute;
		inset: 0;
		background: radial-gradient(circle at 50% 0%, rgba(20, 20, 20, 1) 0%, rgba(3, 3, 3, 1) 100%);
	}

	.ambient-glow {
		position: absolute;
		border-radius: 50%;
		filter: blur(120px);
		opacity: 0.6;
		mix-blend-mode: screen;
		animation: drift 20s infinite alternate cubic-bezier(0.4, 0, 0.2, 1);
		will-change: transform, opacity;
	}

	.glow-1 {
		width: 60vw;
		height: 60vw;
		background: radial-gradient(circle, rgba(249, 115, 22, 0.04) 0%, rgba(249, 115, 22, 0) 70%);
		top: -20%;
		left: -10%;
		animation-duration: 25s;
	}

	.glow-2 {
		width: 50vw;
		height: 50vw;
		background: radial-gradient(circle, rgba(147, 51, 234, 0.03) 0%, rgba(147, 51, 234, 0) 70%);
		bottom: -10%;
		right: -10%;
		animation-duration: 22s;
		animation-delay: -5s;
	}

	.glow-3 {
		width: 70vw;
		height: 40vw;
		background: radial-gradient(circle, rgba(59, 130, 246, 0.02) 0%, rgba(59, 130, 246, 0) 70%);
		top: 30%;
		left: 20%;
		animation-duration: 28s;
		animation-delay: -10s;
	}

	.cinematic-haze {
		position: absolute;
		inset: 0;
		background: linear-gradient(to bottom, transparent 0%, rgba(3, 3, 3, 0.8) 100%);
		z-index: 1;
	}

	.infrastructure-grid {
		position: absolute;
		inset: -50%;
		width: 200%;
		height: 200%;
		background-image: 
			linear-gradient(rgba(255, 255, 255, 0.015) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.015) 1px, transparent 1px);
		background-size: 100px 100px;
		background-position: center center;
		transform: perspective(1000px) rotateX(60deg) translateY(100px) translateZ(-200px);
		opacity: 0.3;
		mask-image: radial-gradient(ellipse at center, black 0%, transparent 60%);
		-webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 60%);
		z-index: 1;
		animation: grid-drift 30s linear infinite;
	}

	.particle-background-canvas {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		z-index: 2;
		pointer-events: none;
	}

	@keyframes drift {
		0% { transform: translate(0, 0) scale(1); opacity: 0.4; }
		50% { transform: translate(5%, 5%) scale(1.05); opacity: 0.6; }
		100% { transform: translate(-5%, 8%) scale(0.95); opacity: 0.5; }
	}

	@keyframes grid-drift {
		0% { background-position: 0px 0px; }
		100% { background-position: 0px 100px; }
	}

	@media (max-width: 768px) {
		.ambient-glow {
			filter: blur(80px);
		}
		.infrastructure-grid {
			opacity: 0.15;
			background-size: 60px 60px;
		}
	}

	/* ── MODERN FUTURISTIC NEON GLOWING CUSTOM CURSOR SYSTEM ── */
	:root {
		--accent: #f97316;
		--accent-glow: rgba(249, 115, 22, 0.35);
	}

	/* Neon Cursor System container */
	.neon-cursor-system {
		display: none;
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 999999;
		opacity: 0;
		transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.neon-cursor-system.active {
		opacity: 1;
	}

	/* Disable standard cursor for non-touch devices with fine pointers */
	@media (hover: hover) and (pointer: fine) {
		html, body, a, button, [role="button"], input, select, textarea, [onclick], .skill-badge, .project-card, .contact-card, .achievement-card, .link, .btn-primary, .btn-ghost {
			cursor: none !important;
		}
		.neon-cursor-system {
			display: block;
		}
	}

	@media (hover: none) or (pointer: coarse) {
		.neon-cursor-system {
			display: none !important;
		}
	}

	/* Small, sharp, bright core dot */
	.cursor-core {
		position: absolute;
		top: 0;
		left: 0;
		width: 8px;
		height: 8px;
		background: #ffffff;
		border-radius: 50%;
		transform: translate(-50%, -50%);
		will-change: transform;
		z-index: 10;
		box-shadow: 0 0 10px #ffffff, 0 0 18px var(--accent);
		transition: background-color 0.25s ease;
	}

	/* Larger blurred halo trailing slightly behind */
	.cursor-glow-ring {
		position: absolute;
		top: 0;
		left: 0;
		width: 36px;
		height: 36px;
		border: 1.5px solid rgba(249, 115, 22, 0.4);
		background: rgba(249, 115, 22, 0.03);
		border-radius: 50%;
		transform: translate(-50%, -50%);
		will-change: transform, width, height, border-color, background-color, box-shadow;
		z-index: 5;
		box-shadow: 0 0 15px rgba(249, 115, 22, 0.15), inset 0 0 10px rgba(249, 115, 22, 0.1);
	}

	/* Full-screen high-performance canvas trail */
	.cursor-trail-canvas {
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		pointer-events: none;
		z-index: 4;
		mix-blend-mode: screen;
	}
</style>

<script>
	// ── GLOBAL PROJECT PROTECTION: DISABLE RIGHT CLICK & SELECTION ──
	document.addEventListener("contextmenu", (e) => e.preventDefault());
	document.addEventListener("dragstart", (e) => e.preventDefault());

	// ── GLOBAL UNIFIED MOTION DESIGN SYSTEM CONSTANTS ──
	const MOTION_TOKENS = {
		duration: {
			fast: 200,
			medium: 380,
			slow: 600,
			cinematic: 1200
		},
		stagger: 80,
		springs: {
			cursorTrack: { stiffness: 0.08, damping: 0.16 },
			cursorDeform: { stiffness: 0.06, damping: 0.22 },
			elasticNode: { stiffness: 0.05, damping: 0.16 },
			elasticPath: { stiffness: 0.04, damping: 0.18 },
			softBlend: { stiffness: 0.03, damping: 0.15 }
		}
	};

	class Spring {
		val: number;
		target: number;
		vel: number;
		stiffness: number;
		damping: number;

		constructor(val = 0, target = 0, stiffness = 0.05, damping = 0.15) {
			this.val = val;
			this.target = target;
			this.vel = 0;
			this.stiffness = stiffness;
			this.damping = damping;
		}

		update() {
			const force = (this.target - this.val) * this.stiffness;
			this.vel += force;
			this.vel *= (1 - this.damping);
			this.val += this.vel;
			return this.val;
		}
	}

	document.addEventListener("DOMContentLoaded", () => {
		let isMobile = window.innerWidth < 768;
		const rawMouse = { 
			x: window.innerWidth / 2, 
			y: window.innerHeight / 2, 
			targetX: window.innerWidth / 2, 
			targetY: window.innerHeight / 2 
		};
		let lastMouseX = rawMouse.targetX;
		let lastMouseY = rawMouse.targetY;

		// New custom cursor DOM cache
		const cursorEl = document.getElementById("neon-cursor-system");
		const cursorCore = cursorEl?.querySelector(".cursor-core") as HTMLElement | null;
		const cursorGlowRing = cursorEl?.querySelector(".cursor-glow-ring") as HTMLElement | null;
		const canvas = document.getElementById("cursor-trail-canvas") as HTMLCanvasElement | null;
		const ctx = canvas ? canvas.getContext("2d") : null;

		// Particle Background DOM cache & state
		const partCanvas = document.getElementById("particle-background-canvas") as HTMLCanvasElement | null;
		const partCtx = partCanvas ? partCanvas.getContext("2d") : null;

		let currentScrollY = window.scrollY || 0;
		let lastScrollY = currentScrollY;
		window.addEventListener("scroll", () => {
			currentScrollY = window.scrollY || 0;
		});

		// Initialize Background Particles
		const bgParticleCount = isMobile ? 35 : 75;
		const bgParticles: Array<{
			x: number;
			y: number;
			vx: number;
			vy: number;
			size: number;
			baseAlpha: number;
			alpha: number;
			color: string;
			parallaxFactor: number;
		}> = [];

		const palette = ["#3b82f6", "#f97316", "#a855f7", "#ffffff"];

		for (let i = 0; i < bgParticleCount; i++) {
			const size = Math.random() * 1.8 + 0.8;
			bgParticles.push({
				x: Math.random() * window.innerWidth,
				y: Math.random() * window.innerHeight,
				vx: (Math.random() - 0.5) * 0.5,
				vy: (Math.random() - 0.5) * 0.5,
				size: size,
				baseAlpha: Math.random() * 0.35 + 0.15,
				alpha: 0,
				color: palette[Math.floor(Math.random() * palette.length)],
				parallaxFactor: size * 0.35
			});
		}

		// Interpolated cursor states
		const core = { x: rawMouse.targetX, y: rawMouse.targetY };
		const ring = { x: rawMouse.targetX, y: rawMouse.targetY };
		
		// Responsive interactive sizing
		const coreSize = { current: 8, target: 8 };
		const ringSize = { current: 36, target: 36 };

		// Smooth Ribbon Trail history buffer
		const trailMax = 24;
		const trailPoints = Array.from({ length: trailMax }, () => ({ x: rawMouse.targetX, y: rawMouse.targetY }));

		// Floating Spark particles array
		const sparkParticles: Array<{
			x: number;
			y: number;
			vx: number;
			vy: number;
			size: number;
			alpha: number;
			age: number;
			maxAge: number;
		}> = [];

		function resizeCanvas() {
			if (canvas) {
				canvas.width = window.innerWidth;
				canvas.height = window.innerHeight;
			}
			if (partCanvas) {
				partCanvas.width = window.innerWidth;
				partCanvas.height = window.innerHeight;
				bgParticles.forEach(p => {
					if (p.x > partCanvas.width) p.x = Math.random() * partCanvas.width;
					if (p.y > partCanvas.height) p.y = Math.random() * partCanvas.height;
				});
			}
		}
		window.addEventListener("resize", resizeCanvas);
		resizeCanvas();

		let hoveredElement: HTMLElement | null = null;
		let isHovered = false;
		let isClicking = false;

		window.addEventListener("mousemove", (e) => {
			rawMouse.targetX = e.clientX;
			rawMouse.targetY = e.clientY;
		});

		window.addEventListener("mousedown", (e) => {
			if (e.button !== 0) return; 
			isClicking = true;
		});

		window.addEventListener("mouseup", (e) => {
			if (e.button !== 0) return;
			isClicking = false;
		});

		document.addEventListener("mouseover", (e) => {
			if (isMobile) return; 
			const target = e.target as HTMLElement | null;
			if (!target) return;
			const interactive = target.closest("a, button, [role='button'], .skill-badge, .project-card, .contact-card, .achievement-card, .link, .btn-primary, .btn-ghost");
			if (interactive) {
				hoveredElement = interactive as HTMLElement;
				isHovered = true;
			}
		});

		document.addEventListener("mouseout", (e) => {
			if (isMobile) return;
			const related = e.relatedTarget as HTMLElement | null;
			if (hoveredElement && (!related || !hoveredElement.contains(related))) {
				hoveredElement = null;
				isHovered = false;
			}
		});

		const spatialElements: HTMLElement[] = [];
		const spatialObserver = new IntersectionObserver((entries) => {
			entries.forEach(entry => {
				const el = entry.target as HTMLElement;
				if (entry.isIntersecting) {
					if (!spatialElements.includes(el)) {
						spatialElements.push(el);
					}
				} else {
					const index = spatialElements.indexOf(el);
					if (index > -1) {
						spatialElements.splice(index, 1);
					}
				}
			});
		}, { rootMargin: "100px" });

		setTimeout(() => {
			document.querySelectorAll(".project-card, .skill-badge, .btn-primary, .btn-ghost, .contact-card, .achievement-card").forEach(el => {
				spatialObserver.observe(el);
			});
		}, 150);

		let blueprintData: any[] = [];

		setTimeout(() => {
			if (isMobile) return;
			const blueprintCards = document.querySelectorAll(".project-card");
			blueprintData = Array.from(blueprintCards).map(card => {
				const svg = card.querySelector(".blueprint-svg");
				if (!svg) return null;
				
				const nodes = card.querySelectorAll(".blueprint-node");
				const nodeStates = Array.from(nodes).map(node => {
					const transform = node.getAttribute("transform") || "";
					const match = transform.match(/translate\(\s*([\d.-]+)\s*,\s*([\d.-]+)\s*\)/);
					const bx = match ? parseFloat(match[1]) : 0;
					const by = match ? parseFloat(match[2]) : 0;
					
					return {
						el: node,
						bx,
						by,
						x: new Spring(bx, bx, MOTION_TOKENS.springs.elasticNode.stiffness, MOTION_TOKENS.springs.elasticNode.damping),
						y: new Spring(by, by, MOTION_TOKENS.springs.elasticNode.stiffness, MOTION_TOKENS.springs.elasticNode.damping)
					};
				});
				
				const paths = card.querySelectorAll(".connection-path, .signal-pulse");
				const pathStates = Array.from(paths).map(path => {
					const baseD = path.getAttribute("d") || "";
					const coords = baseD.match(/(-?[\d.]+)/g)?.map(Number) || [];
					return {
						el: path,
						baseD,
						coords,
						springs: coords.map(c => new Spring(c, c, MOTION_TOKENS.springs.elasticPath.stiffness, MOTION_TOKENS.springs.elasticPath.damping))
					};
				});

				return {
					card: card,
					svg,
					nodeStates,
					pathStates
				};
			}).filter(Boolean);
		}, 300);

		let currentPhase = 1;
		let loaderProgress = 0;
		let phaseTimer = 0;
		let lastTimestamp = 0;

		const loaderPercentEl = document.getElementById("loader-percent");
		const loaderStatusEl = document.getElementById("loader-status-code");
		const loaderStatusTitleEl = document.getElementById("loader-status-title");
		const loaderBarEl = document.getElementById("loader-bar-fill");
		const loaderUiEl = document.getElementById("loader-ui");
		const loaderOverlayEl = document.getElementById("cinematic-loader");
		const mainContentEl = document.getElementById("main-content");
		const ringProgress = document.querySelector(".ring-progress") as HTMLElement | null;
		const ringCircumference = 502.65;

		const loaderProgressSpring = new Spring(0, 0, MOTION_TOKENS.springs.softBlend.stiffness, MOTION_TOKENS.springs.softBlend.damping);

		function resize() {
			isMobile = window.innerWidth < 768;
		}
		window.addEventListener("resize", resize);

		const statusLogs = [
			"SYS.CORE_STAGE_01 // AMBIENT_VOID_SECTOR",
			"DETECTION_EMERGED // CAPTURING_BEACON_PULSE",
			"TOPOLOGY_ACTIVE // GENERATING_COORDINATE_MAP",
			"INITIALIZING_YATHIN.ENGINEER // BOOTING_SERVICES",
			"INTERFACE_SYSTEMS_READY // SYNC_SUCCESS"
		];

		function getGlitchedText(text: string, phaseProgress: number) {
			if (phaseProgress >= 0.96) return text;
			const cyberchars = ["▰", "▱", "▀", "▄", "█", "░", "▒", "▓", "⚡", "⚙", "0", "1", "[", "]", "X", "Y"];
			let result = "";
			for (let i = 0; i < text.length; i++) {
				const char = text[i];
				if (char === " " || char === "/" || char === "." || char === "_") {
					result += char;
				} else {
					const threshold = Math.pow(phaseProgress, 1.4);
					if (Math.random() > threshold) {
						result += cyberchars[Math.floor(Math.random() * cyberchars.length)];
					} else {
						result += char;
					}
				}
			}
			return result;
		}

		function tick(timestamp: number) {
			const dt = timestamp - (lastTimestamp || timestamp);
			lastTimestamp = timestamp;

			if (currentPhase < 5) {
				phaseTimer += dt;
				loaderProgress = Math.min(100, (phaseTimer / 3200) * 100);
			}

			let targetTitle = "ESTABLISHING CORE";
			let baseText = statusLogs[0];
			let phaseProg = 0;

			if (loaderProgress < 20) {
				currentPhase = 1;
				targetTitle = "ESTABLISHING CORE";
				baseText = statusLogs[0];
				phaseProg = loaderProgress / 20;
			} else if (loaderProgress < 45) {
				currentPhase = 2;
				targetTitle = "DECRYPTING LINK";
				baseText = statusLogs[1];
				phaseProg = (loaderProgress - 20) / 25;
			} else if (loaderProgress < 70) {
				currentPhase = 3;
				targetTitle = "TOPOLOGY BOOT";
				baseText = statusLogs[2];
				phaseProg = (loaderProgress - 45) / 25;
			} else if (loaderProgress < 100) {
				currentPhase = 4;
				targetTitle = "BOOTING MODULES";
				baseText = statusLogs[3];
				phaseProg = (loaderProgress - 70) / 30;
			} else {
				if (currentPhase < 5) {
					currentPhase = 5;
					triggerTransition();
				}
				targetTitle = "SYNC COMPLETE";
				baseText = statusLogs[4];
				phaseProg = 1.0;
			}

			if (loaderStatusEl && currentPhase < 5) {
				loaderStatusEl.innerText = getGlitchedText(baseText, phaseProg);
			} else if (loaderStatusEl && currentPhase === 5) {
				loaderStatusEl.innerText = baseText;
			}
			if (loaderStatusTitleEl) {
				loaderStatusTitleEl.innerText = targetTitle;
			}

			loaderProgressSpring.target = loaderProgress;
			const activeProgress = loaderProgressSpring.update();
			
			if (loaderPercentEl) {
				loaderPercentEl.innerText = Math.floor(activeProgress).toString().padStart(2, '0');
			}
			if (loaderBarEl) {
				loaderBarEl.style.width = `${activeProgress}%`;
			}
			if (ringProgress) {
				const offset = ringCircumference - (activeProgress / 100) * ringCircumference;
				ringProgress.style.strokeDashoffset = offset.toString();
			}
			if (loaderUiEl) {
				const speed = 1.0 + (activeProgress / 20.0);
				loaderUiEl.style.setProperty("--orbit-speed", speed.toFixed(2));
			}

			if (currentPhase === 5 && !isMobile) {
				// 1. Core Position Easing (Faster, buttery smooth tracking to eliminate lag)
				core.x += (rawMouse.targetX - core.x) * 0.65;
				core.y += (rawMouse.targetY - core.y) * 0.65;

				// 2. Glow Ring Position Easing (Smooth, elegant trailing)
				ring.x += (core.x - ring.x) * 0.25;
				ring.y += (core.y - ring.y) * 0.25;

				// 3. Dynamic Interactive Sizing & Pulse Animation
				if (isClicking) {
					coreSize.target = 4;
					ringSize.target = 18;
				} else if (isHovered) {
					coreSize.target = 10;
					ringSize.target = 52;
				} else {
					coreSize.target = 8;
					ringSize.target = 36;
				}
				coreSize.current += (coreSize.target - coreSize.current) * 0.2;
				ringSize.current += (ringSize.target - ringSize.current) * 0.15;

				// 4. Update core and ring DOM elements
				if (cursorEl) {
					if (!cursorEl.classList.contains("active")) {
						cursorEl.classList.add("active");
					}

					if (cursorCore) {
						cursorCore.style.transform = `translate3d(${core.x}px, ${core.y}px, 0) translate(-50%, -50%)`;
						cursorCore.style.width = `${coreSize.current}px`;
						cursorCore.style.height = `${coreSize.current}px`;
					}

					if (cursorGlowRing) {
						cursorGlowRing.style.transform = `translate3d(${ring.x}px, ${ring.y}px, 0) translate(-50%, -50%)`;
						cursorGlowRing.style.width = `${ringSize.current}px`;
						cursorGlowRing.style.height = `${ringSize.current}px`;

						if (isHovered) {
							cursorGlowRing.style.borderColor = 'var(--accent, #f97316)';
							cursorGlowRing.style.backgroundColor = 'rgba(249, 115, 22, 0.08)';
							cursorGlowRing.style.boxShadow = '0 0 25px rgba(249, 115, 22, 0.45), inset 0 0 15px rgba(249, 115, 22, 0.2)';
						} else if (isClicking) {
							cursorGlowRing.style.borderColor = 'rgba(255, 255, 255, 0.8)';
							cursorGlowRing.style.backgroundColor = 'rgba(255, 255, 255, 0.15)';
							cursorGlowRing.style.boxShadow = '0 0 35px rgba(255, 255, 255, 0.6), inset 0 0 20px rgba(255, 255, 255, 0.3)';
						} else {
							cursorGlowRing.style.borderColor = 'rgba(249, 115, 22, 0.4)';
							cursorGlowRing.style.backgroundColor = 'rgba(249, 115, 22, 0.03)';
							cursorGlowRing.style.boxShadow = '0 0 15px rgba(249, 115, 22, 0.15), inset 0 0 10px rgba(249, 115, 22, 0.1)';
						}
					}
				}

				// 5. High-fidelity Fluid Trail & Plasma Sparks
				let dx = rawMouse.targetX - lastMouseX;
				let dy = rawMouse.targetY - lastMouseY;
				lastMouseX = rawMouse.targetX;
				lastMouseY = rawMouse.targetY;

				// Update head of the smooth ribbon trail to match core position
				trailPoints[0].x = core.x;
				trailPoints[0].y = core.y;

				// Lerp the rest of the chain for buttery smooth continuous trailing
				for (let i = 1; i < trailPoints.length; i++) {
					const prev = trailPoints[i - 1];
					const curr = trailPoints[i];
					curr.x += (prev.x - curr.x) * 0.55;
					curr.y += (prev.y - curr.y) * 0.55;
				}

				const speed = Math.sqrt(dx * dx + dy * dy);
				const spawnCount = isClicking ? 3 : (isHovered ? 2 : (speed > 1 ? 1 : 0));

				// Spawn spark particles on movement or click
				if (spawnCount > 0 || Math.random() < 0.1) {
					for (let i = 0; i < spawnCount; i++) {
						if (sparkParticles.length < 35) {
							sparkParticles.push({
								x: core.x,
								y: core.y,
								vx: (dx * 0.08) + (Math.random() - 0.5) * 1.2,
								vy: (dy * 0.08) + (Math.random() - 0.5) * 1.2,
								size: (isHovered ? 12 : (isClicking ? 16 : 6)) * (0.6 + Math.random() * 0.6),
								alpha: isClicking ? 0.9 : (isHovered ? 0.8 : 0.6),
								age: 0,
								maxAge: 20 + Math.random() * 20
							});
						}
					}
				}

				// Update spark particles
				for (let i = sparkParticles.length - 1; i >= 0; i--) {
					const p = sparkParticles[i];
					p.age++;
					if (p.age >= p.maxAge) {
						sparkParticles.splice(i, 1);
						continue;
					}

					p.vx *= 0.95;
					p.vy *= 0.95;
					p.x += p.vx;
					p.y += p.vy - 0.15; // warm thermal rise
				}

				// Render glowing trail and sparks on Canvas
				if (ctx && canvas) {
					ctx.clearRect(0, 0, canvas.width, canvas.height);
					ctx.globalCompositeOperation = "screen";

					// Render smooth tapered ribbon trail
					for (let i = 0; i < trailPoints.length - 2; i++) {
						const p1 = trailPoints[i];
						const p2 = trailPoints[i + 1];
						const p3 = trailPoints[i + 2];
						const xc = (p2.x + p3.x) / 2;
						const yc = (p2.y + p3.y) / 2;

						const ratio = i / (trailPoints.length - 2);
						const alpha = (isClicking ? 0.7 : (isHovered ? 0.5 : 0.35)) * (1 - Math.pow(ratio, 0.7));
						const width = (isClicking ? 10 : (isHovered ? 8 : 5)) * (1 - ratio);

						if (alpha <= 0.01 || width <= 0.1) continue;

						ctx.beginPath();
						ctx.moveTo(p1.x, p1.y);
						ctx.quadraticCurveTo(p2.x, p2.y, xc, yc);
						ctx.strokeStyle = isClicking ? `rgba(255, 255, 255, ${alpha})` : `rgba(249, 115, 22, ${alpha})`;
						ctx.lineWidth = width;
						ctx.lineCap = "round";
						ctx.lineJoin = "round";
						ctx.shadowBlur = i < 3 ? (isClicking ? 25 : (isHovered ? 15 : 10)) : 0;
						ctx.shadowColor = isClicking ? 'rgba(255, 255, 255, 0.8)' : 'rgba(249, 115, 22, 0.7)';
						ctx.stroke();
					}

					// Render soft plasma halo circular spark particles
					sparkParticles.forEach(p => {
						const ratio = p.age / p.maxAge;
						const currentAlpha = p.alpha * (1 - ratio);
						const currentSize = Math.max(0.1, p.size * (1 - ratio * 0.5));

						const radGrad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, currentSize);
						if (isClicking) {
							radGrad.addColorStop(0, `rgba(255, 255, 255, ${currentAlpha})`);
							radGrad.addColorStop(0.3, `rgba(249, 115, 22, ${currentAlpha * 0.7})`);
							radGrad.addColorStop(0.8, `rgba(249, 115, 22, ${currentAlpha * 0.15})`);
						} else {
							radGrad.addColorStop(0, `rgba(255, 255, 255, ${currentAlpha * 0.95})`);
							radGrad.addColorStop(0.2, `rgba(249, 115, 22, ${currentAlpha * 0.8})`);
							radGrad.addColorStop(0.7, `rgba(249, 115, 22, ${currentAlpha * 0.18})`);
						}
						radGrad.addColorStop(1, 'rgba(249, 115, 22, 0)');

						ctx.fillStyle = radGrad;
						ctx.beginPath();
						ctx.arc(p.x, p.y, currentSize, 0, Math.PI * 2);
						ctx.fill();
					});
				}

				// Render background particle system with hover interactions and scroll animations
				if (partCtx && partCanvas) {
					partCtx.clearRect(0, 0, partCanvas.width, partCanvas.height);
					
					const scrollDelta = currentScrollY - lastScrollY;
					lastScrollY = currentScrollY;

					const mouseDistLimit = 180;
					const connectDistLimit = isMobile ? 100 : 150;

					// 1. Update and draw particles
					bgParticles.forEach(p => {
						// Scroll parallax animation
						p.y -= scrollDelta * p.parallaxFactor;

						// Natural drift velocity
						p.x += p.vx;
						p.y += p.vy;

						// Edge wrapping
						if (p.x < 0) p.x = partCanvas.width;
						if (p.x > partCanvas.width) p.x = 0;
						if (p.y < 0) p.y = partCanvas.height;
						if (p.y > partCanvas.height) p.y = 0;

						// Hover interaction: calculate distance to mouse
						const dx = p.x - rawMouse.targetX;
						const dy = p.y - rawMouse.targetY;
						const dist = Math.sqrt(dx * dx + dy * dy);

						let activeAlpha = p.baseAlpha;
						let activeSize = p.size;

						if (dist < mouseDistLimit && !isMobile) {
							const force = 1 - dist / mouseDistLimit;
							
							// Gentle magnetic push away or pull
							p.x += (dx / dist) * force * 1.5;
							p.y += (dy / dist) * force * 1.5;

							// Brighten and enlarge near cursor
							activeAlpha = Math.min(0.85, p.baseAlpha + force * 0.5);
							activeSize = p.size * (1 + force * 0.8);

							// Draw subtle interactive beam to mouse cursor
							partCtx.beginPath();
							partCtx.moveTo(p.x, p.y);
							partCtx.lineTo(rawMouse.targetX, rawMouse.targetY);
							partCtx.strokeStyle = `rgba(249, 115, 22, ${force * 0.25})`;
							partCtx.lineWidth = 0.8;
							partCtx.stroke();
						}

						// Draw particle dot
						partCtx.beginPath();
						partCtx.arc(p.x, p.y, activeSize, 0, Math.PI * 2);
						partCtx.fillStyle = p.color;
						partCtx.globalAlpha = activeAlpha;
						partCtx.fill();
						partCtx.globalAlpha = 1.0; // reset
					});

					// 2. Draw subtle constellation/plexus connecting lines
					partCtx.lineWidth = 0.6;
					for (let i = 0; i < bgParticles.length; i++) {
						const p1 = bgParticles[i];
						for (let j = i + 1; j < bgParticles.length; j++) {
							const p2 = bgParticles[j];
							const dx = p1.x - p2.x;
							const dy = p1.y - p2.y;
							const dist = Math.sqrt(dx * dx + dy * dy);

							if (dist < connectDistLimit) {
								const alpha = (1 - dist / connectDistLimit) * 0.22;
								partCtx.beginPath();
								partCtx.moveTo(p1.x, p1.y);
								partCtx.lineTo(p2.x, p2.y);
								partCtx.strokeStyle = `rgba(255, 255, 255, ${alpha})`;
								partCtx.stroke();
							}
						}
					}
				}

				if (spatialElements.length > 0) {
					const radiusLimit = 280;

					spatialElements.forEach(el => {
						const rect = el.getBoundingClientRect();
						const cx = rect.left + rect.width / 2;
						const cy = rect.top + rect.height / 2;

						const dx = rawMouse.targetX - cx;
						const dy = rawMouse.targetY - cy;
						const distance = Math.sqrt(dx * dx + dy * dy);

						if (distance < radiusLimit) {
							const proximity = Math.max(0, 1 - distance / radiusLimit);
							const rx = rawMouse.targetX - rect.left;
							const ry = rawMouse.targetY - rect.top;

							el.style.setProperty("--mouse-x", `${rx}px`);
							el.style.setProperty("--mouse-y", `${ry}px`);
							el.style.setProperty("--proximity", proximity.toFixed(3));
						} else {
							el.style.setProperty("--proximity", "0");
						}
					});
				}

				blueprintData.forEach(data => {
					const proximity = parseFloat(data.card.style.getPropertyValue("--proximity") || "0");
					
					if (proximity > 0.01) {
						const rect = data.svg.getBoundingClientRect();
						const mX = rawMouse.targetX - rect.left;
						const mY = rawMouse.targetY - rect.top;
						
						const localX = (mX / rect.width) * 320;
						const localY = (mY / rect.height) * 80;
						
						data.nodeStates.forEach((ns: any) => {
							const dx = localX - ns.bx;
							const dy = localY - ns.by;
							const dist = Math.sqrt(dx * dx + dy * dy);
							const limit = 80;
							
							if (dist < limit) {
								const pull = (1 - dist / limit) * 8 * proximity;
								const angle = Math.atan2(dy, dx);
								ns.x.target = ns.bx + Math.cos(angle) * pull;
								ns.y.target = ns.by + Math.sin(angle) * pull;
							} else {
								ns.x.target = ns.bx;
								ns.y.target = ns.by;
							}
							
							const currX = ns.x.update();
							const currY = ns.y.update();
							ns.el.setAttribute("transform", `translate(${currX.toFixed(2)}, ${currY.toFixed(2)})`);
						});

						data.pathStates.forEach((ps: any) => {
							for (let i = 0; i < ps.coords.length; i += 2) {
								const px = ps.coords[i];
								const py = ps.coords[i+1];
								if (px === undefined || py === undefined) continue;

								const dx = localX - px;
								const dy = localY - py;
								const dist = Math.sqrt(dx * dx + dy * dy);
								const limit = 75;
								
								if (dist < limit) {
									const pull = (1 - dist / limit) * 9 * proximity;
									const angle = Math.atan2(dy, dx);
									ps.springs[i].target = px + Math.cos(angle) * pull;
									ps.springs[i+1].target = py + Math.sin(angle) * pull;
								} else {
									ps.springs[i].target = px;
									ps.springs[i+1].target = py;
								}
							}

							const originalParts = ps.baseD.split(/(-?[\d.]+)/);
							let coordCount = 0;
							const rebuiltParts = originalParts.map((part: string) => {
								if (/^-?[\d.]+$/.test(part)) {
									const currentVal = ps.springs[coordCount].update();
									coordCount++;
									return currentVal.toFixed(1);
								}
								return part;
							});
							
							ps.el.setAttribute("d", rebuiltParts.join(""));
						});
					} else {
						data.nodeStates.forEach((ns: any) => {
							ns.x.target = ns.bx;
							ns.y.target = ns.by;
							const currX = ns.x.update();
							const currY = ns.y.update();
							ns.el.setAttribute("transform", `translate(${currX.toFixed(2)}, ${currY.toFixed(2)})`);
						});

						data.pathStates.forEach((ps: any) => {
							for (let i = 0; i < ps.coords.length; i++) {
								ps.springs[i].target = ps.coords[i];
							}
							
							const originalParts = ps.baseD.split(/(-?[\d.]+)/);
							let coordCount = 0;
							const rebuiltParts = originalParts.map((part: string) => {
								if (/^-?[\d.]+$/.test(part)) {
									const currentVal = ps.springs[coordCount].update();
									coordCount++;
									return currentVal.toFixed(1);
								}
								return part;
							});
							ps.el.setAttribute("d", rebuiltParts.join(""));
						});
					}
				});
			}

			requestAnimationFrame(tick);
		}

		function triggerTransition() {
			if (loaderUiEl) {
				loaderUiEl.style.transform = "scale(0.92) translateY(-15px)";
				loaderUiEl.style.opacity = "0";
			}

			setTimeout(() => {
				if (loaderOverlayEl) {
					loaderOverlayEl.style.opacity = "0";
					loaderOverlayEl.style.pointerEvents = "none";
				}

				if (mainContentEl) {
					mainContentEl.style.opacity = "1";
					mainContentEl.style.transform = "translateY(0)";
					mainContentEl.style.pointerEvents = "all";
				}

				document.body.classList.remove("loading");

				const nav = document.querySelector("nav");
				if (nav) {
					nav.style.transform = "translateY(0)";
					nav.style.opacity = "1";
				}

				setTimeout(() => {
					if (loaderOverlayEl) {
						loaderOverlayEl.style.display = "none";
					}
				}, 1500);

			}, 400);
		}

		document.body.classList.add("loading");
		requestAnimationFrame(tick);
	});
</script>
