---
interface Props {
  name: string;
  badge: string;
  fullname: string;
  githubUrl: string;
}

const { name, badge, fullname, githubUrl } = Astro.props;
---
<div class="glass project-card reveal">
	<div class="project-header">
		<div class="project-title-area">
			<span class="project-icon">
				<slot name="icon" />
			</span>
			<h3 class="project-name">{name}</h3>
		</div>
		<span class="project-badge">{badge}</span>
	</div>
	
	<div class="project-body">
		<p class="project-fullname">{fullname}</p>
		
		<!-- Structured slots for editorial copy (Problem/Solution) -->
		<div class="project-details">
			<slot name="details" />
		</div>
	</div>

	<div class="project-footer">
		<div class="tech-stack">
			<slot name="tech" />
		</div>
		<div class="card-actions">
			<a href={githubUrl} target="_blank" rel="noopener" class="btn-action">GitHub ↗</a>
		</div>
	</div>
</div>

<style>
	.project-card {
		padding: 2.2rem;
		background: #101010;
		border: 1px solid var(--glass-border);
		border-radius: 12px;
		transition: var(--transition-medium);
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		height: 100%;
	}

	.project-card:hover {
		border-color: var(--accent);
		transform: translateY(-4px);
	}

	.project-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
		padding-bottom: 1rem;
	}

	.project-title-area {
		display: flex;
		align-items: center;
		gap: 0.8rem;
	}

	.project-icon {
		font-size: 1.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--accent);
	}

	.project-name {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 800;
		color: #f5f5f5;
		letter-spacing: -0.02em;
	}

	.project-badge {
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid var(--glass-border);
		color: #8a8a8a;
		font-size: 0.65rem;
		padding: 0.25rem 0.75rem;
		border-radius: 4px;
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		font-family: var(--font-tech);
	}

	.project-body {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		flex-grow: 1;
	}

	.project-fullname {
		color: var(--accent);
		font-size: 0.9rem;
		font-weight: 600;
		font-family: var(--font-tech);
		letter-spacing: 0.02em;
	}

	.project-details {
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		font-size: 0.95rem;
		line-height: 1.7;
		color: #8a8a8a;
	}

	.project-footer {
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
		margin-top: auto;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		padding-top: 1.2rem;
	}

	/* Tech Stack Badges */
	.tech-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	:global(.tech-badge) {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--glass-border);
		color: #8a8a8a;
		font-size: 0.7rem;
		padding: 0.3rem 0.75rem;
		border-radius: 4px;
		transition: var(--transition-fast);
		font-weight: 600;
		text-decoration: none;
	}

	:global(.tech-badge:hover) {
		border-color: #f5f5f5;
		color: #f5f5f5;
	}

	/* Action Buttons */
	.card-actions {
		display: flex;
	}

	.btn-action {
		flex: 1;
		padding: 0.6rem;
		border: 1px solid var(--glass-border);
		border-radius: 6px;
		color: #8a8a8a;
		text-decoration: none;
		font-family: var(--font-tech);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-align: center;
		transition: var(--transition-medium);
		background: transparent;
	}

	.btn-action:hover {
		border-color: #f5f5f5;
		color: #f5f5f5;
		transform: translateY(-1px);
	}
</style>
