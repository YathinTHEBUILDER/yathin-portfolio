---
import ProjectCard from './ProjectCard.astro';
---
<!-- PROJECTS -->
<section id="projects">
	<h2 class="section-title reveal">My <span>Projects</span></h2>
	<div class="title-bar reveal"></div>
	<p style="color:#888;margin-bottom:2.5rem;font-size:0.95rem;" class="reveal">
		Things I've actually built — not just studied.
	</p>
	<div class="projects-grid">
		<!-- Project 1: InvoiceFlow -->
		<ProjectCard
			id="INV_FLOW"
			status="SYS.ONLINE // SEC_01"
			name="InvoiceFlow"
			badge="Active"
			fullname="Co-Financing Invoice Discounting Platform"
			desc="A shared retail investor invoice financing platform for Indian MSMEs. Solves working capital shortages by fractionally co-financing GST-verified invoices with automated trust, funding, and settlement engines."
			githubUrl="https://github.com/YathinTHEBUILDER/InvoiceFlow"
		>
			<svg slot="icon" viewBox="0 0 24 24" width="1em" height="1em" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" style="color: #10b981;">
				<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
			</svg>
			<svg slot="blueprint" class="blueprint-svg" viewBox="0 0 320 80">
				<path class="connection-path" d="M40,40 L120,25 L200,55 L280,40"></path>
				<path class="connection-path" d="M120,25 L280,40"></path>
				<path class="signal-pulse" d="M40,40 L120,25 L200,55 L280,40"></path>
				<g class="blueprint-node" transform="translate(40, 40)">
					<circle class="node-dot" r="6"></circle>
					<text class="node-text" x="0" y="18" text-anchor="middle">MSME / INV</text>
				</g>
				<g class="blueprint-node" transform="translate(120, 25)">
					<circle class="node-dot" r="8"></circle>
					<text class="node-text" x="0" y="20" text-anchor="middle">NEXT.JS</text>
				</g>
				<g class="blueprint-node" transform="translate(200, 55)">
					<circle class="node-dot" r="6"></circle>
					<text class="node-text" x="0" y="18" text-anchor="middle">TRUST ENG</text>
				</g>
				<g class="blueprint-node" transform="translate(280, 40)">
					<circle class="node-dot" r="8"></circle>
					<text class="node-text" x="0" y="20" text-anchor="middle">SUPABASE</text>
				</g>
			</svg>
			<a slot="tech" href="https://nextjs.org/" target="_blank" rel="noopener" class="tech-badge" style="display:inline-flex;align-items:center;gap:0.3rem;text-decoration:none;">
