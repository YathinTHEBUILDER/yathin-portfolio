---
import ProjectCard from './ProjectCard.astro';
---
<!-- PROJECTS -->
<section id="projects">
	<h2 class="section-title reveal">Featured work</h2>
	<p class="section-subtitle reveal">
		Projects I’ve built while learning, experimenting, and shipping.
	</p>
	
	<div class="featured-projects-container">
		<!-- Primary Hero Project Card: InvoiceFlow -->
		<div class="hero-project-wrap">
			<ProjectCard
				name="InvoiceFlow"
				badge="Active prototype"
				fullname="MSME invoice financing platform for Indian businesses."
				githubUrl="https://github.com/YathinTHEBUILDER/InvoiceFlow"
				statusType="blue"
			>
				<div slot="details">
					<p><strong>Problem:</strong> MSMEs often wait too long for invoice payments, which affects working capital.</p>
					<p><strong>What I built:</strong> A role-based platform with MSME, investor, and admin workflows for invoice upload, verification, funding, and dashboard management.</p>
				</div>
				<span slot="tech" class="tech-badge">Next.js</span>
				<span slot="tech" class="tech-badge">Supabase</span>
				<span slot="tech" class="tech-badge">TypeScript</span>
				<span slot="tech" class="tech-badge">Vercel</span>
			</ProjectCard>
		</div>

		<!-- Grid of other projects: Skillqore, J.A.R.V.I.S, F.R.I.D.A.Y -->
		<div class="secondary-projects-grid">
			<!-- Project 2: Skillqore -->
			<ProjectCard
				name="Skillqore"
				badge="Stable"
				fullname="AI resume and career roadmap platform."
				githubUrl="https://github.com/YathinTHEBUILDER/Skillqore"
				statusType="green"
			>
				<div slot="details">
					<p><strong>Problem:</strong> Hackathon developers and students struggle to dynamically align learning goals and analyze skills gaps relative to live job profiles.</p>
					<p><strong>What I built:</strong> An AI pipeline that extracts resumes, benchmarks capabilities, and maps out targeted learning pathways.</p>
				</div>
				<span slot="tech" class="tech-badge">React</span>
				<span slot="tech" class="tech-badge">Supabase</span>
				<span slot="tech" class="tech-badge">Tailwind</span>
				<span slot="tech" class="tech-badge">Gemini API</span>
			</ProjectCard>

			<!-- Project 3: J.A.R.V.I.S -->
			<ProjectCard
				name="J.A.R.V.I.S"
				badge="Stable"
				fullname="Personal AI assistant experiment."
				githubUrl="https://github.com/YathinTHEBUILDER/J.A.R.V.I.S_Stable"
				statusType="yellow"
			>
				<div slot="details">
					<p><strong>Problem:</strong> Standard desktop AI agents have high latency and lack up-to-the-minute web indexing for engineering questions.</p>
					<p><strong>What I built:</strong> A conversational local agent integrating Tavily live search with ultra-low latency Groq LPU inference for instant feedback loops.</p>
				</div>
				<span slot="tech" class="tech-badge">Python</span>
				<span slot="tech" class="tech-badge">Groq API</span>
				<span slot="tech" class="tech-badge">Tavily API</span>
				<span slot="tech" class="tech-badge">FastAPI</span>
			</ProjectCard>

			<!-- Project 4: F.R.I.D.A.Y -->
			<ProjectCard
				name="F.R.I.D.A.Y"
				badge="Stable"
				fullname="Realtime multimodal assistant experiment."
				githubUrl="https://github.com/YathinTHEBUILDER/F.R.I.D.A.Y_Stable"
				statusType="red"
			>
				<div slot="details">
					<p><strong>Problem:</strong> Digital assistants are mostly single-mode text portals, lacking situational computer vision or live vocal reasoning capabilities.</p>
					<p><strong>What I built:</strong> A multimodal agent utilizing Gemini API to process live webcam streams and audio feeds simultaneously for natural voice interactions.</p>
				</div>
				<span slot="tech" class="tech-badge">Python</span>
				<span slot="tech" class="tech-badge">Gemini API</span>
				<span slot="tech" class="tech-badge">OpenCV</span>
				<span slot="tech" class="tech-badge">WebRTC</span>
			</ProjectCard>
		</div>
	</div>

	<div class="more-projects reveal">
		<a
			href="https://github.com/YathinTHEBUILDER"
			target="_blank"
			rel="noopener"
			class="btn-secondary"
		>
			<span>Explore more on GitHub</span>
			<span>→</span>
		</a>
	</div>
</section>

<style>
	#projects {
		position: relative;
	}

	.featured-projects-container {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.secondary-projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 3rem;
	}

	.more-projects {
		text-align: center;
		margin-top: 4rem;
	}

	/* Elegant grid staggers hover effect: fade other cards when hovering one */
	.secondary-projects-grid:has(:hover) :global(.project-card:not(:hover)) {
		opacity: 0.5;
		transform: scale(0.98);
	}

	/* Premium 2-Column Hero layout for desktop */
	@media (min-width: 1024px) {
		.hero-project-wrap :global(.project-card) {
			display: grid;
			grid-template-columns: 1.5fr 1fr;
			gap: 3.5rem;
		}
		.hero-project-wrap :global(.project-footer) {
			border-top: none;
			padding-top: 0;
			border-left: 1px solid var(--border);
			padding-left: 3.5rem;
			margin-top: 0;
			justify-content: center;
		}
	}
</style>
