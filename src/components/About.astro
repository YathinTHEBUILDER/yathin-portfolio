---
// About.astro
---
<!-- ABOUT -->
<section id="about">
	<h2 class="section-title reveal">About <span>Me</span></h2>
	<div class="title-bar reveal"></div>
	<div class="about-grid">
		<!-- Left Editorial Panel -->
		<div class="about-sidebar reveal">
			<p class="about-name">Yathin G</p>
			<p class="about-role">Software Builder & Developer</p>
			<p class="about-loc">
				<svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
				Mysuru, Karnataka 🇮🇳
			</p>
		</div>
		
		<!-- Right Content Panel -->
		<div class="about-content-wrapper">
			<div class="about-status-badge reveal">
				<span class="badge-text">Biography</span>
			</div>
			<div class="about-bio-card reveal">
				<p class="about-bio">
					I’m a Computer Science & Engineering student based in Mysuru, dedicated to building practical AI tools and high-quality web applications. I focus on creating useful software that solves real-world challenges, prioritizing clean backend logic and responsive user interfaces.
					<br /><br />
					Python first. Interfaces second. Execution always.
				</p>
			</div>
			
			<!-- Stats Grid -->
			<div class="stats-grid reveal">
				<div class="glass stat-card">
					<span class="stat-number">4+</span>
					<p class="stat-label">Featured Projects</p>
				</div>
				<div class="glass stat-card">
					<span class="stat-number">CSE</span>
					<p class="stat-label">Engineering Degree</p>
				</div>
				<div class="glass stat-card">
					<span class="stat-number">Mysuru</span>
					<p class="stat-label">Location</p>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	/* ABOUT */
	.about-grid {
		display: grid;
		grid-template-columns: 1fr 2fr;
		gap: 4rem;
		align-items: start;
	}

	.about-sidebar {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.5rem;
	}

	.about-name {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 2.2rem;
		letter-spacing: -0.03em;
		color: #f5f5f5;
	}

	.about-role {
		color: var(--accent);
		font-size: 1rem;
		font-weight: 600;
		font-family: var(--font-tech);
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.about-loc {
		color: #8a8a8a;
		font-size: 0.9rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-top: 1rem;
	}

	/* About Content Box */
	.about-content-wrapper {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.about-status-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.4rem 1rem;
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--glass-border);
		border-radius: 4px;
		color: var(--accent);
		font-family: var(--font-tech);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		align-self: flex-start;
	}

	.about-bio-card {
		position: relative;
		background: #111111;
		border: 1px solid var(--glass-border);
		border-radius: 12px;
		padding: 2.5rem;
		box-shadow: 0 10px 30px rgba(0,0,0,0.5);
	}

	.about-bio {
		line-height: 1.8;
		color: #cbd5e1;
		font-size: 1.05rem;
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.2rem;
	}

	.stat-card {
		padding: 1.8rem 1.2rem;
		text-align: center;
		border-radius: 12px;
		background: #111111;
		border: 1px solid var(--glass-border);
		transition: var(--transition-medium);
	}
	.stat-card:hover {
		transform: translateY(-4px);
		border-color: rgba(249, 115, 22, 0.3);
	}

	.stat-number {
		font-family: var(--font-tech);
		font-size: 2rem;
		font-weight: 800;
		color: var(--accent);
		display: block;
		letter-spacing: -0.02em;
		margin-bottom: 0.4rem;
	}

	.stat-label {
		font-size: 0.75rem;
		color: #8a8a8a;
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		font-family: var(--font-sans);
	}

	@media (max-width: 768px) {
		.about-grid {
			grid-template-columns: 1fr;
			gap: 3rem;
		}
		.stats-grid {
			grid-template-columns: repeat(3, 1fr);
			gap: 0.8rem;
		}
		.stat-card {
			padding: 1.2rem 0.8rem;
		}
		.stat-number {
			font-size: 1.5rem;
		}
		.stat-label {
			font-size: 0.65rem;
		}
	}
</style>
