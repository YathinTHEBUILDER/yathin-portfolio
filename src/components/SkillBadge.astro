---
interface Props {
  href?: string;
  isMajor?: boolean;
}

const { href, isMajor = false } = Astro.props;
const Element = href ? 'a' : 'span';
---
<Element
  href={href}
  target={href ? "_blank" : undefined}
  rel={href ? "noopener" : undefined}
  class={`skill-badge ${isMajor ? 'major-mastery' : ''}`}
>
	<slot name="icon" />
	<slot />
	{isMajor && <span class="mastery-tag">Major Mastery</span>}
</Element>

<style>
	.skill-badge {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		padding: 0.6rem 1.2rem;
		border-radius: 12px;
		font-family: var(--font-tech);
		font-size: 0.85rem;
		font-weight: 600;
		color: #cbd5e1;
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		backdrop-filter: blur(10px);
		box-shadow: inset 0 1px 1px rgba(255,255,255,0.05);
		text-decoration: none;
		cursor: default;
	}

	/* Force cursor pointer for links */
	a.skill-badge {
		cursor: pointer;
	}

	.skill-badge:hover {
		transform: translateY(-3px) scale(1.05);
		border-color: var(--accent);
		background: rgba(249, 115, 22, 0.12);
		color: #fff;
		box-shadow: 0 10px 25px rgba(249, 115, 22, 0.25), inset 0 1px 1px rgba(255,255,255,0.1);
	}

	:global(.skill-badge) svg {
		width: 16px;
		height: 16px;
		fill: currentColor;
	}

	.skill-badge.major-mastery {
		background: linear-gradient(135deg, rgba(249, 115, 22, 0.25), rgba(249, 115, 22, 0.08));
		border: 1px solid rgba(249, 115, 22, 0.6);
		color: #fff;
		box-shadow: 0 0 20px rgba(249, 115, 22, 0.2), inset 0 1px 1px rgba(255,255,255,0.2);
		font-weight: 800;
		letter-spacing: 0.05em;
	}

	.skill-badge.major-mastery:hover {
		background: linear-gradient(135deg, rgba(249, 115, 22, 0.4), rgba(249, 115, 22, 0.15));
		border-color: rgba(249, 115, 22, 0.9);
		box-shadow: 0 0 30px rgba(249, 115, 22, 0.4), inset 0 1px 1px rgba(255,255,255,0.3);
	}

	.mastery-tag {
		font-size: 0.65rem;
		background: var(--accent);
		color: #000;
		padding: 0.15rem 0.5rem;
		border-radius: 4px;
		font-weight: 800;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		margin-left: 0.2rem;
		box-shadow: 0 0 10px var(--accent);
	}
</style>
