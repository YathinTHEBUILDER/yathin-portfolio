---
// Contact.astro
---
<!-- CONTACT -->
<section id="contact">
	<h2 class="section-title reveal">Contact</h2>
	<div class="title-bar reveal" style="margin:0.5rem auto 2rem;">
	</div>
	<h3 class="contact-heading reveal">
		Let's connect
	</h3>
	<p class="contact-sub reveal">
		Open to discussions on full stack development, product design, or strategic collaborations.
	</p>
	<div class="contact-grid">
		<a
			href="https://github.com/YathinTHEBUILDER"
			target="_blank"
			rel="noopener"
			class="glass contact-card reveal"
		>
			<span class="contact-icon">
