---
// Contact.astro
---
<!-- CONTACT -->
<section id="contact" class="contact-section">
	<h2 class="section-title reveal">Contact</h2>
	<div class="title-divider reveal"></div>
	
	<h3 class="contact-heading reveal">Let’s build something useful.</h3>
	<p class="contact-sub reveal">
		Open to collaborations, hackathons, student tech projects, and product experiments.
	</p>
	
	<!-- 3 Social Cards -->
	<div class="contact-grid">
		<a
			href="mailto:yathingnaneshwar@gmail.com"
			class="card-premium contact-card reveal"
		>
			<span class="contact-icon icon-red">
				<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
			</span>
			<span class="contact-label">Email</span>
			<span class="contact-value">yathingnaneshwar@gmail.com</span>
		</a>

		<a
			href="https://github.com/YathinTHEBUILDER"
			target="_blank"
			rel="noopener"
			class="card-premium contact-card reveal"
		>
			<span class="contact-icon icon-blue">
				<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
			</span>
			<span class="contact-label">GitHub</span>
			<span class="contact-value">@YathinTHEBUILDER</span>
		</a>

		<a
			href="https://www.linkedin.com/in/yathin-gnaneshwar-5133b4367"
			target="_blank"
			rel="noopener"
			class="card-premium contact-card reveal"
		>
			<span class="contact-icon icon-green">
				<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
			</span>
			<span class="contact-label">LinkedIn</span>
			<span class="contact-value">Yathin Gnaneshwar</span>
		</a>
	</div>

	<!-- Formspree Secure Form -->
	<div class="contact-form-container reveal">
		<form id="contact-form" class="card-premium contact-form">
			<div class="form-group">
				<label for="name" class="form-label">Name</label>
				<input type="text" id="name" name="name" class="form-input" required placeholder="Enter your name" />
			</div>
			<div class="form-group">
				<label for="email" class="form-label">Email</label>
				<input type="email" id="email" name="email" class="form-input" required placeholder="Enter your email address" />
			</div>
			<div class="form-group">
				<label for="message" class="form-label">Message</label>
				<textarea id="message" name="message" class="form-textarea" required placeholder="Write your message here..."></textarea>
			</div>
			<button type="submit" id="contact-submit-btn" class="btn-primary" style="justify-content: center; width: 100%; margin-top: 0.5rem;">
				<span>Send Message</span>
				<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 0.3rem;"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
			</button>
		</form>
	</div>

	<p class="contact-location reveal">
		Currently based in Mysuru, Karnataka, India 🇮🇳<br />
		Open to remote collaborations worldwide.
	</p>
</section>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const form = document.getElementById('contact-form');
		const btn = document.getElementById('contact-submit-btn');
		
		// Rate Limiting Constants
		const COOLDOWN_MS = 60 * 1000; // 1 minute cooldown
		const MAX_DAILY_SUBMITS = 5;
		const DAY_MS = 24 * 60 * 60 * 1000; // 24 hours

		function getRateLimitState() {
			try {
				const data = localStorage.getItem('nexus_contact_rate_limit');
				return data ? JSON.parse(data) : { lastSubmitTime: 0, dailySubmits: [] };
			} catch (e) {
				return { lastSubmitTime: 0, dailySubmits: [] };
			}
		}

		function saveRateLimitState(state) {
			try {
				localStorage.setItem('nexus_contact_rate_limit', JSON.stringify(state));
			} catch (e) {}
		}

		function updateButtonCooldown() {
			if (!btn) return;
			const state = getRateLimitState();
			const now = Date.now();
			
			const recentDaily = state.dailySubmits.filter(t => now - t < DAY_MS);
			if (recentDaily.length !== state.dailySubmits.length) {
				state.dailySubmits = recentDaily;
				saveRateLimitState(state);
			}

			if (recentDaily.length >= MAX_DAILY_SUBMITS) {
				const earliestSubmit = Math.min(...recentDaily);
				const resetTimeRemaining = DAY_MS - (now - earliestSubmit);
				const hoursLeft = Math.ceil(resetTimeRemaining / (1000 * 60 * 60));
				btn.disabled = true;
				const btnText = btn.querySelector('span');
				if (btnText) {
					btnText.innerText = `Limit Exceeded (Reset: ${hoursLeft}h)`;
				}
				return true;
			}

			const elapsed = now - state.lastSubmitTime;
			if (elapsed < COOLDOWN_MS) {
				const remaining = Math.ceil((COOLDOWN_MS - elapsed) / 1000);
				btn.disabled = true;
				const btnText = btn.querySelector('span');
				if (btnText) {
					btnText.innerText = `Cooldown: ${remaining}s`;
				}
				
				setTimeout(updateButtonCooldown, 1000);
				return true;
			}

			btn.disabled = false;
			const btnText = btn.querySelector('span');
			if (btnText) {
				btnText.innerText = 'Send Message';
			}
			return false;
		}

		updateButtonCooldown();
		
		if(form) {
			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				
				const now = Date.now();
				const state = getRateLimitState();
				
				const elapsed = now - state.lastSubmitTime;
				if (elapsed < COOLDOWN_MS) {
					const remaining = Math.ceil((COOLDOWN_MS - elapsed) / 1000);
					alert(`Rate Limit: Please wait ${remaining} seconds before sending another message.`);
					return;
				}
				
				const recentDaily = state.dailySubmits.filter(t => now - t < DAY_MS);
				if (recentDaily.length >= MAX_DAILY_SUBMITS) {
					alert(`Daily Limit: You have reached the maximum of ${MAX_DAILY_SUBMITS} messages per 24 hours. Please try again tomorrow.`);
					return;
				}

				const originalContent = btn.innerHTML;
				btn.innerHTML = '<span>Transmitting...</span>';
				btn.disabled = true;
				
				try {
					const response = await fetch('https://formspree.io/f/xaqkygpk', {
						method: 'POST',
						body: new FormData(form),
						headers: { 'Accept': 'application/json' }
					});
					
					if (response.ok) {
						alert('Thanks! Your message has been sent securely.');
						form.reset();
						
						const updatedState = getRateLimitState();
						updatedState.lastSubmitTime = Date.now();
						updatedState.dailySubmits.push(Date.now());
						saveRateLimitState(updatedState);
						
						updateButtonCooldown();
					} else {
						const data = await response.json();
						if (Object.hasOwn(data, 'errors')) {
							alert('Error: ' + data.errors.map(err => err.message).join(', '));
						} else {
							alert('System error: unable to transmit message. Please try again.');
						}
						btn.innerHTML = originalContent;
						btn.disabled = false;
					}
				} catch (error) {
					alert('Network error: unable to reach the server. Please check your connection.');
					btn.innerHTML = originalContent;
					btn.disabled = false;
				}
			});
		}
	});
</script>

<style>
	.contact-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.title-divider {
		width: 40px;
		height: 3px;
		background: var(--accent-blue);
		border-radius: 2px;
		margin-bottom: 2.5rem;
	}

	.contact-heading {
		font-family: var(--font-display);
		font-size: clamp(1.5rem, 3.5vw, 2.2rem);
		font-weight: 700;
		color: var(--text-primary);
		margin-bottom: 1rem;
		letter-spacing: -0.02em;
	}

	.contact-sub {
		color: var(--text-muted);
		max-width: 550px;
		margin: 0 auto 3.5rem;
		line-height: 1.6;
		font-size: 1.05rem;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
		width: 100%;
		max-width: 900px;
		margin: 0 auto 3rem;
	}

	.contact-card {
		padding: 2.2rem 1.5rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.8rem;
		text-decoration: none;
		color: inherit;
	}

	.contact-icon {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: var(--transition-medium);
	}

	.icon-red { background: rgba(234, 67, 53, 0.08); color: var(--accent-red); }
	.icon-blue { background: rgba(26, 115, 232, 0.08); color: var(--accent-blue); }
	.icon-green { background: rgba(24, 128, 56, 0.08); color: var(--accent-green); }

	.contact-card:hover .contact-icon {
		transform: scale(1.1);
	}

	.contact-label {
		font-family: var(--font-display);
		font-size: 1.05rem;
		font-weight: 700;
		color: var(--text-primary);
	}

	.contact-value {
		color: var(--text-muted);
		font-size: 0.85rem;
		font-family: var(--font-sans);
		word-break: break-all;
	}

	.contact-form-container {
		width: 100%;
		max-width: 600px;
		margin: 0 auto 3.5rem;
	}

	.contact-form {
		padding: 2.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		text-align: left;
		background: var(--bg-soft);
	}

	.contact-form:hover {
		transform: none; /* remove hover translation on contact form card */
		box-shadow: var(--shadow-md);
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.form-label {
		font-family: var(--font-tech);
		font-size: 0.75rem;
		color: var(--text-muted);
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.form-input, .form-textarea {
		background: #ffffff;
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 0.8rem 1rem;
		color: var(--text-primary);
		font-family: var(--font-sans);
		font-size: 0.95rem;
		transition: var(--transition-fast);
		outline: none;
	}

	.form-input:focus, .form-textarea:focus {
		border-color: var(--accent-blue);
		box-shadow: 0 0 0 3px rgba(26, 115, 232, 0.12);
	}

	.form-input::placeholder, .form-textarea::placeholder {
		color: #9ca3af;
	}

	.form-textarea {
		resize: vertical;
		min-height: 120px;
	}

	.contact-location {
		color: var(--text-muted);
		font-size: 0.85rem;
		line-height: 1.7;
	}

	@media (max-width: 768px) {
		.contact-grid {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.contact-card {
			padding: 1.8rem;
		}

		.contact-form {
			padding: 1.8rem;
		}
	}
</style>
