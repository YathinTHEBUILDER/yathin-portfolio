			</span>
			<span class="contact-label">GitHub</span>
			<span class="contact-sub-label">@YathinTHEBUILDER</span>
		</a>
		<a
			href="https://www.linkedin.com/in/yathin-gnaneshwar-5133b4367"
			target="_blank"
			rel="noopener"
			class="glass contact-card reveal"
		>
			<span class="contact-icon">
				<svg viewBox="0 0 24 24" width="36" height="36" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
			</span>
			<span class="contact-label">LinkedIn</span>
			<span class="contact-sub-label">Yathin</span>
		</a>
		<a
			href="https://www.instagram.com/yathin_gnaneshwar"
			target="_blank"
			rel="noopener"
			class="glass contact-card reveal"
		>
			<span class="contact-icon">
				<svg viewBox="0 0 24 24" width="36" height="36" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
			</span>
			<span class="contact-label">Instagram</span>
			<span class="contact-sub-label">@yathin_gnaneshwar</span>
		</a>
	</div>

	<div class="contact-form-container reveal">
		<form id="contact-form" class="contact-form">
			<div class="form-group">
				<label for="name" class="form-label">Name</label>
				<input type="text" id="name" name="name" class="form-input" required placeholder="Enter your name" />
			</div>
			<div class="form-group">
				<label for="email" class="form-label">Email</label>
				<input type="email" id="email" name="email" class="form-input" required placeholder="Enter your email address" />
			</div>
			<div class="form-group">
				<label for="message" class="form-label">Message</label>
				<textarea id="message" name="message" class="form-textarea" required placeholder="Write your message here..."></textarea>
			</div>
			<button type="submit" id="contact-submit-btn" class="btn-primary" style="justify-content: center; width: 100%; margin-top: 0.5rem;">
				<span>Send Message</span>
				<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 0.3rem;"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
			</button>
		</form>
	</div>

	<p class="contact-location reveal">
		Currently based in Mysuru, Karnataka, India 🇮🇳<br />
		Open to remote collaborations worldwide.
	</p>
</section>

<script is:inline>
	document.addEventListener('DOMContentLoaded', () => {
		const form = document.getElementById('contact-form');
		const btn = document.getElementById('contact-submit-btn');
		
		// Rate Limiting Constants
		const COOLDOWN_MS = 60 * 1000; // 1 minute cooldown
		const MAX_DAILY_SUBMITS = 5;
		const DAY_MS = 24 * 60 * 60 * 1000; // 24 hours

		// Helper to get rate limit state from localStorage
		function getRateLimitState() {
			try {
				const data = localStorage.getItem('nexus_contact_rate_limit');
				return data ? JSON.parse(data) : { lastSubmitTime: 0, dailySubmits: [] };
			} catch (e) {
				return { lastSubmitTime: 0, dailySubmits: [] };
			}
		}

		// Helper to save rate limit state to localStorage
		function saveRateLimitState(state) {
			try {
				localStorage.setItem('nexus_contact_rate_limit', JSON.stringify(state));
			} catch (e) {}
		}

		// Update button state with countdown if in cooldown
		function updateButtonCooldown() {
			if (!btn) return;
			const state = getRateLimitState();
			const now = Date.now();
			
			// Filter daily submissions older than 24h
			const recentDaily = state.dailySubmits.filter(t => now - t < DAY_MS);
			if (recentDaily.length !== state.dailySubmits.length) {
				state.dailySubmits = recentDaily;
				saveRateLimitState(state);
			}

			// Check daily limit first
			if (recentDaily.length >= MAX_DAILY_SUBMITS) {
				const earliestSubmit = Math.min(...recentDaily);
				const resetTimeRemaining = DAY_MS - (now - earliestSubmit);
				const hoursLeft = Math.ceil(resetTimeRemaining / (1000 * 60 * 60));
				btn.disabled = true;
				const btnText = btn.querySelector('span');
				if (btnText) {
					btnText.innerText = `Limit Exceeded (Reset: ${hoursLeft}h)`;
				}
				return true; // daily limit active
			}

			// Check active cooldown
			const elapsed = now - state.lastSubmitTime;
			if (elapsed < COOLDOWN_MS) {
				const remaining = Math.ceil((COOLDOWN_MS - elapsed) / 1000);
				btn.disabled = true;
				const btnText = btn.querySelector('span');
				if (btnText) {
					btnText.innerText = `Cooldown: ${remaining}s`;
				}
				
				// Poll every second to update button text
				setTimeout(updateButtonCooldown, 1000);
				return true; // cooldown active
			}

			// Reset button state
			btn.disabled = false;
			const btnText = btn.querySelector('span');
			if (btnText) {
				btnText.innerText = 'Send Message';
			}
			return false;
		}

		// Initial run to restore any active cooldown/limit
		updateButtonCooldown();
		
		if(form) {
			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				
				const now = Date.now();
				const state = getRateLimitState();
				
				// Double check rate limits on submit trigger
				const elapsed = now - state.lastSubmitTime;
				if (elapsed < COOLDOWN_MS) {
					const remaining = Math.ceil((COOLDOWN_MS - elapsed) / 1000);
					alert(`Rate Limit: Please wait ${remaining} seconds before sending another message.`);
					return;
				}
				
				const recentDaily = state.dailySubmits.filter(t => now - t < DAY_MS);
				if (recentDaily.length >= MAX_DAILY_SUBMITS) {
					alert(`Daily Limit: You have reached the maximum of ${MAX_DAILY_SUBMITS} messages per 24 hours. Please try again tomorrow.`);
					return;
				}

				const originalContent = btn.innerHTML;
				btn.innerHTML = '<span>Transmitting...</span>';
				btn.disabled = true;
				
				try {
					const response = await fetch('https://formspree.io/f/xaqkygpk', {
						method: 'POST',
						body: new FormData(form),
						headers: { 'Accept': 'application/json' }
					});
					
					if (response.ok) {
						alert('Thanks! Your message has been sent securely.');
						form.reset();
						
						// Record successful submission
						const updatedState = getRateLimitState();
						updatedState.lastSubmitTime = Date.now();
						updatedState.dailySubmits.push(Date.now());
						saveRateLimitState(updatedState);
						
						// Start button cooldown countdown
						updateButtonCooldown();
					} else {
						const data = await response.json();
						if (Object.hasOwn(data, 'errors')) {
							alert('Error: ' + data.errors.map(err => err.message).join(', '));
						} else {
							alert('System error: unable to transmit message. Please try again.');
						}
						btn.innerHTML = originalContent;
						btn.disabled = false;
					}
				} catch (error) {
					alert('Network error: unable to reach the server. Please check your connection.');
					btn.innerHTML = originalContent;
					btn.disabled = false;
				}
			});
		}
	});
</script>

<style>
	/* CONTACT */
	#contact {
		text-align: center;
	}

	.contact-heading {
		font-family: var(--font-display);
		font-size: clamp(1.4rem, 3.5vw, 2.2rem);
		font-weight: 800;
		margin-bottom: 1rem;
		letter-spacing: -0.02em;
	}

	.contact-sub {
		color: #888;
		max-width: 550px;
		margin: 0 auto 3rem;
		line-height: 1.7;
		font-size: 0.95rem;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.5rem;
		max-width: 800px;
		margin: 0 auto 2.5rem;
	}

	.contact-card {
		padding: 2rem 1.5rem;
		text-align: center;
		text-decoration: none;
		color: inherit;
		background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
		border: 1px solid rgba(255,255,255,0.05);
		border-radius: 20px;
		backdrop-filter: blur(12px);
		transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.8rem;
	}
	.contact-card:hover {
		border-color: rgba(249, 115, 22, 0.5);
		box-shadow: 0 15px 35px rgba(0,0,0,0.5), inset 0 0 20px rgba(249, 115, 22, 0.1);
		transform: translateY(-6px);
	}

	.contact-icon {
		font-size: 2.5rem;
		color: #cbd5e1;
		transition: all 0.4s ease;
		display: flex;
		align-items: center;
		justify-content: center;
		filter: drop-shadow(0 0 5px rgba(255,255,255,0.1));
	}
	.contact-card:hover .contact-icon {
		color: var(--accent);
		transform: scale(1.15) translateY(-2px);
		filter: drop-shadow(0 0 15px var(--accent-glow));
	}
	.contact-label {
		font-family: var(--font-display);
		font-size: 0.95rem;
		font-weight: 700;
	}
	.contact-sub-label {
		color: #666;
		font-size: 0.75rem;
	}

	.contact-location {
		color: #666;
		font-size: 0.85rem;
		line-height: 1.8;
	}

	.contact-form-container {
		max-width: 600px;
		margin: 0 auto 3rem;
	}
	.contact-form {
		padding: 2.5rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		text-align: left;
		background: linear-gradient(145deg, rgba(20,20,20,0.6), rgba(10,10,10,0.8));
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 20px;
		backdrop-filter: blur(20px);
		box-shadow: 0 20px 40px rgba(0,0,0,0.6), inset 0 1px 1px rgba(255,255,255,0.05);
	}
	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.form-label {
		font-family: var(--font-tech);
		font-size: 0.85rem;
		color: #cbd5e1;
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}
	.form-input, .form-textarea {
		background: rgba(0, 0, 0, 0.4);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 12px;
		padding: 1rem 1.2rem;
		color: #fff;
		font-family: var(--font-sans);
		font-size: 1rem;
		transition: all 0.3s ease;
		outline: none;
	}
	.form-input:focus, .form-textarea:focus {
		border-color: var(--accent);
		box-shadow: 0 0 15px rgba(249, 115, 22, 0.2);
		background: rgba(0, 0, 0, 0.6);
	}
	.form-input::placeholder, .form-textarea::placeholder {
		color: #64748b;
	}
	.form-textarea {
		resize: vertical;
		min-height: 120px;
	}
</style>
