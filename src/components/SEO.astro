---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Yathin | Full Stack Developer & AI Engineer",
  description = "Portfolio of Yathin — Full Stack Developer and AI Engineer exploring machine intelligence and modern web architectures."
} = Astro.props;
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="theme-color" content="#1a73e8" />

<!-- Google Fonts: Premium AI & Engineering Pack -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
	rel="stylesheet"
/>

