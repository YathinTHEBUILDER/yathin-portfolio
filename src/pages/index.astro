			<script is:inline>
				document.addEventListener('DOMContentLoaded', () => {
					const form = document.getElementById('contact-form');
					const btn = document.getElementById('contact-submit-btn');
					
					// Rate Limiting Constants
					const COOLDOWN_MS = 60 * 1000; // 1 minute cooldown
					const MAX_DAILY_SUBMITS = 5;
					const DAY_MS = 24 * 60 * 60 * 1000; // 24 hours

					// Helper to get rate limit state from localStorage
					function getRateLimitState() {
						try {
							const data = localStorage.getItem('nexus_contact_rate_limit');
							return data ? JSON.parse(data) : { lastSubmitTime: 0, dailySubmits: [] };
						} catch (e) {
							return { lastSubmitTime: 0, dailySubmits: [] };
						}
					}

					// Helper to save rate limit state to localStorage
					function saveRateLimitState(state) {
						try {
							localStorage.setItem('nexus_contact_rate_limit', JSON.stringify(state));
						} catch (e) {}
					}

					// Update button state with countdown if in cooldown
					function updateButtonCooldown() {
						if (!btn) return;
						const state = getRateLimitState();
						const now = Date.now();
						
						// Filter daily submissions older than 24h
						const recentDaily = state.dailySubmits.filter(t => now - t < DAY_MS);
						if (recentDaily.length !== state.dailySubmits.length) {
							state.dailySubmits = recentDaily;
							saveRateLimitState(state);
						}

						// Check daily limit first
						if (recentDaily.length >= MAX_DAILY_SUBMITS) {
							const earliestSubmit = Math.min(...recentDaily);
							const resetTimeRemaining = DAY_MS - (now - earliestSubmit);
							const hoursLeft = Math.ceil(resetTimeRemaining / (1000 * 60 * 60));
							btn.disabled = true;
							const btnText = btn.querySelector('span');
							if (btnText) {
								btnText.innerText = `Limit Exceeded (Reset: ${hoursLeft}h)`;
							}
							return true; // daily limit active
						}

						// Check active cooldown
						const elapsed = now - state.lastSubmitTime;
						if (elapsed < COOLDOWN_MS) {
							const remaining = Math.ceil((COOLDOWN_MS - elapsed) / 1000);
							btn.disabled = true;
							const btnText = btn.querySelector('span');
							if (btnText) {
								btnText.innerText = `Cooldown: ${remaining}s`;
							}
							
							// Poll every second to update button text
							setTimeout(updateButtonCooldown, 1000);
							return true; // cooldown active
						}

						// Reset button state
						btn.disabled = false;
						const btnText = btn.querySelector('span');
						if (btnText) {
							btnText.innerText = 'Send Message';
						}
						return false;
					}

					// Initial run to restore any active cooldown/limit
					updateButtonCooldown();
					
					if(form) {
						form.addEventListener('submit', async (e) => {
							e.preventDefault();
							
							const now = Date.now();
							const state = getRateLimitState();
							
							// Double check rate limits on submit trigger
							const elapsed = now - state.lastSubmitTime;
							if (elapsed < COOLDOWN_MS) {
								const remaining = Math.ceil((COOLDOWN_MS - elapsed) / 1000);
								alert(`Rate Limit: Please wait ${remaining} seconds before sending another message.`);
								return;
							}
							
							const recentDaily = state.dailySubmits.filter(t => now - t < DAY_MS);
							if (recentDaily.length >= MAX_DAILY_SUBMITS) {
								alert(`Daily Limit: You have reached the maximum of ${MAX_DAILY_SUBMITS} messages per 24 hours. Please try again tomorrow.`);
								return;
							}

							const originalContent = btn.innerHTML;
							btn.innerHTML = '<span>Transmitting...</span>';
							btn.disabled = true;
							
							try {
								const response = await fetch('https://formspree.io/f/xaqkygpk', {
									method: 'POST',
									body: new FormData(form),
									headers: { 'Accept': 'application/json' }
								});
								
								if (response.ok) {
									alert('Thanks! Your message has been sent securely.');
									form.reset();
									
									// Record successful submission
									const updatedState = getRateLimitState();
									updatedState.lastSubmitTime = Date.now();
									updatedState.dailySubmits.push(Date.now());
									saveRateLimitState(updatedState);
									
									// Start button cooldown countdown
									updateButtonCooldown();
								} else {
									const data = await response.json();
									if (Object.hasOwn(data, 'errors')) {
										alert('Error: ' + data.errors.map(err => err.message).join(', '));
									} else {
										alert('System error: unable to transmit message. Please try again.');
									}
									btn.innerHTML = originalContent;
									btn.disabled = false;
								}
							} catch (error) {
								alert('Network error: unable to reach the server. Please check your connection.');
								btn.innerHTML = originalContent;
								btn.disabled = false;
							}
						});
					}
				});
			</script>

