---
// Yathin — Portfolio
import SEO from '../components/SEO.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';
import Skills from '../components/Skills.astro';
import Playground from '../components/Playground.astro';
import Contact from '../components/Contact.astro';

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<SEO />
	</head>

	<body>
		<!-- MAIN CONTENT WRAPPER -->
		<div id="main-content" style="opacity: 0; transition: opacity 0.4s ease;">

			<Navbar />

			<Hero />

			<About />

			<Projects />

			<Skills />

			<Playground />

			<Contact />

			<!-- FOOTER -->
			<footer style="content-visibility: auto; text-align: center; padding: 4rem 2rem; border-top: 1px solid var(--border); background: var(--bg-soft);">
				<p style="color: var(--text-primary); font-size: 0.95rem; font-weight: 600;">
					Designed and engineered by <span class="footer-name" style="color: var(--accent-blue); font-weight: 700;">Yathin G</span>
				</p>
				<p class="footer-stack" style="color: var(--text-muted); font-size: 0.8rem; margin-top: 0.5rem;">
					Powered by Astro · Vanilla CSS · Deployed on Vercel
				</p>
				<p class="footer-copy" style="color: var(--text-muted); font-size: 0.75rem; margin-top: 1rem;">
					© 2026 Yathin G. All rights reserved.
				</p>
			</footer>
		</div> <!-- Closes #main-content -->

		<script>
			import Lenis from 'lenis';
			import gsap from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';

			try {
				gsap.registerPlugin(ScrollTrigger);
			} catch (e) {
				console.error("GSAP ScrollTrigger plugin registration failed:", e);
			}

			declare global {
				interface Window {
					Lenis: any;
				}
			}

			const runOnInit = (fn: () => void) => {
				if (document.readyState === "loading") {
					document.addEventListener("DOMContentLoaded", fn);
				} else {
					fn();
				}
			};

			// ── Lenis Smooth Scroll & Navbar Synchronization ──────────
			const highlightNav = () => {
				const sections = document.querySelectorAll("section[id]");
				const navLinks = document.querySelectorAll(".nav-links a.nav-item");
				let scrollY = window.scrollY;

				sections.forEach((current) => {
					const el = current as HTMLElement;
					const sectionHeight = el.offsetHeight;
					const sectionTop = el.offsetTop - 150;
					const sectionId = current.getAttribute("id");

					if (scrollY > sectionTop && scrollY <= sectionTop + sectionHeight) {
						navLinks.forEach((link) => {
							link.classList.remove("active");
							if (link.getAttribute("href") === `#${sectionId}`) {
								link.classList.add("active");
							}
						});
					}
				});
			};

			runOnInit(() => {
				// Make main-content instantly visible to prevent flash/layout shifts
				const mainContent = document.getElementById("main-content");
				if (mainContent) {
					mainContent.style.opacity = "1";
				}

				const lenis = new Lenis({
					autoRaf: false,
					lerp: 0.08, // Premium smooth snappy scrolling
					smoothWheel: true,
					wheelMultiplier: 0.9,
					touchMultiplier: 1.2
				});
				(window as any).lenis = lenis;

				// Hook Lenis into GSAP ticker
				gsap.ticker.add((time) => {
					lenis.raf(time * 1000);
				});

				// Connect ScrollTrigger updates and active states
				lenis.on('scroll', (e: any) => {
					ScrollTrigger.update();
					highlightNav();
				});

				// Hook all internal anchor links to smooth scroll
				document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
					anchor.addEventListener("click", function (this: HTMLAnchorElement, e) {
						e.preventDefault();
						const targetId = this.getAttribute("href");
						if (targetId) {
							const target = document.querySelector(targetId);
							if (target) {
								lenis.scrollTo(target as HTMLElement, { offset: -80 });
							}
						}
					});
				});
			});

			// ── GSAP Scroll-Reveal & Entrance Timelines ───────────
			runOnInit(() => {
				try {
					if (!gsap || !ScrollTrigger) {
						throw new Error("GSAP or ScrollTrigger was not loaded correctly.");
					}

					// Snappy Hero Entrance Animation (no boot preloader delay)
					const tl = gsap.timeline({
						defaults: { ease: "power3.out", duration: 0.8 }
					});

					// Navbar fade down
					tl.fromTo("#site-header", { opacity: 0, y: -20 }, { opacity: 1, y: 0 })
					  // Hero staggers
					  .fromTo(".hero-title", { opacity: 0, y: 30 }, { opacity: 1, y: 0 }, "-=0.5")
					  .fromTo(".hero-tagline", { opacity: 0, y: 20 }, { opacity: 1, y: 0 }, "-=0.6")
					  .fromTo(".hero-sub", { opacity: 0, y: 20 }, { opacity: 1, y: 0 }, "-=0.6")
					  .fromTo(".hero-actions", { opacity: 0, y: 20 }, { opacity: 1, y: 0 }, "-=0.6")
					  // Side card enters with subtle slide and scale
					  .fromTo(".status-card", { opacity: 0, x: 20, scale: 0.95 }, { opacity: 1, x: 0, scale: 1, duration: 1 }, "-=0.6");

					// Section reveals
					document.querySelectorAll("section").forEach((section) => {
						// Animating section titles and dividers
						gsap.fromTo(section.querySelectorAll(".section-title, .title-divider, .section-subtitle, .about-bio, .playground-title, .playground-text, .contact-heading, .contact-sub"), 
							{ opacity: 0, y: 20 },
							{
								opacity: 1,
								y: 0,
								duration: 0.6,
								stagger: 0.1,
								ease: "power3.out",
								scrollTrigger: {
									trigger: section,
									start: "top 85%",
									toggleActions: "play none none none"
								}
							}
						);

						// Stagger project cards
						if (section.id === "projects") {
							gsap.fromTo(section.querySelectorAll(".project-card"),
								{ opacity: 0, y: 30 },
								{
									opacity: 1,
									y: 0,
									duration: 0.7,
									stagger: 0.12,
									ease: "power3.out",
									scrollTrigger: {
										trigger: ".featured-projects-container",
										start: "top 80%",
										toggleActions: "play none none none"
									}
								}
							);
						}

						// Stagger stack cards & badges
						if (section.id === "skills") {
							gsap.fromTo(section.querySelectorAll(".skill-category-card"),
								{ opacity: 0, y: 20 },
								{
									opacity: 1,
									y: 0,
									duration: 0.6,
									stagger: 0.1,
									ease: "power3.out",
									scrollTrigger: {
										trigger: ".skills-grid",
										start: "top 80%",
										toggleActions: "play none none none"
									}
								}
							);
						}

						// Stagger about bio cards
						if (section.id === "about") {
							gsap.fromTo(section.querySelectorAll(".about-card"),
								{ opacity: 0, y: 20 },
								{
									opacity: 1,
									y: 0,
									duration: 0.6,
									stagger: 0.08,
									ease: "power3.out",
									scrollTrigger: {
										trigger: ".about-cards-grid",
										start: "top 80%",
										toggleActions: "play none none none"
									}
								}
							);
						}

						// Playground card reveal
						if (section.id === "playground") {
							gsap.fromTo(section.querySelectorAll(".playground-card"),
								{ opacity: 0, y: 30 },
								{
									opacity: 1,
									y: 0,
									duration: 0.7,
									ease: "power3.out",
									scrollTrigger: {
										trigger: section,
										start: "top 80%",
										toggleActions: "play none none none"
									}
								}
							);
						}

						// Stagger contact cards & form
						if (section.id === "contact") {
							gsap.fromTo(section.querySelectorAll(".contact-card"),
								{ opacity: 0, y: 20 },
								{
									opacity: 1,
									y: 0,
									duration: 0.6,
									stagger: 0.08,
									ease: "power3.out",
									scrollTrigger: {
										trigger: ".contact-grid",
										start: "top 80%",
										toggleActions: "play none none none"
									}
								}
							);

							gsap.fromTo(section.querySelectorAll(".contact-form-container"),
								{ opacity: 0, y: 25 },
								{
									opacity: 1,
									y: 0,
									duration: 0.7,
									ease: "power3.out",
									scrollTrigger: {
										trigger: ".contact-form-container",
										start: "top 80%",
										toggleActions: "play none none none"
									}
								}
							);
						}
					});

				} catch (err) {
					console.error("GSAP Animations failed to initialize. Triggering fallbacks.", err);
					
					// Fail-safe fallback to make everything visible
					document.querySelectorAll("section, .project-card, .skill-category-card, .about-card, .contact-card, .contact-form-container, .status-card, .playground-card").forEach(el => {
						if (el instanceof HTMLElement) {
							el.style.opacity = "1";
							el.style.transform = "none";
						}
					});
				}
			});
		</script>
	</body>
</html>
