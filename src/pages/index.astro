---
// Yathin — Portfolio
// Single-file version, no components needed
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Yathin | AI Builder & CS Student</title>
		<meta
			name="description"
			content="Portfolio of Yathin — CS Engineering student at VCE, building AI assistants and intelligent systems."
		/>
		<meta name="theme-color" content="#f97316" />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Syne:wght@400;500;700&display=swap"
			rel="stylesheet"
		/>

		<!-- Typed.js -->
		<script
			src="https://cdn.jsdelivr.net/npm/typed.js@2.1.0/dist/typed.umd.js"
		></script>

		<!-- tsParticles -->
		<script
			src="https://cdn.jsdelivr.net/npm/tsparticles@2.12.0/tsparticles.bundle.min.js"
		></script>

		<!-- Vanilla Tilt -->
		<script
			src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js"
		></script>

		<style>
			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			:root {
				--accent: #f97316;
				--accent-glow: rgba(249, 115, 22, 0.35);
				--bg: #0a0a0a;
				--glass: rgba(255, 255, 255, 0.05);
				--glass-border: rgba(255, 255, 255, 0.1);
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				background: var(--bg);
				color: #fff;
				font-family: "Syne", sans-serif;
				overflow-x: hidden;
			}

			/* Scrollbar */
			::-webkit-scrollbar {
				width: 6px;
			}
			::-webkit-scrollbar-track {
				background: #111;
			}
			::-webkit-scrollbar-thumb {
				background: var(--accent);
				border-radius: 3px;
			}
			::selection {
				background: var(--accent);
				color: #000;
			}

			/* Particles */
			#tsparticles {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				z-index: -1;
			}

			/* Glass utility */
			.glass {
				background: var(--glass);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border: 1px solid var(--glass-border);
				border-radius: 16px;
			}

			/* NAVBAR */
			nav {
				position: sticky;
				top: 0;
				z-index: 100;
				background: rgba(0, 0, 0, 0.2);
				backdrop-filter: blur(20px);
				border-bottom: 1px solid var(--glass-border);
				padding: 1rem 2rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
				animation: slideDown 0.6s ease-out;
			}

			@keyframes slideDown {
				from {
					transform: translateY(-100%);
					opacity: 0;
				}
				to {
					transform: translateY(0);
					opacity: 1;
				}
			}

			.nav-logo {
				font-family: "Orbitron", sans-serif;
				font-weight: 900;
				font-size: 1.3rem;
				color: var(--accent);
				text-decoration: none;
			}

			.nav-links {
				display: flex;
				gap: 2rem;
				list-style: none;
			}
			.nav-links a {
				color: #ccc;
				text-decoration: none;
				font-size: 0.9rem;
				letter-spacing: 0.05em;
				transition: color 0.2s;
			}
			.nav-links a:hover {
				color: var(--accent);
			}

			.hamburger {
				display: none;
				flex-direction: column;
				gap: 5px;
				cursor: pointer;
				background: none;
				border: none;
			}
			.hamburger span {
				display: block;
				width: 24px;
				height: 2px;
				background: #fff;
				border-radius: 2px;
				transition: 0.3s;
			}

			.mobile-menu {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(0, 0, 0, 0.95);
				backdrop-filter: blur(20px);
				z-index: 200;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				gap: 2.5rem;
			}
			.mobile-menu.open {
				display: flex;
			}
			.mobile-menu a {
				color: #fff;
				text-decoration: none;
				font-family: "Orbitron", sans-serif;
				font-size: 1.5rem;
				transition: color 0.2s;
			}
			.mobile-menu a:hover {
				color: var(--accent);
			}
			.mobile-close {
				position: absolute;
				top: 1.5rem;
				right: 2rem;
				background: none;
				border: none;
				color: #fff;
				font-size: 2rem;
				cursor: pointer;
			}

			@media (max-width: 768px) {
				.nav-links {
					display: none;
				}
				.hamburger {
					display: flex;
				}
			}

			/* SECTIONS */
			section {
				padding: 6rem 2rem;
				max-width: 1100px;
				margin: 0 auto;
			}

			.section-title {
				font-family: "Orbitron", sans-serif;
				font-size: clamp(1.8rem, 4vw, 2.8rem);
				font-weight: 700;
				margin-bottom: 0.5rem;
			}
			.section-title span {
				color: var(--accent);
			}

			.title-bar {
				width: 60px;
				height: 3px;
				background: var(--accent);
				border-radius: 2px;
				margin-bottom: 3rem;
				box-shadow: 0 0 10px var(--accent-glow);
			}

			/* HERO */
			#home {
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				text-align: center;
				flex-direction: column;
				padding: 2rem;
				max-width: 100%;
			}

			.hero-greeting {
				color: var(--accent);
				font-size: 0.9rem;
				letter-spacing: 0.3em;
				text-transform: uppercase;
				margin-bottom: 1rem;
				opacity: 0;
				animation: fadeUp 0.6s ease-out 0.1s forwards;
			}

			.hero-name {
				font-family: "Orbitron", sans-serif;
				font-size: clamp(2.5rem, 8vw, 6rem);
				font-weight: 900;
				line-height: 1.1;
				margin-bottom: 1.5rem;
				opacity: 0;
				animation: fadeUp 0.6s ease-out 0.3s forwards;
			}

			.hero-name .gradient {
				background: linear-gradient(135deg, #f97316, #fbbf24);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
			}

			.hero-typewriter {
				font-size: clamp(1rem, 3vw, 1.4rem);
				color: var(--accent);
				margin-bottom: 1rem;
				min-height: 2rem;
				opacity: 0;
				animation: fadeUp 0.6s ease-out 0.5s forwards;
			}

			.hero-sub {
				color: #888;
				font-size: 0.95rem;
				margin-bottom: 2.5rem;
				opacity: 0;
				animation: fadeUp 0.6s ease-out 0.6s forwards;
			}

			.hero-btns {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
				justify-content: center;
				margin-bottom: 3rem;
				opacity: 0;
				animation: fadeUp 0.6s ease-out 0.7s forwards;
			}

			.btn-primary {
				padding: 0.75rem 2rem;
				border: 1px solid var(--accent);
				background: rgba(249, 115, 22, 0.1);
				color: var(--accent);
				border-radius: 8px;
				text-decoration: none;
				font-family: "Syne", sans-serif;
				font-weight: 600;
				transition: all 0.3s;
				box-shadow: 0 0 15px transparent;
				cursor: pointer;
			}
			.btn-primary:hover {
				background: rgba(249, 115, 22, 0.2);
				box-shadow: 0 0 20px var(--accent-glow);
			}

			.btn-ghost {
				padding: 0.75rem 2rem;
				border: 1px solid var(--glass-border);
				background: transparent;
				color: #ccc;
				border-radius: 8px;
				text-decoration: none;
				font-family: "Syne", sans-serif;
				font-weight: 600;
				transition: all 0.3s;
			}
			.btn-ghost:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			
			.btn-icon-only {
				padding: 0.75rem;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.btn-icon-only svg {
				width: 1.25rem;
				height: 1.25rem;
				fill: currentColor;
				transition: fill 0.3s ease;
			}

			.hero-avatar {
				width: 150px;
				height: 150px;
				border-radius: 50%;
				background: var(--glass);
				backdrop-filter: blur(12px);
				border: 3px solid transparent;
				background-clip: padding-box;
				display: flex;
				align-items: center;
				justify-content: center;
				font-family: "Orbitron", sans-serif;
				font-size: 2.5rem;
				font-weight: 900;
				color: var(--accent);
				position: relative;
				animation:
					pulse 3s ease-in-out infinite,
					fadeUp 0.6s ease-out 0.2s both;
				box-shadow:
					0 0 0 3px var(--accent),
					0 0 30px var(--accent-glow);
				margin-bottom: 2rem;
			}

			@keyframes pulse {
				0%,
				100% {
					box-shadow:
						0 0 0 3px var(--accent),
						0 0 30px var(--accent-glow);
				}
				50% {
					box-shadow:
						0 0 0 3px var(--accent),
						0 0 50px var(--accent-glow);
				}
			}

			.scroll-indicator {
				position: absolute;
				bottom: 2rem;
				left: 50%;
				transform: translateX(-50%);
				color: var(--accent);
				animation: bounce 2s infinite;
				font-size: 1.5rem;
			}

			@keyframes bounce {
				0%,
				100% {
					transform: translateX(-50%) translateY(0);
				}
				50% {
					transform: translateX(-50%) translateY(8px);
				}
			}

			@keyframes fadeUp {
				from {
					opacity: 0;
					transform: translateY(30px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			/* ABOUT */
			.about-grid {
				display: grid;
				grid-template-columns: 1fr 2fr;
				gap: 4rem;
				align-items: start;
			}

			.about-avatar-wrap {
				text-align: center;
			}

			.about-avatar {
				width: 180px;
				height: 180px;
				border-radius: 50%;
				background: var(--glass);
				backdrop-filter: blur(12px);
				box-shadow:
					0 0 0 3px var(--accent),
					0 0 30px var(--accent-glow);
				display: flex;
				align-items: center;
				justify-content: center;
				font-family: "Orbitron", sans-serif;
				font-size: 2.8rem;
				font-weight: 900;
				color: var(--accent);
				margin: 0 auto 1.5rem;
			}

			.about-name {
				font-family: "Orbitron", sans-serif;
				font-weight: 700;
				font-size: 1rem;
				margin-bottom: 0.3rem;
			}

			.about-role {
				color: var(--accent);
				font-size: 0.85rem;
				margin-bottom: 0.3rem;
			}
			.about-uni {
				color: #666;
				font-size: 0.8rem;
				margin-bottom: 0.2rem;
			}
			.about-loc {
				color: #555;
				font-size: 0.75rem;
			}

			.about-bio {
				line-height: 1.9;
				color: #ccc;
				margin-bottom: 2rem;
				font-size: 0.95rem;
			}

			.stats-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
				margin-bottom: 2rem;
			}

			.stat-card {
				padding: 1.2rem;
				text-align: center;
				border-radius: 12px;
			}

			.stat-number {
				font-family: "Orbitron", sans-serif;
				font-size: 1.8rem;
				font-weight: 900;
				color: var(--accent);
				display: block;
			}

			.stat-label {
				font-size: 0.75rem;
				color: #888;
				margin-top: 0.3rem;
			}

			.quote {
				border-left: 3px solid var(--accent);
				padding-left: 1rem;
				color: #888;
				font-style: italic;
				font-size: 0.9rem;
			}

			@media (max-width: 768px) {
				.about-grid {
					grid-template-columns: 1fr;
					gap: 2rem;
				}
				.stats-grid {
					grid-template-columns: repeat(3, 1fr);
				}
			}

			/* PROJECTS */
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
				gap: 2rem;
			}

			.project-card {
				padding: 1.8rem;
				transition: all 0.3s ease;
				cursor: default;
			}

			.project-card:hover {
				border-color: rgba(249, 115, 22, 0.3);
				box-shadow: 0 0 30px var(--accent-glow);
				transform: translateY(-4px);
			}

			.project-top {
				display: flex;
				align-items: center;
				gap: 1rem;
				margin-bottom: 0.5rem;
			}

			.project-icon {
				font-size: 2rem;
			}

			.project-name {
				font-family: "Orbitron", sans-serif;
				font-size: 1.1rem;
				font-weight: 700;
			}

			.project-badge {
				margin-left: auto;
				background: var(--accent);
				color: #000;
				font-size: 0.65rem;
				padding: 0.2rem 0.6rem;
				border-radius: 999px;
				font-weight: 700;
			}

			.project-fullname {
				color: #666;
				font-size: 0.75rem;
				margin-bottom: 1rem;
			}

			.project-desc {
				color: #aaa;
				font-size: 0.875rem;
				line-height: 1.7;
				margin-bottom: 1.2rem;
			}

			.tech-stack {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-bottom: 1.5rem;
			}

			.tech-badge {
				background: rgba(249, 115, 22, 0.1);
				border: 1px solid rgba(249, 115, 22, 0.3);
				color: #fb923c;
				font-size: 0.7rem;
				padding: 0.25rem 0.7rem;
				border-radius: 999px;
			}

			.project-link {
				display: inline-block;
				padding: 0.5rem 1.2rem;
				border: 1px solid var(--glass-border);
				border-radius: 8px;
				color: #ccc;
				text-decoration: none;
				font-size: 0.85rem;
				transition: all 0.3s;
			}
			.project-link:hover {
				border-color: var(--accent);
				color: var(--accent);
				box-shadow: 0 0 12px var(--accent-glow);
			}

			/* SKILLS */
			.skills-categories {
				display: flex;
				flex-direction: column;
				gap: 2.5rem;
			}

			.skill-cat-label {
				font-size: 0.75rem;
				color: var(--accent);
				text-transform: uppercase;
				letter-spacing: 0.15em;
				margin-bottom: 1rem;
				display: flex;
				align-items: center;
				gap: 1rem;
			}
			.skill-cat-label::after {
				content: "";
				flex: 1;
				height: 1px;
				background: var(--glass-border);
			}

			.skill-badges {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
			}

			.skill-badge {
				background: var(--glass);
				border: 1px solid var(--glass-border);
				padding: 0.4rem 1rem;
				border-radius: 999px;
				font-size: 0.85rem;
				color: #ccc;
				transition: all 0.2s;
				cursor: default;
			}
			.skill-badge:hover {
				transform: scale(1.08);
				border-color: rgba(249, 115, 22, 0.5);
				background: rgba(249, 115, 22, 0.1);
				color: #fb923c;
			}

			/* ACHIEVEMENTS */
			.achievements-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.5rem;
			}

			.achievement-card {
				padding: 1.8rem;
				transition: all 0.3s;
			}
			.achievement-card:hover {
				border-color: rgba(249, 115, 22, 0.3);
				box-shadow: 0 0 25px var(--accent-glow);
				transform: translateY(-4px);
			}

			.achievement-icon {
				font-size: 2.2rem;
				margin-bottom: 1rem;
				display: block;
			}

			.achievement-title {
				font-family: "Orbitron", sans-serif;
				font-size: 0.95rem;
				font-weight: 700;
				margin-bottom: 0.6rem;
			}

			.achievement-desc {
				color: #888;
				font-size: 0.85rem;
				line-height: 1.7;
			}

			.achievement-card.soon {
				border-style: dashed;
				opacity: 0.7;
			}

			/* CONTACT */
			#contact {
				text-align: center;
			}

			.contact-heading {
				font-family: "Orbitron", sans-serif;
				font-size: clamp(1.3rem, 3vw, 2rem);
				font-weight: 700;
				margin-bottom: 1rem;
			}

			.contact-sub {
				color: #888;
				max-width: 550px;
				margin: 0 auto 3rem;
				line-height: 1.7;
				font-size: 0.95rem;
			}

			.contact-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
				gap: 1.5rem;
				max-width: 800px;
				margin: 0 auto 2.5rem;
			}

			.contact-card {
				padding: 1.8rem 1rem;
				text-align: center;
				text-decoration: none;
				color: inherit;
				transition: all 0.3s;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.6rem;
			}
			.contact-card:hover {
				border-color: rgba(249, 115, 22, 0.4);
				box-shadow: 0 0 25px var(--accent-glow);
				transform: translateY(-4px);
			}

			.contact-icon {
				font-size: 2.2rem;
				color: #ccc;
				transition: color 0.3s;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.contact-card:hover .contact-icon {
				color: var(--accent);
			}
			.contact-label {
				font-family: "Orbitron", sans-serif;
				font-size: 0.85rem;
				font-weight: 700;
			}
			.contact-sub-label {
				color: #666;
				font-size: 0.75rem;
			}

			.contact-location {
				color: #666;
				font-size: 0.85rem;
				line-height: 1.8;
			}

			/* FOOTER */
			footer {
				text-align: center;
				padding: 2.5rem 2rem;
				border-top: 1px solid var(--glass-border);
				color: #555;
				font-size: 0.85rem;
			}
			footer .footer-name {
				color: var(--accent);
			}
			footer .footer-stack {
				margin-top: 0.4rem;
				font-size: 0.75rem;
			}
			footer .footer-copy {
				margin-top: 1rem;
				font-size: 0.75rem;
				color: #444;
			}

			/* SCROLL REVEAL */
			.reveal {
				opacity: 0;
				transform: translateY(40px);
				transition:
					opacity 0.6s ease-out,
					transform 0.6s ease-out;
			}
			.reveal.visible {
				opacity: 1;
				transform: translateY(0);
			}
		</style>
	</head>

	<body>
		<!-- Particles Background -->
		<div id="tsparticles"></div>

		<!-- Mobile Menu -->
		<div class="mobile-menu" id="mobileMenu">
			<button class="mobile-close" onclick="closeMobileMenu()">✕</button>
			<a href="#home" onclick="closeMobileMenu()">Home</a>
			<a href="#about" onclick="closeMobileMenu()">About</a>
			<a href="#projects" onclick="closeMobileMenu()">Projects</a>
			<a href="#skills" onclick="closeMobileMenu()">Skills</a>
			<a href="#achievements" onclick="closeMobileMenu()">Achievements</a>
			<a href="#contact" onclick="closeMobileMenu()">Contact</a>
		</div>

		<!-- NAVBAR -->
		<nav>
			<a href="#home" class="nav-logo" style="display: flex; align-items: center;">
				<img src="https://github.com/YathinTHEBUILDER.png" alt="YG" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid var(--accent);" />
			</a>
			<ul class="nav-links">
				<li><a href="#about">About</a></li>
				<li><a href="#projects">Projects</a></li>
				<li><a href="#skills">Skills</a></li>
				<li><a href="#achievements">Achievements</a></li>
				<li><a href="#contact">Contact</a></li>
			</ul>
			<button
				class="hamburger"
				onclick="openMobileMenu()"
				aria-label="Menu"
			>
