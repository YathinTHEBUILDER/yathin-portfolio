---
// Yathin — Portfolio
import PersistentEnvironment from '../components/PersistentEnvironment.astro';
import SEO from '../components/SEO.astro';
import CinematicLoader from '../components/CinematicLoader.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';
import Skills from '../components/Skills.astro';
import Contact from '../components/Contact.astro';

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<SEO />
	</head>

	<body>
		<!-- Unified Spatial Ecosystem Canvas Layer (Modular and Persistent) -->
		<PersistentEnvironment />

		<!-- World-Class Cinematic Preloader Overlay -->
		<CinematicLoader />

		<!-- MAIN CONTENT WRAPPER -->
		<div id="main-content" style="opacity: 0; pointer-events: none; transition: opacity var(--motion-duration-cinematic) var(--motion-ease-cinematic), transform var(--motion-duration-cinematic) var(--motion-ease-cinematic), filter var(--motion-duration-cinematic) var(--motion-ease-cinematic); transform: translateY(30px); filter: blur(20px);">

			<Navbar />

			<Hero />

			<About />

			<Projects />

			<Skills />

			<Contact />

			<!-- FOOTER -->
			<footer>
				<p>
					Designed and engineered by <span class="footer-name">Yathin</span>
				</p>
				<p class="footer-stack">
					Powered by Astro · Vanilla CSS · Deployed on Vercel
				</p>
				<p class="footer-copy">
					© 2025 Yathin. All rights reserved.
				</p>
			</footer>
		</div> <!-- Closes #main-content -->

		<script>
			import Lenis from 'lenis';
			import gsap from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';

			try {
				gsap.registerPlugin(ScrollTrigger);
			} catch (e) {
				console.error("GSAP ScrollTrigger plugin registration failed:", e);
			}

			declare var Typed: any;
			declare var VanillaTilt: any;

			declare global {
				interface Window {
					VanillaTilt: any;
					Lenis: any;
				}
			}

			const runOnInit = (fn: () => void) => {
				if (document.readyState === "loading") {
					document.addEventListener("DOMContentLoaded", fn);
				} else {
					fn();
				}
			};

			// ── Lenis Smooth Scroll ──────────────────────────────────
			runOnInit(() => {
				const lenis = new Lenis({
					autoRaf: false,
					lerp: 0.06, // Slightly lower lerp for a smoother, premium deceleration feel
					smoothWheel: true,
					wheelMultiplier: 1.0,
					touchMultiplier: 1.5,
				});
				(window as any).lenis = lenis;

				// Hook Lenis into GSAP ticker for perfect synchronization of animations
				gsap.ticker.add((time) => {
					lenis.raf(time * 1000);
				});

				// Disable lag smoothing in GSAP to prevent visual jumps/stutters
				gsap.ticker.lagSmoothing(0);

				// Connect ScrollTrigger updates with Lenis scroll event
				lenis.on('scroll', ScrollTrigger.update);

				// Hook all internal anchor links to smooth scroll
				document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
					anchor.addEventListener("click", function (this: HTMLAnchorElement, e) {
						e.preventDefault();
						const targetId = this.getAttribute("href");
						if (targetId) {
							const target = document.querySelector(targetId);
							if (target) {
								lenis.scrollTo(target as HTMLElement, { offset: -85 });
							}
						}
					});
				});
			});

			// ── Vanilla Tilt ──────────────────────────────────────
			runOnInit(() => {
				if (window.VanillaTilt) {
					VanillaTilt.init(document.querySelectorAll("[data-tilt]"), {
						max: 8,
						glare: true,
						"max-glare": 0.2,
					});
				}
			});

			// ── GSAP Scroll-Reveal & Entrance Timelines ───────────
			runOnInit(() => {
				try {
					if (!gsap || !ScrollTrigger) {
						throw new Error("GSAP or ScrollTrigger was not loaded correctly.");
					}

					// Coordinated Hero entrance synced with preloader boot event
					document.addEventListener("nxs-boot-complete", () => {
						const tl = gsap.timeline({
							defaults: { ease: "power4.out", duration: 1.2 }
						});

						tl.fromTo(".hero-hud-decorator", { opacity: 0, y: -20 }, { opacity: 1, y: 0 })
						  .fromTo(".hero-name", { opacity: 0, y: 30 }, { opacity: 1, y: 0 }, "-=0.9")
						  .fromTo(".hero-typewriter-box", { opacity: 0, y: 30 }, { opacity: 1, y: 0 }, "-=1.0")
						  .fromTo(".hero-sub", { opacity: 0, y: 30 }, { opacity: 1, y: 0 }, "-=1.0")
						  .fromTo(".hero-btns", { opacity: 0, y: 35 }, { opacity: 1, y: 0 }, "-=1.0")
						  .fromTo(".scroll-indicator-wrap", { opacity: 0, y: 20 }, { opacity: 1, y: 0 }, "-=0.9");
					});

					// Projects staggered fade-in reveal
					gsap.fromTo("#projects .project-card", 
						{ opacity: 0, y: 55, z: -50 },
						{
							opacity: 1,
							y: 0,
							z: 0,
							duration: 1.0,
							stagger: 0.15,
							ease: "power4.out",
							scrollTrigger: {
								trigger: "#projects .projects-grid",
								start: "top 85%",
								toggleActions: "play none none none"
							}
						}
					);

					// Skills categories staggered fade-in reveal
					gsap.fromTo("#skills .skill-category-card", 
						{ opacity: 0, y: 50, z: -50 },
						{
							opacity: 1,
							y: 0,
							z: 0,
							duration: 1.0,
							stagger: 0.18,
							ease: "power4.out",
							scrollTrigger: {
								trigger: "#skills .skills-categories",
								start: "top 85%",
								toggleActions: "play none none none"
							}
						}
					);

					// Contact channel cards staggered reveal
					gsap.fromTo("#contact .contact-card", 
						{ opacity: 0, y: 40, z: -40 },
						{
							opacity: 1,
							y: 0,
							z: 0,
							duration: 0.8,
							stagger: 0.1,
							ease: "power4.out",
							scrollTrigger: {
								trigger: "#contact .contact-grid",
								start: "top 88%",
								toggleActions: "play none none none"
							}
						}
					);

					// About section stats counters staggered reveal
					gsap.fromTo("#about .stat-card", 
						{ opacity: 0, y: 40 },
						{
							opacity: 1,
							y: 0,
							duration: 0.8,
							stagger: 0.1,
							ease: "power4.out",
							scrollTrigger: {
								trigger: "#about .stats-grid",
								start: "top 90%",
								toggleActions: "play none none none"
							}
						}
					);

					// General scroll-reveal fallback for standard elements
					document.querySelectorAll(".reveal").forEach((el) => {
						if (
							el.classList.contains("project-card") || 
							el.classList.contains("skill-category-card") || 
							el.classList.contains("contact-card") || 
							el.classList.contains("stat-card")
						) {
							return; // already stagger-revealed above
						}

						gsap.fromTo(el, 
							{ opacity: 0, y: 40, z: -30 },
							{
								opacity: 1,
								y: 0,
								z: 0,
								duration: 0.9,
								ease: "power4.out",
								scrollTrigger: {
									trigger: el,
									start: "top 88%",
									toggleActions: "play none none none"
								}
							}
						);
					});
				} catch (err) {
					console.error("GSAP Animations failed to initialize. Triggering fallbacks.", err);
					
					// Fail-safe fallback to make everything visible immediately so user doesn't get stuck
					document.querySelectorAll(".reveal").forEach(el => {
						if (el instanceof HTMLElement) {
							el.style.opacity = "1";
							el.style.transform = "none";
						}
					});
					document.querySelectorAll(".hero-name, .hero-typewriter-box, .hero-sub, .hero-btns, .scroll-indicator-wrap, .hero-hud-decorator").forEach(el => {
						if (el instanceof HTMLElement) {
							el.style.opacity = "1";
							el.style.transform = "none";
						}
					});
					
					// Trigger loader completion if it was waiting for boot completion event
					const loaderOverlayEl = document.getElementById("cinematic-loader");
					const mainContentEl = document.getElementById("main-content");
					if (loaderOverlayEl) {
						loaderOverlayEl.style.opacity = "0";
						loaderOverlayEl.style.pointerEvents = "none";
					}
					if (mainContentEl) {
						mainContentEl.style.opacity = "1";
						mainContentEl.style.transform = "none";
						mainContentEl.style.filter = "none";
						mainContentEl.style.pointerEvents = "all";
					}
					document.body.classList.remove("loading");
				}
			});

			// ── Navbar opacity on scroll ──────────────────────────
			const updateNavbarBg = (y: number) => {
				const nav = document.querySelector("nav");
				if (nav) {
					nav.style.background =
						y > 50 ? "rgba(0,0,0,0.5)" : "rgba(0,0,0,0.2)";
				}
			};

			window.addEventListener("scroll", () => {
				if (!(window as any).lenis) {
					updateNavbarBg(window.scrollY);
				}
			});

			const checkLenisNav = setInterval(() => {
				if ((window as any).lenis) {
					clearInterval(checkLenisNav);
					(window as any).lenis.on('scroll', (e: any) => {
						updateNavbarBg(e.scroll);
					});
				}
			}, 100);
		</script>
	</body>
</html>
