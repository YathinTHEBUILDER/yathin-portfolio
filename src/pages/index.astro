---
// Yathin — Portfolio
import PersistentEnvironment from '../components/PersistentEnvironment.astro';
import SEO from '../components/SEO.astro';
import CinematicLoader from '../components/CinematicLoader.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';
import Skills from '../components/Skills.astro';
import Contact from '../components/Contact.astro';

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<SEO />
	</head>

	<body>
		<!-- Unified Spatial Ecosystem Canvas Layer (Modular and Persistent) -->
		<PersistentEnvironment />

		<!-- World-Class Cinematic Preloader Overlay -->
		<CinematicLoader />

		<!-- MAIN CONTENT WRAPPER -->
		<div id="main-content" style="opacity: 0; pointer-events: none; transition: opacity var(--motion-duration-cinematic) var(--motion-ease-cinematic), transform var(--motion-duration-cinematic) var(--motion-ease-cinematic); transform: translateY(24px);">

			<Navbar />

			<Hero />

			<About />

			<Projects />

			<Skills />

			<Contact />

			<!-- FOOTER -->
			<footer style="content-visibility: auto; text-align: center; padding: 4rem 2rem; border-top: 1px solid var(--glass-border); background: #0a0a0a;">
				<p style="color: #f5f5f5; font-size: 0.95rem; font-weight: 500;">
					Designed and engineered by <span class="footer-name" style="color: var(--accent); font-weight: 700;">Yathin G</span>
				</p>
				<p class="footer-stack" style="color: #8a8a8a; font-size: 0.8rem; margin-top: 0.5rem;">
					Powered by Astro · Vanilla CSS · Deployed on Vercel
				</p>
				<p class="footer-copy" style="color: #666; font-size: 0.75rem; margin-top: 1rem;">
					© 2026 Yathin G. All rights reserved.
				</p>
			</footer>
		</div> <!-- Closes #main-content -->

		<script>
			import Lenis from 'lenis';
			import gsap from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';

			try {
				gsap.registerPlugin(ScrollTrigger);
			} catch (e) {
				console.error("GSAP ScrollTrigger plugin registration failed:", e);
			}

			declare global {
				interface Window {
					Lenis: any;
				}
			}

			const runOnInit = (fn: () => void) => {
				if (document.readyState === "loading") {
					document.addEventListener("DOMContentLoaded", fn);
				} else {
					fn();
				}
			};

			// ── Lenis Smooth Scroll & Navbar Synchronization ──────────
			const highlightNav = () => {
				const sections = document.querySelectorAll("section[id]");
				const navLinks = document.querySelectorAll(".nav-links a");
				let scrollY = window.scrollY;

				sections.forEach((current) => {
					const el = current as HTMLElement;
					const sectionHeight = el.offsetHeight;
					const sectionTop = el.offsetTop - 150;
					const sectionId = current.getAttribute("id");

					if (scrollY > sectionTop && scrollY <= sectionTop + sectionHeight) {
						navLinks.forEach((link) => {
							link.classList.remove("active");
							if (link.getAttribute("href") === `#${sectionId}`) {
								link.classList.add("active");
							}
						});
					}
				});
			};

			const updateNavbarBg = (y: number) => {
				const nav = document.querySelector("nav");
				if (nav) {
					nav.style.background =
						y > 50 ? "rgba(7,7,7,0.95)" : "transparent";
				}
			};

			runOnInit(() => {
				const lenis = new Lenis({
					autoRaf: false,
					lerp: 0.08, // Premium smooth snappy deceleration feel
					smoothWheel: true,
				});
				(window as any).lenis = lenis;

				// Hook Lenis into GSAP ticker for perfect synchronization of animations
				gsap.ticker.add((time) => {
					lenis.raf(time * 1000);
				});

				// Connect ScrollTrigger updates and active states with Lenis scroll event
				lenis.on('scroll', (e: any) => {
					ScrollTrigger.update();
					updateNavbarBg(e.scroll);
					highlightNav();
				});

				// Hook all internal anchor links to smooth scroll
				document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
					anchor.addEventListener("click", function (this: HTMLAnchorElement, e) {
						e.preventDefault();
						const targetId = this.getAttribute("href");
						if (targetId) {
							const target = document.querySelector(targetId);
							if (target) {
								lenis.scrollTo(target as HTMLElement, { offset: -100 });
							}
						}
					});
				});
			});

			// ── GSAP Scroll-Reveal & Entrance Timelines ───────────
			runOnInit(() => {
				try {
					if (!gsap || !ScrollTrigger) {
						throw new Error("GSAP or ScrollTrigger was not loaded correctly.");
					}

					// Coordinated Hero entrance synced with preloader boot event
					document.addEventListener("nxs-boot-complete", () => {
						const tl = gsap.timeline({
							defaults: { ease: "power3.out", duration: 0.6 }
						});

						tl.fromTo(".hero-name", { opacity: 0, y: 15 }, { opacity: 1, y: 0 })
						  .fromTo(".hero-tagline", { opacity: 0, y: 15 }, { opacity: 1, y: 0 }, "-=0.4")
						  .fromTo(".hero-sub", { opacity: 0, y: 15 }, { opacity: 1, y: 0 }, "-=0.4")
						  .fromTo(".hero-btns", { opacity: 0, y: 15 }, { opacity: 1, y: 0 }, "-=0.4")
						  .fromTo(".scroll-indicator-wrap", { opacity: 0 }, { opacity: 1 }, "-=0.3");
					});

					// Projects staggered fade-in reveal with premium subtle scale
					gsap.fromTo("#projects .project-card", 
						{ opacity: 0, y: 24, scale: 0.98 },
						{
							opacity: 1,
							y: 0,
							scale: 1,
							duration: 0.6,
							stagger: 0.1,
							ease: "power2.out",
							scrollTrigger: {
								trigger: "#projects .secondary-projects-grid",
								start: "top 90%",
								toggleActions: "play none none none"
							}
						}
					);

					// General scroll-reveal fallback for standard elements (fade up only)
					document.querySelectorAll(".reveal").forEach((el) => {
						if (el.classList.contains("project-card")) {
							return; // already stagger-revealed above
						}

						gsap.fromTo(el, 
							{ opacity: 0, y: 20 },
							{
								opacity: 1,
								y: 0,
								duration: 0.5,
								ease: "power2.out",
								scrollTrigger: {
									trigger: el,
									start: "top 92%",
									toggleActions: "play none none none"
								}
							}
						);
					});
				} catch (err) {
					console.error("GSAP Animations failed to initialize. Triggering fallbacks.", err);
					
					// Fail-safe fallback to make everything visible immediately so user doesn't get stuck
					document.querySelectorAll(".reveal").forEach(el => {
						if (el instanceof HTMLElement) {
							el.style.opacity = "1";
							el.style.transform = "none";
						}
					});
					document.querySelectorAll(".hero-name, .hero-tagline, .hero-sub, .hero-btns, .scroll-indicator-wrap").forEach(el => {
						if (el instanceof HTMLElement) {
							el.style.opacity = "1";
							el.style.transform = "none";
						}
					});
					
					// Trigger loader completion if it was waiting for boot completion event
					const loaderOverlayEl = document.getElementById("cinematic-loader");
					const mainContentEl = document.getElementById("main-content");
					if (loaderOverlayEl) {
						loaderOverlayEl.style.opacity = "0";
						loaderOverlayEl.style.pointerEvents = "none";
					}
					if (mainContentEl) {
						mainContentEl.style.opacity = "1";
						mainContentEl.style.transform = "none";
						mainContentEl.style.filter = "none";
						mainContentEl.style.pointerEvents = "all";
					}
					document.body.classList.remove("loading");
				}
			});

			// ── Navbar opacity on scroll fallback ──────────────────
			window.addEventListener("scroll", () => {
				if (!(window as any).lenis) {
					updateNavbarBg(window.scrollY);
					highlightNav();
				}
			});

			const checkLenisNav = setInterval(() => {
				if ((window as any).lenis) {
					clearInterval(checkLenisNav);
					(window as any).lenis.on('scroll', (e: any) => {
						updateNavbarBg(e.scroll);
					});
				}
			}, 100);
		</script>
	</body>
</html>
