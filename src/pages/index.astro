	<script>
			declare var Typed: any;
			declare var VanillaTilt: any;

			declare global {
				interface Window {
					VanillaTilt: any;
				}
			}

			// ── Typed.js ──────────────────────────────────────────
			document.addEventListener("DOMContentLoaded", () => {
				new Typed("#typed", {
					strings: [
						"Full Stack Developer & AI Engineer.",
						"Building scalable web applications.",
						"Developing intelligent AI solutions.",
					],
					typeSpeed: 50,
					backSpeed: 30,
					backDelay: 2000,
					loop: true,
				});
			});

			// ── Unified Spatial Ecosystem Engine (Relocated globally to PersistentEnvironment) ───


			// ── Vanilla Tilt ──────────────────────────────────────
			document.addEventListener("DOMContentLoaded", () => {
				if (window.VanillaTilt) {
					VanillaTilt.init(document.querySelectorAll("[data-tilt]"), {
						max: 8,
						glare: true,
						"max-glare": 0.2,
					});
				}
			});

			// ── Scroll Reveal ─────────────────────────────────────
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((e, i) => {
						if (e.isIntersecting) {
							setTimeout(
								() => e.target.classList.add("visible"),
								i * 80,
							);
						}
					});
				},
				{ threshold: 0.12 },
			);

			document
				.querySelectorAll(".reveal")
				.forEach((el) => observer.observe(el));

			// ── Mobile Menu ───────────────────────────────────────
			function openMobileMenu() {
				document.getElementById("mobileMenu")?.classList.add("open");
			}
			function closeMobileMenu() {
				document.getElementById("mobileMenu")?.classList.remove("open");
			}

			// ── Navbar opacity on scroll ──────────────────────────
			window.addEventListener("scroll", () => {
				const nav = document.querySelector("nav");
				if (nav) {
					nav.style.background =
						window.scrollY > 50 ? "rgba(0,0,0,0.5)" : "rgba(0,0,0,0.2)";
				}
			});

			// ── Interactive Systems Gallery (Replaced by MacOS Workspace React component) ──
			// Legacy overlay controller removed — now handled by ProjectsWorkspace.jsx

			// Expose empty stubs for any leftover inline handlers
			(window as any).openSystemPanel = () => {};
			(window as any).closeSystemPanel = () => {};



		</script>
