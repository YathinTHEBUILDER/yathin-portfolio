---
// Yathin — Portfolio
import PersistentEnvironment from '../components/PersistentEnvironment.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Yathin | Full Stack Developer & AI Engineer</title>
		<meta
			name="description"
			content="Portfolio of Yathin — Full Stack Developer and AI Engineer exploring machine intelligence and modern web architectures."
		/>
		<meta name="theme-color" content="#f97316" />

		<!-- Google Fonts: Premium AI & Engineering Pack -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>

		<!-- Typed.js -->
		<script
			src="https://cdn.jsdelivr.net/npm/typed.js@2.1.0/dist/typed.umd.js"
		></script>



		<!-- Vanilla Tilt -->
		<script
			src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js"
		></script>

		<style>
			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			:root {
				/* ── PREMIUM TYPOGRAPHY SYSTEM ── */
				--font-display: 'Outfit', sans-serif;
				--font-tech: 'Space Grotesk', monospace, sans-serif;
				--font-sans: 'Plus Jakarta Sans', sans-serif;

				/* ── UNIFIED MOTION SYSTEM TOKENS (Phase 2) ── */
				--motion-duration-fast: 0.2s;      /* Micro-interactions, badge color fades */
				--motion-duration-medium: 0.38s;   /* Standard card hover displacement, panels */
				--motion-duration-slow: 0.6s;      /* Revealer slides, grid layout displacements */
				--motion-duration-cinematic: 1.2s; /* Global site reveal loader overlay fades */

				/* Sleek cinematic easing curves */
				--motion-ease-cinematic: cubic-bezier(0.16, 1, 0.3, 1);    /* Premium smooth quintic ease-out */
				--motion-ease-expressive: cubic-bezier(0.34, 1.56, 0.64, 1); /* Snappy physical spring ease-out */
				--motion-ease-standard: cubic-bezier(0.4, 0, 0.2, 1);       /* Controlled ease-in-out */

				/* Ready-to-use transitions */
				--transition-fast: all var(--motion-duration-fast) var(--motion-ease-standard);
				--transition-medium: all var(--motion-duration-medium) var(--motion-ease-cinematic);
				--transition-slow: all var(--motion-duration-slow) var(--motion-ease-cinematic);
				--transition-cinematic: all var(--motion-duration-cinematic) var(--motion-ease-cinematic);

				--accent: #f97316;
				--accent-glow: rgba(249, 115, 22, 0.35);
				--bg: #0a0a0a;
				--glass: rgba(255, 255, 255, 0.05);
				--glass-border: rgba(255, 255, 255, 0.1);
			}

						/* ── UNIFIED SPATIAL ECOSYSTEM BACKGROUND ── */
			/* Relocated to PersistentEnvironment.astro component */

			/* Hide scrollbars when preloader is loading */
			body.loading {
				overflow: hidden !important;
				height: 100vh;
			}

			section {
				scroll-margin-top: 85px;
			}

			/* ── WORLD-CLASS CINEMATIC PRELOADER OVERLAY ── */
			#cinematic-loader {
				position: fixed;
				inset: 0;
				z-index: 9999;
				background: #060606;
				display: flex;
				align-items: center;
				justify-content: center;
				transition: opacity var(--motion-duration-cinematic) var(--motion-ease-cinematic), visibility var(--motion-duration-cinematic);
				overflow: hidden;
			}

			.loader-overlay-gradient {
				position: absolute;
				inset: 0;
				background: radial-gradient(circle at center, rgba(249, 115, 22, 0.045) 0%, transparent 65%);
				pointer-events: none;
			}

			.loader-grid-overlay {
				position: absolute;
				inset: 0;
				background-image: 
					linear-gradient(rgba(255, 255, 255, 0.008) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.008) 1px, transparent 1px);
				background-size: 50px 50px;
				background-position: center;
				mask-image: radial-gradient(circle at center, black 40%, transparent 80%);
				-webkit-mask-image: radial-gradient(circle at center, black 40%, transparent 80%);
				pointer-events: none;
			}

			.loader-ui {
				position: relative;
				width: 320px;
				height: 380px;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				border: 1px solid rgba(255, 255, 255, 0.03);
				background: rgba(10, 10, 10, 0.45);
				backdrop-filter: blur(25px);
				-webkit-backdrop-filter: blur(25px);
				border-radius: 24px;
				padding: 2.5rem;
				box-shadow: 0 30px 60px rgba(0, 0, 0, 0.8), inset 0 1px 1px rgba(255,255,255,0.05);
				transition: var(--transition-cinematic);
			}

			.hud-box {
				position: absolute;
				width: 16px;
				height: 16px;
				border: 1.5px solid rgba(249, 115, 22, 0.25);
				pointer-events: none;
			}
			.hud-box.top-left { top: -2px; left: -2px; border-right: none; border-bottom: none; }
			.hud-box.top-right { top: -2px; right: -2px; border-left: none; border-bottom: none; }
			.hud-box.bottom-left { bottom: -2px; left: -2px; border-right: none; border-top: none; }
			.hud-box.bottom-right { bottom: -2px; right: -2px; border-left: none; border-top: none; }

			.holo-ring-container {
				position: relative;
				width: 170px;
				height: 170px;
				margin-bottom: 2.5rem;
			}

			.holo-ring {
				width: 100%;
				height: 100%;
				transform: rotate(-90deg);
			}

			.ring-outer {
				fill: none;
				stroke: rgba(255, 255, 255, 0.03);
				stroke-width: 1;
				stroke-dasharray: 4 6;
			}

			.ring-progress {
				fill: none;
				stroke: var(--accent);
				stroke-width: 2.5;
				stroke-dasharray: 502.65; /* 2 * PI * 80 */
				stroke-dashoffset: 502.65;
				stroke-linecap: round;
				filter: drop-shadow(0 0 6px var(--accent-glow));
			}

			.ring-core {
				fill: var(--accent);
				opacity: 0.12;
				filter: drop-shadow(0 0 10px var(--accent-glow));
			}

			.ring-orbit-1 {
				fill: none;
				stroke: rgba(255, 255, 255, 0.04);
				stroke-width: 1;
				stroke-dasharray: 12 18;
				animation: spin-clockwise calc(24s / var(--orbit-speed, 1)) infinite linear;
				transform-origin: center;
			}

			.ring-orbit-2 {
				fill: none;
				stroke: rgba(249, 115, 22, 0.08);
				stroke-width: 1.5;
				stroke-dasharray: 60 15;
				animation: spin-counter calc(16s / var(--orbit-speed, 1)) infinite linear;
				transform-origin: center;
			}

			@keyframes spin-clockwise {
				from { transform: rotate(0deg); }
				to { transform: rotate(360deg); }
			}

			@keyframes spin-counter {
				from { transform: rotate(360deg); }
				to { transform: rotate(0deg); }
			}

			.holo-percentage {
				position: absolute;
				inset: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				font-family: var(--font-tech);
				font-size: 1.9rem;
				font-weight: 700;
				color: #fff;
				letter-spacing: 0.02em;
				text-shadow: 0 0 10px rgba(255, 255, 255, 0.2);
			}

			.holo-percentage::after {
				content: "%";
				font-size: 0.85rem;
				color: var(--accent);
				font-weight: 700;
				margin-left: 2px;
			}

			.status-panel {
				width: 100%;
				text-align: center;
				font-family: var(--font-tech);
			}

			.status-header {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.5rem;
				margin-bottom: 0.5rem;
			}

			.status-indicator-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--accent);
				box-shadow: 0 0 8px var(--accent);
				animation: blink calc(1.2s / var(--orbit-speed, 1)) infinite alternate cubic-bezier(0.4, 0, 0.2, 1);
			}

			@keyframes blink {
				0% { opacity: 0.2; transform: scale(0.9); }
				100% { opacity: 1; transform: scale(1.1); }
			}

			.status-title {
				font-size: 0.7rem;
				font-weight: 700;
				letter-spacing: 0.25em;
				color: #888;
			}

			.status-code {
				font-family: monospace;
				font-size: 0.65rem;
				color: var(--accent);
				letter-spacing: 0.05em;
				opacity: 0.8;
				min-height: 14px;
			}

			.status-strip {
				width: 100%;
				margin-top: 1.2rem;
			}

			.status-bar-bg {
				width: 100%;
				height: 2px;
				background: rgba(255, 255, 255, 0.03);
				border-radius: 1px;
				overflow: hidden;
			}

			.status-bar-fill {
				height: 100%;
				width: 0%;
				background: var(--accent);
				box-shadow: 0 0 5px var(--accent-glow);
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				background: transparent;
				color: #fff;
				font-family: var(--font-sans);
				overflow-x: hidden;
			}

			/* Scrollbar */
			::-webkit-scrollbar {
				width: 6px;
			}
			::-webkit-scrollbar-track {
				background: #111;
			}
			::-webkit-scrollbar-thumb {
				background: var(--accent);
				border-radius: 3px;
			}
			::selection {
				background: var(--accent);
				color: #000;
			}



			/* Glass utility */
			.glass {
				background: var(--glass);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border: 1px solid var(--glass-border);
				border-radius: 16px;
			}

			/* NAVBAR */
			nav {
				position: sticky;
				top: 0;
				z-index: 100;
				background: linear-gradient(180deg, rgba(5,5,5,0.9) 0%, rgba(5,5,5,0.4) 100%);
				backdrop-filter: blur(20px);
				border-bottom: 1px solid rgba(255, 255, 255, 0.05);
				padding: 1rem 2rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
				animation: slideDown 0.6s ease-out;
				box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
			}

			@keyframes slideDown {
				from {
					transform: translateY(-100%);
					opacity: 0;
				}
				to {
					transform: translateY(0);
					opacity: 1;
				}
			}

			.nav-logo {
				font-family: var(--font-display);
				font-weight: 900;
				font-size: 1.3rem;
				color: var(--accent);
				text-decoration: none;
				text-shadow: 0 0 10px var(--accent-glow);
			}

			.nav-links {
				display: flex;
				gap: 1rem;
				list-style: none;
			}
			.nav-links a {
				color: #94a3b8;
				text-decoration: none;
				font-size: 0.9rem;
				font-weight: 600;
				letter-spacing: 0.05em;
				transition: all 0.3s ease;
				position: relative;
				padding: 0.5rem 1rem;
				border-radius: 8px;
			}
			.nav-links a:hover,
			.nav-links a.active {
				color: #fff;
				background: rgba(255, 255, 255, 0.05);
				text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
			}
			.nav-links a::after {
				content: '';
				position: absolute;
				bottom: 0;
				left: 50%;
				width: 0;
				height: 2px;
				background: var(--accent);
				box-shadow: 0 0 8px var(--accent-glow);
				transition: width 0.3s ease;
				transform: translateX(-50%);
			}
			.nav-links a:hover::after,
			.nav-links a.active::after {
				width: 60%;
			}
			.nav-links a.nav-terminal-btn::after {
				display: none;
			}
			.nav-links a.nav-terminal-btn:hover {
				background: rgba(249, 115, 22, 0.25);
				color: #fff;
				box-shadow: 0 0 15px var(--accent-glow);
				transform: translateY(-2px);
			}

			.hamburger {
				display: none;
				flex-direction: column;
				gap: 5px;
				cursor: pointer;
				background: none;
				border: none;
			}
			.hamburger span {
				display: block;
				width: 24px;
				height: 2px;
				background: #fff;
				border-radius: 2px;
				transition: 0.3s;
			}

			.mobile-menu {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(0, 0, 0, 0.95);
				backdrop-filter: blur(20px);
				z-index: 200;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				gap: 2.5rem;
			}
			.mobile-menu.open {
				display: flex;
			}
			.mobile-menu a {
				color: #fff;
				text-decoration: none;
				font-family: var(--font-display);
				font-size: 1.5rem;
				font-weight: 700;
				transition: color 0.2s;
			}
			.mobile-menu a:hover {
				color: var(--accent);
			}
			.mobile-close {
				position: absolute;
				top: 1.5rem;
				right: 2rem;
				background: none;
				border: none;
				color: #fff;
				font-size: 2rem;
				cursor: pointer;
			}

			@media (max-width: 768px) {
				.nav-links {
					display: none;
				}
				.hamburger {
					display: flex;
				}
			}

			/* SECTIONS */
			section {
				padding: 6rem 2rem;
				max-width: 1100px;
				margin: 0 auto;
			}

			.section-title {
				font-family: var(--font-display);
				font-size: clamp(1.8rem, 4vw, 2.8rem);
				font-weight: 800;
				margin-bottom: 0.5rem;
				letter-spacing: -0.02em;
			}
			.section-title span {
				color: var(--accent);
			}

			.title-bar {
				width: 60px;
				height: 3px;
				background: var(--accent);
				border-radius: 2px;
				margin-bottom: 3rem;
				box-shadow: 0 0 10px var(--accent-glow);
			}

			/* HERO */
			#home {
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				text-align: center;
				flex-direction: column;
				padding: 2rem;
				max-width: 100%;
				position: relative;
			}

			/* Floating HUD Decorators */
			.hero-hud-decorator {
				position: absolute;
				top: 2.5rem;
				display: flex;
				flex-direction: column;
				font-family: var(--font-tech);
				font-size: 0.65rem;
				letter-spacing: 0.2em;
				color: #64748b;
				pointer-events: none;
				opacity: 0;
				animation: fadeUp 1s ease-out 0.8s forwards;
			}
			.hero-hud-decorator.top-left {
				left: 2.5rem;
				text-align: left;
				border-left: 1px solid rgba(249, 115, 22, 0.3);
				padding-left: 0.8rem;
				gap: 0.3rem;
			}
			.hero-hud-decorator.top-right {
				right: 2.5rem;
				text-align: right;
				border-right: 1px solid rgba(249, 115, 22, 0.3);
				padding-right: 0.8rem;
				gap: 0.3rem;
			}
			.hud-pulse-status {
				display: inline-flex;
				align-items: center;
				justify-content: flex-end;
				gap: 0.4rem;
				color: var(--accent);
			}
			.hud-status-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--accent);
				box-shadow: 0 0 10px var(--accent);
				animation: dot-pulse-fast 1.5s infinite alternate;
			}

			@media (max-width: 1024px) {
				.hero-hud-decorator { display: none; }
			}

			/* Core Avatar Display */
			.hero-avatar-container {
				position: relative;
				width: 200px;
				height: 200px;
				margin: 0 auto 2.5rem;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.hero-avatar-wrap {
				position: relative;
				width: 150px;
				height: 150px;
				opacity: 0;
				animation: fadeUp 0.8s ease-out forwards;
				display: flex;
				align-items: center;
				justify-content: center;
				cursor: pointer;
			}
			.hero-avatar-glow-bg {
				position: absolute;
				inset: -20px;
				background: radial-gradient(circle at center, rgba(249, 115, 22, 0.25) 0%, transparent 70%);
				border-radius: 50%;
				filter: blur(15px);
				transition: all 0.5s ease;
			}
			.hero-avatar-wrap:hover .hero-avatar-glow-bg {
				background: radial-gradient(circle at center, rgba(249, 115, 22, 0.45) 0%, transparent 75%);
				filter: blur(20px);
				transform: scale(1.1);
			}
			.hero-avatar-ring {
				position: absolute;
				inset: -8px;
				border-radius: 50%;
				background: conic-gradient(from 0deg, transparent 0%, rgba(249, 115, 22, 0.8) 25%, transparent 50%);
				animation: spin-slow 4s linear infinite;
				z-index: 0;
				transition: inset 0.4s ease;
			}
			.hero-avatar-ring::before {
				content: '';
				position: absolute;
				inset: 2px;
				border-radius: 50%;
				background: #050505;
			}
			.hero-avatar-ring-2 {
				position: absolute;
				inset: -18px;
				border-radius: 50%;
				border: 1px dashed rgba(249, 115, 22, 0.35);
				animation: spin-slow 15s linear infinite reverse;
				z-index: 0;
				transition: inset 0.4s ease, border-color 0.4s ease;
			}
			.hero-avatar-ring-3 {
				position: absolute;
				inset: -28px;
				border-radius: 50%;
				border: 1px solid rgba(255, 255, 255, 0.05);
				animation: spin-slow 25s linear infinite;
				z-index: 0;
				transition: inset 0.4s ease;
			}
			.hero-avatar-wrap:hover .hero-avatar-ring { inset: -12px; }
			.hero-avatar-wrap:hover .hero-avatar-ring-2 { inset: -24px; border-color: rgba(249, 115, 22, 0.6); }
			.hero-avatar-wrap:hover .hero-avatar-ring-3 { inset: -36px; border-color: rgba(255, 255, 255, 0.15); }

			.hero-avatar {
				position: relative;
				width: 100%;
				height: 100%;
				border-radius: 50%;
				overflow: hidden;
				z-index: 2;
				box-shadow: 0 0 30px rgba(249, 115, 22, 0.3), inset 0 0 20px rgba(0,0,0,0.5);
				border: 2px solid rgba(255, 255, 255, 0.15);
				transition: border-color 0.4s ease, transform 0.4s ease;
			}
			.hero-avatar-wrap:hover .hero-avatar {
				border-color: var(--accent);
				transform: scale(1.03);
			}

			/* Orbital Trackers */
			.orbit-tracker {
				position: absolute;
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--accent);
				box-shadow: 0 0 10px var(--accent);
				z-index: 3;
			}
			.tracker-1 {
				top: 10px;
				left: 50%;
				transform-origin: 0 90px;
				animation: spin-slow 8s linear infinite;
			}
			.tracker-2 {
				bottom: 10px;
				right: 50%;
				transform-origin: 0 -90px;
				animation: spin-slow 12s linear infinite reverse;
			}

			@keyframes spin-slow {
				100% { transform: rotate(360deg); }
			}

			/* Status Badge */
			.hero-greeting-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.6rem;
				padding: 0.45rem 1.4rem;
				background: rgba(249, 115, 22, 0.08);
				border: 1px solid rgba(249, 115, 22, 0.3);
				border-radius: 30px;
				color: var(--accent);
				font-family: var(--font-tech);
				font-size: 0.8rem;
				font-weight: 700;
				letter-spacing: 0.25em;
				text-transform: uppercase;
				margin-bottom: 1.5rem;
				opacity: 0;
				animation: fadeUp 0.8s ease-out 0.1s forwards;
				backdrop-filter: blur(12px);
				box-shadow: 0 0 20px rgba(249, 115, 22, 0.15);
				position: relative;
				overflow: hidden;
			}
			.badge-scanner {
				position: absolute;
				top: 0;
				bottom: 0;
				width: 20px;
				background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
				animation: badge-scan 3s ease-in-out infinite;
				transform: skewX(-20deg);
			}
			@keyframes badge-scan {
				0% { left: -30%; }
				100% { left: 130%; }
			}
			.pulse-dot-inner {
				width: 6px;
				height: 6px;
				background: var(--accent);
				border-radius: 50%;
				box-shadow: 0 0 10px var(--accent);
				animation: dot-pulse-fast 1.5s infinite alternate;
			}
			@keyframes dot-pulse-fast {
				0% { opacity: 0.4; box-shadow: 0 0 4px var(--accent); }
				100% { opacity: 1; box-shadow: 0 0 12px var(--accent), 0 0 20px rgba(249, 115, 22, 0.5); }
			}

			/* Hero Name */
			.hero-name {
				font-family: var(--font-display);
				font-size: clamp(3.2rem, 8.5vw, 7rem);
				font-weight: 900;
				line-height: 1.1;
				margin-bottom: 1.5rem;
				opacity: 0;
				animation: fadeUp 0.8s ease-out 0.2s forwards;
				letter-spacing: -0.03em;
				position: relative;
			}
			.hero-name .gradient {
				background: linear-gradient(135deg, #ffffff 0%, #f97316 50%, #fbbf24 100%);
				background-size: 200% auto;
				animation: textShine 5s linear infinite;
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				filter: drop-shadow(0 0 35px rgba(249, 115, 22, 0.3));
			}
			@keyframes textShine {
				to { background-position: 200% center; }
			}

			/* Typewriter Box */
			.hero-typewriter-box {
				display: inline-flex;
				align-items: center;
				gap: 0.6rem;
				background: rgba(0, 0, 0, 0.4);
				border: 1px solid rgba(255, 255, 255, 0.1);
				padding: 0.6rem 1.5rem;
				border-radius: 12px;
				font-family: var(--font-tech);
				font-size: clamp(1.1rem, 3vw, 1.5rem);
				color: #f1f5f9;
				margin-bottom: 1.8rem;
				min-height: 3rem;
				opacity: 0;
				font-weight: 500;
				animation: fadeUp 0.8s ease-out 0.4s forwards;
				box-shadow: 0 10px 30px rgba(0,0,0,0.5), inset 0 1px 1px rgba(255,255,255,0.05);
				backdrop-filter: blur(12px);
				letter-spacing: 0.02em;
			}
			.typewriter-prefix {
				color: var(--accent);
				font-weight: 700;
			}

			/* Hero Subtitle */
			.hero-sub {
				color: #94a3b8;
				font-size: 1.15rem;
				line-height: 1.8;
				max-width: 650px;
				margin: 0 auto 3.5rem;
				opacity: 0;
				animation: fadeUp 0.8s ease-out 0.5s forwards;
				font-weight: 400;
			}

			/* Hero Buttons */
			.hero-btns {
				display: flex;
				gap: 1.2rem;
				flex-wrap: wrap;
				justify-content: center;
				align-items: center;
				margin-bottom: 3rem;
				opacity: 0;
				animation: fadeUp 0.6s ease-out 0.7s forwards;
			}

			.btn-primary {
				padding: 0.9rem 2.5rem;
				border: 1px solid rgba(249, 115, 22, 0.6);
				background: linear-gradient(135deg, rgba(249, 115, 22, 0.3), rgba(249, 115, 22, 0.1));
				color: #fff;
				border-radius: 14px;
				text-decoration: none;
				font-family: var(--font-sans);
				font-weight: 600;
				letter-spacing: 0.05em;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				box-shadow: inset 0 1px 1px rgba(255,255,255,0.2), 0 0 25px rgba(249, 115, 22, 0.2);
				backdrop-filter: blur(12px);
				cursor: pointer;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.6rem;
			}
			.btn-arrow {
				transition: transform 0.3s ease;
			}
			.btn-primary:hover {
				background: linear-gradient(135deg, rgba(249, 115, 22, 0.5), rgba(249, 115, 22, 0.2));
				box-shadow: inset 0 1px 1px rgba(255,255,255,0.3), 0 0 35px rgba(249, 115, 22, 0.4);
				transform: translateY(-3px) scale(1.02);
				border-color: rgba(249, 115, 22, 0.9);
			}
			.btn-primary:hover .btn-arrow {
				transform: translateX(4px);
			}

			.btn-secondary {
				padding: 0.9rem 2.2rem;
				border: 1px solid rgba(255, 255, 255, 0.15);
				background: rgba(255, 255, 255, 0.03);
				color: #e2e8f0;
				border-radius: 14px;
				text-decoration: none;
				font-family: var(--font-sans);
				font-weight: 600;
				letter-spacing: 0.05em;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				backdrop-filter: blur(12px);
				display: flex;
				align-items: center;
				gap: 0.6rem;
				box-shadow: inset 0 1px 1px rgba(255,255,255,0.05);
			}
			.btn-secondary:hover {
				border-color: rgba(249, 115, 22, 0.5);
				background: rgba(249, 115, 22, 0.1);
				color: var(--accent);
				transform: translateY(-3px);
				box-shadow: 0 10px 25px rgba(0,0,0,0.5), inset 0 1px 1px rgba(255,255,255,0.1);
			}

			.social-group {
				display: flex;
				gap: 0.8rem;
				align-items: center;
			}

			.btn-ghost {
				width: 48px;
				height: 48px;
				border: 1px solid rgba(255, 255, 255, 0.12);
				background: rgba(255, 255, 255, 0.03);
				color: #94a3b8;
				border-radius: 50%;
				text-decoration: none;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				backdrop-filter: blur(12px);
				display: flex;
				align-items: center;
				justify-content: center;
				box-shadow: inset 0 1px 1px rgba(255,255,255,0.05);
			}
			.btn-ghost:hover {
				border-color: rgba(249, 115, 22, 0.5);
				background: rgba(249, 115, 22, 0.15);
				color: var(--accent);
				transform: translateY(-4px) scale(1.08);
				box-shadow: 0 10px 25px rgba(249, 115, 22, 0.25), inset 0 1px 1px rgba(255,255,255,0.1);
			}
			.btn-ghost svg {
				width: 1.3rem;
				height: 1.3rem;
				fill: currentColor;
				transition: fill 0.3s ease;
			}

			/* Sleek Scroll Indicator */
			.scroll-indicator-wrap {
				position: absolute;
				bottom: 2rem;
				left: 50%;
				transform: translateX(-50%);
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.5rem;
				opacity: 0;
				animation: fadeUp 0.8s ease-out 1s forwards;
				pointer-events: none;
			}
			.mouse-frame {
				width: 22px;
				height: 36px;
				border: 2px solid rgba(255, 255, 255, 0.2);
				border-radius: 12px;
				display: flex;
				justify-content: center;
				padding-top: 6px;
				box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
			}
			.mouse-wheel {
				width: 4px;
				height: 8px;
				background: var(--accent);
				border-radius: 2px;
				animation: scroll-wheel 2s cubic-bezier(0.15, 0.41, 0.69, 0.94) infinite;
				box-shadow: 0 0 8px var(--accent);
			}
			.scroll-text {
				font-family: var(--font-tech);
				font-size: 0.65rem;
				letter-spacing: 0.25em;
				color: #64748b;
				text-transform: uppercase;
			}

			@keyframes scroll-wheel {
				0% { transform: translateY(0); opacity: 1; }
				50% { transform: translateY(10px); opacity: 0; }
				51% { transform: translateY(-5px); opacity: 0; }
				100% { transform: translateY(0); opacity: 1; }
			}

			@keyframes fadeUp {
				from {
					opacity: 0;
					transform: translateY(30px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			/* ABOUT */
			.about-grid {
				display: grid;
				grid-template-columns: 1fr 2fr;
				gap: 4rem;
				align-items: start;
			}

			.about-avatar-wrap {
				text-align: center;
			}

			.about-avatar {
				width: 180px;
				height: 180px;
				border-radius: 50%;
				background: var(--glass);
				backdrop-filter: blur(12px);
				box-shadow:
					0 0 0 3px rgba(249, 115, 22, 0.4),
					0 0 40px rgba(249, 115, 22, 0.2);
				display: flex;
				align-items: center;
				justify-content: center;
				font-family: var(--font-display);
				font-size: 2.8rem;
				font-weight: 800;
				color: var(--accent);
				margin: 0 auto 1.5rem;
				position: relative;
			}
			.about-avatar::after {
				content: '';
				position: absolute;
				inset: -6px;
				border-radius: 50%;
				border: 1px dashed rgba(249, 115, 22, 0.3);
				animation: spin-slow 10s linear infinite;
			}

			.about-name {
				font-family: var(--font-display);
				font-weight: 700;
				font-size: 1.4rem;
				margin-bottom: 0.4rem;
				letter-spacing: -0.01em;
			}

			.about-role {
				color: var(--accent);
				font-size: 0.9rem;
				margin-bottom: 0.4rem;
				font-weight: 600;
			}
			.about-uni {
				color: #888;
				font-size: 0.8rem;
				margin-bottom: 0.2rem;
			}
			.about-loc {
				color: #666;
				font-size: 0.8rem;
			}

			.about-bio {
				line-height: 1.9;
				color: #cbd5e1;
				margin-bottom: 2.5rem;
				font-size: 1rem;
			}

			.stats-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1rem;
				margin-bottom: 2rem;
			}

			.stat-card {
				padding: 1.5rem 1.2rem;
				text-align: center;
				border-radius: 16px;
				background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
				border: 1px solid rgba(255,255,255,0.05);
				backdrop-filter: blur(10px);
				transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
			}
			.stat-card:hover {
				transform: translateY(-5px);
				border-color: rgba(249, 115, 22, 0.4);
				box-shadow: 0 10px 30px rgba(0,0,0,0.5), inset 0 0 15px rgba(249, 115, 22, 0.1);
			}

			.stat-number {
				font-family: var(--font-tech);
				font-size: 2rem;
				font-weight: 700;
				color: var(--accent);
				display: block;
				letter-spacing: -0.02em;
			}

			.stat-label {
				font-size: 0.75rem;
				color: #888;
				margin-top: 0.3rem;
			}

			.quote {
				border-left: 3px solid var(--accent);
				padding-left: 1rem;
				color: #888;
				font-style: italic;
				font-size: 0.9rem;
			}

			@media (max-width: 768px) {
				.about-grid {
					grid-template-columns: 1fr;
					gap: 2rem;
				}
				.stats-grid {
					grid-template-columns: repeat(3, 1fr);
				}
			}

			/* PROJECTS - INTERACTIVE SYSTEMS GALLERY */
			#projects {
				position: relative;
				overflow: visible;
			}

			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(330px, 1fr));
				gap: 2.5rem;
			}

			/* Project Card as a Dynamic System Module */
			.project-card {
				position: relative;
				padding: 2.2rem;
				background: linear-gradient(145deg, rgba(20,20,20,0.8), rgba(5,5,5,0.9));
				backdrop-filter: blur(20px);
				border: 1px solid rgba(255,255,255,0.05);
				border-radius: 20px;
				transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
				overflow: hidden;
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				transform-style: preserve-3d;
				perspective: 1000px;
				cursor: default;
			}

			.project-card::before {
				content: '';
				position: absolute;
				inset: 0;
				background: linear-gradient(135deg, rgba(249, 115, 22, 0.1) 0%, transparent 100%);
				opacity: 0;
				transition: opacity 0.5s ease;
				z-index: 0;
				pointer-events: none;
			}

			.project-card:hover {
				border-color: rgba(249, 115, 22, 0.5);
				box-shadow: 
					0 25px 50px rgba(0, 0, 0, 0.8),
					0 0 40px rgba(249, 115, 22, 0.15),
					inset 0 0 0 1px rgba(249, 115, 22, 0.1);
				transform: translateY(-8px) scale(1.02);
			}

			.project-card:hover::before {
				opacity: 1;
			}

			/* Surrounding Dimming Effects */
			.projects-grid:has(.project-card:hover) .project-card:not(:hover) {
				opacity: 0.28;
				filter: blur(2.5px) grayscale(0.2);
				transform: scale(0.96) translateY(2px);
				transition: var(--transition-slow);
			}

			/* System Status Header */
			.system-status-bar {
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-family: var(--font-tech);
				font-size: 0.72rem;
				letter-spacing: 0.12em;
				color: #666;
				border-bottom: 1px solid rgba(255, 255, 255, 0.05);
				padding-bottom: 0.8rem;
				z-index: 1;
			}

			.status-tag {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				font-weight: 700;
			}

			.status-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: #10b981;
				box-shadow: 0 0 8px #10b981;
				animation: statusPulse 1.8s infinite alternate;
			}

			.project-card:hover .status-dot {
				background: var(--accent);
				box-shadow: 0 0 10px var(--accent);
				animation: statusPulseFast 0.8s infinite alternate;
			}

			@keyframes statusPulse {
				0% { opacity: 0.4; }
				100% { opacity: 1; }
			}
			@keyframes statusPulseFast {
				0% { opacity: 0.5; transform: scale(0.9); }
				100% { opacity: 1; transform: scale(1.2); }
			}

			/* Card Details Layout */
			.project-info-wrap {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
				z-index: 1;
			}

			.project-top {
				display: flex;
				align-items: center;
				gap: 0.8rem;
			}

			.project-icon {
				font-size: 1.8rem;
				filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.1));
				transition: transform var(--motion-duration-medium) var(--motion-ease-cinematic);
			}
			.project-card:hover .project-icon {
				transform: scale(1.15) rotate(5deg);
			}

			.project-name {
				font-family: var(--font-display);
				font-size: 1.5rem;
				font-weight: 800;
				color: #fff;
				letter-spacing: -0.01em;
				text-shadow: 0 2px 10px rgba(0,0,0,0.5);
			}

			.project-badge {
				background: rgba(249, 115, 22, 0.15);
				border: 1px solid rgba(249, 115, 22, 0.4);
				color: var(--accent);
				font-size: 0.68rem;
				padding: 0.3rem 0.8rem;
				border-radius: 6px;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				font-family: var(--font-tech);
				margin-left: auto;
				box-shadow: 0 0 10px rgba(249, 115, 22, 0.1);
			}

			.project-fullname {
				color: #cbd5e1;
				font-size: 0.85rem;
				font-weight: 500;
			}

			.project-desc {
				color: #94a3b8;
				font-size: 0.95rem;
				line-height: 1.7;
				z-index: 1;
			}

			/* Visual System Blueprint Preview */
			.system-blueprint {
				position: relative;
				height: 110px;
				width: 100%;
				background: rgba(0, 0, 0, 0.4);
				border: 1px solid rgba(255, 255, 255, 0.05);
				border-radius: 12px;
				overflow: hidden;
				display: flex;
				align-items: center;
				justify-content: center;
				z-index: 1;
				transition: border-color 0.4s ease;
			}

			.project-card:hover .system-blueprint {
				border-color: rgba(249, 115, 22, 0.25);
				box-shadow: inset 0 0 20px rgba(249, 115, 22, 0.05);
			}

			.grid-bg {
				position: absolute;
				inset: 0;
				background-image: 
					linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
				background-size: 15px 15px;
				pointer-events: none;
			}

			.blueprint-svg {
				width: 90%;
				height: 80%;
				overflow: visible;
			}

			.connection-path {
				fill: none;
				stroke: rgba(255, 255, 255, 0.08);
				stroke-width: 1.5;
				transition: stroke 0.4s ease;
			}

			.project-card:hover .connection-path {
				stroke: rgba(249, 115, 22, 0.3);
			}

			.signal-pulse {
				fill: none;
				stroke: var(--accent);
				stroke-width: 2.5;
				stroke-linecap: round;
				stroke-dasharray: 8 35;
				stroke-dashoffset: 0;
				animation: signalFlow 2s infinite linear;
				opacity: 0.4;
				transition: opacity 0.4s ease;
			}

			.project-card:hover .signal-pulse {
				opacity: 1;
				animation-duration: 1.2s;
			}

			@keyframes signalFlow {
				to {
					stroke-dashoffset: -43;
				}
			}

			.blueprint-node {
				transition: all 0.4s ease;
			}

			.node-dot {
				fill: #1a1a1a;
				stroke: rgba(255, 255, 255, 0.3);
				stroke-width: 1.5;
				transition: all 0.4s ease;
			}

			.node-text {
				font-family: var(--font-tech);
				font-size: 8px;
				fill: #666;
				font-weight: 600;
				letter-spacing: 0.05em;
				transition: fill 0.4s ease;
			}

			.project-card:hover .node-dot {
				stroke: var(--accent);
				fill: rgba(249, 115, 22, 0.2);
				filter: drop-shadow(0 0 6px var(--accent-glow));
			}

			.project-card:hover .node-text {
				fill: #e2e8f0;
			}

			/* Tech Stack Badges */
			.tech-stack {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
				z-index: 1;
			}

			.tech-badge {
				background: rgba(255, 255, 255, 0.03);
				border: 1px solid rgba(255, 255, 255, 0.08);
				backdrop-filter: blur(5px);
				color: #cbd5e1;
				font-size: 0.75rem;
				padding: 0.35rem 0.9rem;
				border-radius: 8px;
				transition: all 0.3s ease;
				font-weight: 600;
			}

			.tech-badge:hover {
				border-color: rgba(249, 115, 22, 0.4);
				background: rgba(249, 115, 22, 0.1);
				color: #fff;
				transform: translateY(-2px);
				box-shadow: 0 4px 10px rgba(0,0,0,0.3);
			}

			/* Controls / Action Buttons */
			.card-actions {
				display: flex;
				gap: 0.8rem;
				margin-top: auto;
				z-index: 1;
			}

			.btn-action {
				flex: 1;
				padding: 0.6rem 1rem;
				border: 1px solid var(--glass-border);
				border-radius: 8px;
				color: #bbb;
				text-decoration: none;
				font-family: var(--font-tech);
				font-size: 0.75rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-align: center;
				transition: var(--transition-medium);
				cursor: pointer;
				background: transparent;
			}

			.btn-action.primary {
				background: rgba(249, 115, 22, 0.08);
				border-color: rgba(249, 115, 22, 0.3);
				color: var(--accent);
			}

			.btn-action:hover {
				border-color: var(--accent);
				color: var(--accent);
				box-shadow: 0 0 15px var(--accent-glow);
				transform: translateY(-2px);
			}

			.btn-action.primary:hover {
				background: rgba(249, 115, 22, 0.15);
			}

			/* ── CINEMATIC OPEN SYSTEM PANEL ── */
			.system-overlay {
				position: fixed;
				inset: 0;
				background: rgba(0, 0, 0, 0.8);
				backdrop-filter: blur(16px);
				-webkit-backdrop-filter: blur(16px);
				z-index: 999;
				display: flex;
				justify-content: flex-end;
				opacity: 0;
				pointer-events: none;
				transition: opacity var(--motion-duration-slow) var(--motion-ease-cinematic);
			}

			.system-overlay.active {
				opacity: 1;
				pointer-events: all;
			}

			.system-panel {
				width: 100%;
				max-width: 650px;
				height: 100%;
				background: #0d0d0d;
				border-left: 1px solid var(--glass-border);
				display: flex;
				flex-direction: column;
				transform: translateX(100%);
				transition: transform var(--motion-duration-slow) var(--motion-ease-cinematic);
				box-shadow: -20px 0 50px rgba(0, 0, 0, 0.8);
				padding: 2.5rem;
				overflow-y: auto;
			}

			.system-overlay.active .system-panel {
				transform: translateX(0);
			}

			.panel-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				border-bottom: 1px solid rgba(255, 255, 255, 0.08);
				padding-bottom: 1.5rem;
				margin-bottom: 2rem;
			}

			.panel-title-wrap {
				display: flex;
				align-items: center;
				gap: 1rem;
			}

			.panel-project-icon {
				font-size: 2.2rem;
			}

			.panel-project-name {
				font-family: var(--font-display);
				font-size: 1.8rem;
				font-weight: 800;
				letter-spacing: -0.01em;
			}

			.panel-close-btn {
				background: none;
				border: 1px solid var(--glass-border);
				padding: 0.5rem 1rem;
				color: #888;
				font-family: var(--font-tech);
				font-size: 0.75rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				border-radius: 6px;
				cursor: pointer;
				transition: var(--transition-medium);
			}

			.panel-close-btn:hover {
				border-color: var(--accent);
				color: var(--accent);
				box-shadow: 0 0 10px var(--accent-glow);
			}

			.panel-section-title {
				font-family: var(--font-tech);
				font-size: 0.85rem;
				color: var(--accent);
				text-transform: uppercase;
				letter-spacing: 0.15em;
				margin-bottom: 1.2rem;
				display: flex;
				align-items: center;
				gap: 0.8rem;
			}

			.panel-section-title::after {
				content: '';
				flex: 1;
				height: 1px;
				background: rgba(255, 255, 255, 0.08);
			}

			.pipeline-container {
				background: rgba(0, 0, 0, 0.4);
				border: 1px solid rgba(255, 255, 255, 0.05);
				border-radius: 12px;
				padding: 1.8rem;
				margin-bottom: 2rem;
				position: relative;
			}

			/* Detailed SVG architecture flow */
			.panel-flow-svg {
				width: 100%;
				height: auto;
				overflow: visible;
			}

			.panel-desc {
				color: #ccc;
				font-size: 0.95rem;
				line-height: 1.8;
				margin-bottom: 2rem;
			}

			/* Spec Sheet Grid */
			.spec-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1.2rem;
				margin-bottom: 2.5rem;
			}

			.spec-item {
				background: rgba(255, 255, 255, 0.02);
				border: 1px solid rgba(255, 255, 255, 0.04);
				padding: 1rem;
				border-radius: 8px;
			}

			.spec-label {
				font-family: var(--font-tech);
				font-size: 0.7rem;
				color: #666;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				display: block;
				margin-bottom: 0.4rem;
			}

			.spec-val {
				font-family: var(--font-sans);
				font-size: 0.95rem;
				font-weight: 700;
				color: #ddd;
			}

			.panel-actions {
				display: flex;
				gap: 1rem;
				margin-top: auto;
			}

			@media(max-width: 768px) {
				.system-panel {
					padding: 1.5rem;
				}
				.spec-grid {
					grid-template-columns: 1fr;
				}
			}

			/* SKILLS */
			.skills-categories {
				display: flex;
				flex-direction: column;
				gap: 2.5rem;
			}

			.skill-cat-label {
				font-size: 0.75rem;
				color: var(--accent);
				text-transform: uppercase;
				letter-spacing: 0.15em;
				margin-bottom: 1rem;
				display: flex;
				align-items: center;
				gap: 1rem;
			}
			.skill-cat-label::after {
				content: "";
				flex: 1;
				height: 1px;
				background: var(--glass-border);
			}

			.skill-badges {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
			}

			.skill-badge {
				background: var(--glass);
				border: 1px solid var(--glass-border);
				padding: 0.4rem 1rem;
				border-radius: 999px;
				font-size: 0.85rem;
				color: #ccc;
				transition: var(--transition-fast);
				cursor: default;
			}
			.skill-badge:hover {
				transform: scale(1.08) translateY(-2px);
				border-color: rgba(249, 115, 22, 0.5);
				background: rgba(249, 115, 22, 0.1);
				color: #fb923c;
				box-shadow: 0 0 calc(var(--proximity, 1) * 15px) rgba(249, 115, 22, 0.2);
			}

			/* ACHIEVEMENTS */
			.achievements-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.5rem;
			}

			.achievement-card {
				padding: 2rem;
				background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
				border: 1px solid rgba(255,255,255,0.05);
				border-radius: 16px;
				backdrop-filter: blur(12px);
				transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
			}
			.achievement-card:hover {
				border-color: rgba(249, 115, 22, 0.4);
				box-shadow: 0 15px 30px rgba(0,0,0,0.4), inset 0 0 20px rgba(249, 115, 22, 0.05);
				transform: translateY(-5px);
			}

			.achievement-icon {
				font-size: 2.5rem;
				margin-bottom: 1.2rem;
				display: inline-block;
				transition: transform 0.4s ease;
				filter: drop-shadow(0 0 10px rgba(255,255,255,0.1));
			}
			.achievement-card:hover .achievement-icon {
				transform: scale(1.1) rotate(5deg);
				filter: drop-shadow(0 0 15px rgba(249, 115, 22, 0.4));
			}

			.achievement-title {
				font-family: var(--font-display);
				font-size: 1.2rem;
				font-weight: 700;
				margin-bottom: 0.6rem;
				color: #f8fafc;
				letter-spacing: -0.01em;
			}

			.achievement-desc {
				color: #94a3b8;
				font-size: 0.9rem;
				line-height: 1.7;
			}

			.achievement-card.soon {
				border-style: dashed;
				opacity: 0.7;
			}

			/* CONTACT */
			#contact {
				text-align: center;
			}

			.contact-heading {
				font-family: var(--font-display);
				font-size: clamp(1.4rem, 3.5vw, 2.2rem);
				font-weight: 800;
				margin-bottom: 1rem;
				letter-spacing: -0.02em;
			}

			.contact-sub {
				color: #888;
				max-width: 550px;
				margin: 0 auto 3rem;
				line-height: 1.7;
				font-size: 0.95rem;
			}

			.contact-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
				gap: 1.5rem;
				max-width: 800px;
				margin: 0 auto 2.5rem;
			}

			.contact-card {
				padding: 2rem 1.5rem;
				text-align: center;
				text-decoration: none;
				color: inherit;
				background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
				border: 1px solid rgba(255,255,255,0.05);
				border-radius: 20px;
				backdrop-filter: blur(12px);
				transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.8rem;
			}
			.contact-card:hover {
				border-color: rgba(249, 115, 22, 0.5);
				box-shadow: 0 15px 35px rgba(0,0,0,0.5), inset 0 0 20px rgba(249, 115, 22, 0.1);
				transform: translateY(-6px);
			}

			.contact-icon {
				font-size: 2.5rem;
				color: #cbd5e1;
				transition: all 0.4s ease;
				display: flex;
				align-items: center;
				justify-content: center;
				filter: drop-shadow(0 0 5px rgba(255,255,255,0.1));
			}
			.contact-card:hover .contact-icon {
				color: var(--accent);
				transform: scale(1.15) translateY(-2px);
				filter: drop-shadow(0 0 15px var(--accent-glow));
			}
			.contact-label {
				font-family: var(--font-display);
				font-size: 0.95rem;
				font-weight: 700;
			}
			.contact-sub-label {
				color: #666;
				font-size: 0.75rem;
			}

			.contact-location {
				color: #666;
				font-size: 0.85rem;
				line-height: 1.8;
			}

			/* FOOTER */
			footer {
				text-align: center;
				padding: 2.5rem 2rem;
				border-top: 1px solid var(--glass-border);
				color: #555;
				font-size: 0.85rem;
			}
			footer .footer-name {
				color: var(--accent);
			}
			footer .footer-stack {
				margin-top: 0.4rem;
				font-size: 0.75rem;
			}
			footer .footer-copy {
				margin-top: 1rem;
				font-size: 0.75rem;
				color: #444;
			}

			/* SCROLL REVEAL */
			.reveal {
				opacity: 0;
				transform: translateY(45px) translateZ(-50px);
				transform-style: preserve-3d;
				transition:
					opacity 0.85s cubic-bezier(0.16, 1, 0.3, 1),
					transform 0.85s cubic-bezier(0.16, 1, 0.3, 1);
			}
			.reveal.visible {
				opacity: 1;
				transform: translateY(0) translateZ(0);
			}
			#main-content {
				perspective: 1200px;
				transform-style: preserve-3d;
			}



			/* DOM Elements Spatial Proximity Styling */
			.project-card, .skill-badge, .btn-primary, .btn-ghost, .contact-card, .achievement-card {
				--mouse-x: 50%;
				--mouse-y: 50%;
				--proximity: 0;
				position: relative;
			}

			/* Dynamic border glow on cards relative to cursor proximity */
			.project-card, .contact-card, .achievement-card {
				transition: border-color var(--motion-duration-medium) var(--motion-ease-cinematic), box-shadow var(--motion-duration-medium) var(--motion-ease-cinematic), transform var(--motion-duration-medium) var(--motion-ease-cinematic);
			}

			.project-card::after, .contact-card::after, .achievement-card::after {
				content: '';
				position: absolute;
				inset: -1px;
				border-radius: inherit;
				padding: 1px;
				background: radial-gradient(
					circle 120px at var(--mouse-x) var(--mouse-y), 
					rgba(249, 115, 22, calc(var(--proximity) * 0.45)), 
					transparent 70%
				);
				-webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
				mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
				-webkit-mask-composite: xor;
				mask-composite: exclude;
				pointer-events: none;
				z-index: 2;
				opacity: calc(0.3 + 0.7 * var(--proximity));
				transition: opacity var(--motion-duration-fast) var(--motion-ease-standard);
			}

			.project-card::before {
				background: radial-gradient(
					circle 180px at var(--mouse-x) var(--mouse-y), 
					rgba(249, 115, 22, calc(var(--proximity) * 0.08)), 
					transparent 70%
				) !important;
				opacity: 1 !important;
			}

			
		</style>
