---
// Yathin — Portfolio
import PersistentEnvironment from '../components/PersistentEnvironment.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<script is:inline>
			window.addEventListener('error', (event) => {
				alert('GLOBAL ERROR: ' + event.message + ' at ' + event.filename + ':' + event.lineno);
			});
			window.addEventListener('unhandledrejection', (event) => {
				alert('UNHANDLED REJECTION: ' + event.reason);
			});
		</script>
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Yathin | Full Stack Developer & AI Engineer</title>
		<meta
			name="description"
			content="Portfolio of Yathin — Full Stack Developer and AI Engineer exploring machine intelligence and modern web architectures."
		/>
		<meta name="theme-color" content="#f97316" />

		<!-- Google Fonts: Premium AI & Engineering Pack -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>

		<!-- Typed.js -->
		<script
			src="https://cdn.jsdelivr.net/npm/typed.js@2.1.0/dist/typed.umd.js"
		></script>



		<!-- Vanilla Tilt -->
		<script
			src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js"
		></script>



		<style>
			*,
			*::before,
			*::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			:root {
				/* ── PREMIUM TYPOGRAPHY SYSTEM ── */
				--font-display: 'Outfit', sans-serif;
				--font-tech: 'Space Grotesk', monospace, sans-serif;
				--font-sans: 'Plus Jakarta Sans', sans-serif;

				/* ── UNIFIED MOTION SYSTEM TOKENS (Phase 2) ── */
				--motion-duration-fast: 0.2s;      /* Micro-interactions, badge color fades */
				--motion-duration-medium: 0.38s;   /* Standard card hover displacement, panels */
				--motion-duration-slow: 0.6s;      /* Revealer slides, grid layout displacements */
				--motion-duration-cinematic: 1.2s; /* Global site reveal loader overlay fades */

				/* Sleek cinematic easing curves */
				--motion-ease-cinematic: cubic-bezier(0.16, 1, 0.3, 1);    /* Premium smooth quintic ease-out */
				--motion-ease-expressive: cubic-bezier(0.34, 1.56, 0.64, 1); /* Snappy physical spring ease-out */
				--motion-ease-standard: cubic-bezier(0.4, 0, 0.2, 1);       /* Controlled ease-in-out */

				/* Ready-to-use transitions */
				--transition-fast: all var(--motion-duration-fast) var(--motion-ease-standard);
				--transition-medium: all var(--motion-duration-medium) var(--motion-ease-cinematic);
				--transition-slow: all var(--motion-duration-slow) var(--motion-ease-cinematic);
				--transition-cinematic: all var(--motion-duration-cinematic) var(--motion-ease-cinematic);

				--accent: #f97316;
				--accent-glow: rgba(249, 115, 22, 0.35);
				--bg: #0a0a0a;
				--glass: rgba(255, 255, 255, 0.05);
				--glass-border: rgba(255, 255, 255, 0.1);
			}

						/* ── UNIFIED SPATIAL ECOSYSTEM BACKGROUND ── */
			/* Relocated to PersistentEnvironment.astro component */

			/* Hide scrollbars when preloader is loading */
			body.loading {
				overflow: hidden !important;
				height: 100vh;
			}

			section {
				scroll-margin-top: 85px;
			}

			/* ── WORLD-CLASS CINEMATIC PRELOADER OVERLAY ── */
			#cinematic-loader {
				position: fixed;
				inset: 0;
				z-index: 9999;
				background: #020202;
				display: flex;
				align-items: center;
				justify-content: center;
				transition: opacity var(--motion-duration-cinematic) var(--motion-ease-cinematic), visibility var(--motion-duration-cinematic);
				overflow: hidden;
			}

			/* Subtle Screen-Wide Scanning Glow */
			.loader-scanline {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 2px;
				background: linear-gradient(180deg, transparent, var(--accent) 50%, transparent);
				opacity: 0.06;
				pointer-events: none;
				z-index: 5;
				animation: scan-sweep 6s linear infinite;
			}

			@keyframes scan-sweep {
				0% { transform: translateY(-10vh); }
				100% { transform: translateY(110vh); }
			}

			.loader-overlay-gradient {
				position: absolute;
				inset: 0;
				background: radial-gradient(circle at center, rgba(249, 115, 22, 0.035) 0%, transparent 65%);
				pointer-events: none;
				z-index: 1;
			}

			/* Extremely Subtle Matrix Grid Background */
			.loader-grid-overlay {
				position: absolute;
				inset: 0;
				background-image: 
					radial-gradient(rgba(249, 115, 22, 0.08) 1px, transparent 1px);
				background-size: 30px 30px;
				background-position: center;
				mask-image: radial-gradient(circle at center, black 40%, transparent 80%);
				-webkit-mask-image: radial-gradient(circle at center, black 40%, transparent 80%);
				pointer-events: none;
				z-index: 2;
				transition: transform var(--motion-duration-cinematic) var(--motion-ease-cinematic);
			}

			/* Perfect Symmetric Screen Border Frame */
			.loader-viewport-frame {
				position: absolute;
				inset: 2rem;
				border: 1px solid rgba(249, 115, 22, 0.04);
				pointer-events: none;
				z-index: 4;
				transition: opacity var(--motion-duration-cinematic) var(--motion-ease-cinematic), transform var(--motion-duration-cinematic) var(--motion-ease-cinematic);
			}

			/* Corner Static Telemetries inside the frame */
			.loader-viewport-frame::before {
				content: "[SYS.NEXUS_CORE // DIAG_ACTIVE]";
				position: absolute;
				top: 1rem;
				left: 1rem;
				font-family: var(--font-tech);
				font-size: 0.58rem;
				letter-spacing: 0.25em;
				color: rgba(255, 255, 255, 0.35);
			}

			.loader-viewport-frame::after {
				content: "[LINK.ESTABLISHED // SECURE_KEY]";
				position: absolute;
				top: 1rem;
				right: 1rem;
				font-family: var(--font-tech);
				font-size: 0.58rem;
				letter-spacing: 0.25em;
				color: rgba(255, 255, 255, 0.35);
			}

			.loader-frame-bottom-left {
				position: absolute;
				bottom: 1rem;
				left: 1rem;
				font-family: var(--font-tech);
				font-size: 0.58rem;
				letter-spacing: 0.25em;
				color: rgba(255, 255, 255, 0.35);
			}

			.loader-frame-bottom-right {
				position: absolute;
				bottom: 1rem;
				right: 1rem;
				font-family: var(--font-tech);
				font-size: 0.58rem;
				letter-spacing: 0.25em;
				color: var(--accent);
				text-shadow: 0 0 6px var(--accent-glow);
				opacity: 0.85;
			}

			/* Spacious, Geometric Central Console Dashboard */
			.loader-ui {
				position: relative;
				width: 380px;
				height: 380px;
				background: rgba(10, 10, 10, 0.5);
				border: 1px solid rgba(255, 255, 255, 0.04);
				border-radius: 16px;
				padding: 3rem;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: flex-start;
				backdrop-filter: blur(25px);
				-webkit-backdrop-filter: blur(25px);
				z-index: 10;
				box-shadow: 
					0 30px 80px rgba(0, 0, 0, 0.9), 
					inset 0 1px 1px rgba(255, 255, 255, 0.03);
				transition: all var(--motion-duration-cinematic) var(--motion-ease-cinematic);
			}

			/* Elegant corner highlights for the card */
			.loader-ui::before {
				content: "";
				position: absolute;
				top: -1px;
				left: 15px;
				right: 15px;
				height: 1px;
				background: linear-gradient(90deg, transparent, rgba(249, 115, 22, 0.25), transparent);
			}

			/* Concentric High-Tech Ring Visuals */
			.holo-ring-container {
				position: relative;
				width: 170px;
				height: 170px;
				display: flex;
				align-items: center;
				justify-content: center;
				margin-bottom: 2.2rem;
			}

			.holo-ring {
				position: absolute;
				width: 100%;
				height: 100%;
				transform: rotate(-90deg);
			}

			/* Deep glowing technical arcs */
			.ring-glow-back {
				fill: none;
				stroke: var(--accent);
				stroke-width: 1;
				opacity: 0.15;
				transition: opacity 0.5s ease;
			}

			.ring-outer {
				fill: none;
				stroke: rgba(255, 255, 255, 0.04);
				stroke-width: 2;
				stroke-dasharray: 4 8;
			}

			.ring-progress {
				fill: none;
				stroke: var(--accent);
				stroke-width: 2;
				stroke-linecap: round;
				stroke-dasharray: 502.65; /* Circumference of r=80 circle */
				stroke-dashoffset: 502.65;
				filter: drop-shadow(0 0 6px var(--accent-glow));
				transition: stroke-dashoffset 0.08s ease-out;
			}

			.ring-tech-inner {
				fill: none;
				stroke: rgba(249, 115, 22, 0.2);
				stroke-width: 1;
				stroke-dasharray: 2 12;
				animation: tech-ring-spin 18s linear infinite;
				transform-origin: center;
			}

			@keyframes tech-ring-spin {
				to { transform: rotate(360deg); }
			}

			.ring-core {
				fill: rgba(249, 115, 22, 0.05);
				stroke: rgba(249, 115, 22, 0.2);
				stroke-width: 1;
			}

			.ring-orbit-1 {
				fill: none;
				stroke: rgba(255, 255, 255, 0.03);
				stroke-width: 1;
				stroke-dasharray: 100 20;
				animation: orbit-rotate-cw 12s linear infinite;
				transform-origin: center;
			}

			.ring-orbit-2 {
				fill: none;
				stroke: rgba(249, 115, 22, 0.08);
				stroke-width: 1;
				stroke-dasharray: 40 40;
				animation: orbit-rotate-ccw 8s linear infinite;
				transform-origin: center;
			}

			@keyframes orbit-rotate-cw {
				to { transform: rotate(360deg); }
			}

			@keyframes orbit-rotate-ccw {
				to { transform: rotate(-360deg); }
			}

			/* large, clean, high-tech percentage */
			.holo-percentage {
				font-family: var(--font-tech);
				font-size: 1.85rem;
				font-weight: 700;
				color: #ffffff;
				letter-spacing: -0.02em;
				text-shadow: 0 0 10px rgba(255, 255, 255, 0.15);
				z-index: 2;
				display: flex;
				align-items: baseline;
			}

			.holo-percentage::after {
				content: "%";
				font-size: 0.95rem;
				color: var(--accent);
				margin-left: 0.1rem;
				opacity: 0.8;
			}

			/* Spacious central status panel */
			.status-panel {
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
				margin-top: auto;
			}

			.status-header {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				margin-bottom: 0.4rem;
			}

			.status-indicator-dot {
				width: 4px;
				height: 4px;
				border-radius: 50%;
				background: var(--accent);
				box-shadow: 0 0 6px var(--accent-glow);
				animation: dot-pulse-fast 1s infinite alternate;
			}

			@keyframes dot-pulse-fast {
				0% { opacity: 0.3; }
				100% { opacity: 1; filter: drop-shadow(0 0 4px var(--accent-glow)); }
			}

			.status-title {
				font-family: var(--font-tech);
				font-size: 0.68rem;
				font-weight: 700;
				letter-spacing: 0.25em;
				color: rgba(255, 255, 255, 0.4);
				text-transform: uppercase;
			}

			/* Clean, single-line typing ticker */
			.status-ticker {
				font-family: var(--font-tech);
				font-size: 0.72rem;
				font-weight: 600;
				color: var(--accent);
				letter-spacing: 0.15em;
				text-transform: uppercase;
				height: 1rem;
				display: flex;
				align-items: center;
				justify-content: center;
				text-shadow: 0 0 6px var(--accent-glow);
				margin-bottom: 1.4rem;
				opacity: 0.95;
			}

			/* Sleek Edge-to-Edge Oscilloscope Wave at bottom */
			.loader-wave-container {
				width: 100%;
				height: 20px;
				border-top: 1px solid rgba(255, 255, 255, 0.03);
				padding-top: 0.8rem;
				margin-top: 0.5rem;
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
			}

			.loader-wave-svg {
				width: 100%;
				height: 100%;
			}

			/* Extreme Transition Wakestate Animations */
			.loader-waking .ring-glow-back {
				opacity: 0.8;
			}
			
			.loader-waking .ring-core {
				fill: #ffffff;
				opacity: 0.85;
				filter: drop-shadow(0 0 15px #ffffff), drop-shadow(0 0 25px var(--accent));
			}

			.loader-waking .holo-percentage {
				color: #ffffff !important;
				text-shadow: 0 0 15px #ffffff, 0 0 25px var(--accent);
			}

			.loader-waking {
				box-shadow: 
					0 30px 80px rgba(0, 0, 0, 0.95), 
					0 0 60px rgba(249, 115, 22, 0.15), 
					inset 0 1px 1px rgba(255, 255, 255, 0.15);
				border-color: rgba(249, 115, 22, 0.4);
			}

			/* Responsive Scaling */
			@media (max-width: 768px) {
				.loader-viewport-frame {
					display: none !important;
				}
				.loader-scanline {
					display: none !important;
				}
				.loader-ui {
					width: 290px;
					height: 310px;
					padding: 2.2rem 1.8rem;
				}
				.holo-ring-container {
					width: 120px;
					height: 120px;
					margin-bottom: 1.4rem;
				}
				.holo-percentage {
					font-size: 1.4rem;
				}
				.status-ticker {
					font-size: 0.65rem;
					margin-bottom: 0.8rem;
				}
			}


			/* ── Lenis Smooth Scroll CSS Overrides ── */
			html.lenis,
			html.lenis body {
				height: auto;
			}

			.lenis.lenis-smooth {
				scroll-behavior: auto !important;
			}

			.lenis.lenis-smooth [data-lenis-prevent] {
				overscroll-behavior: contain;
			}

			.lenis.lenis-stopped {
				overflow: hidden;
			}

			.lenis.lenis-smooth iframe {
				pointer-events: none;
			}

			html {
				scroll-behavior: auto !important;
			}

			body {
				background: transparent;
				color: #fff;
				font-family: var(--font-sans);
				overflow-x: hidden;
			}

			/* Scrollbar */
			::-webkit-scrollbar {
				width: 6px;
			}
			::-webkit-scrollbar-track {
				background: #111;
			}
			::-webkit-scrollbar-thumb {
				background: var(--accent);
				border-radius: 3px;
			}
			::selection {
				background: var(--accent);
				color: #000;
			}



			/* Glass utility */
			.glass {
				background: var(--glass);
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				border: 1px solid var(--glass-border);
				border-radius: 16px;
			}

			/* NAVBAR */
			nav {
				position: sticky;
				top: 0;
				z-index: 100;
				background: linear-gradient(180deg, rgba(5,5,5,0.9) 0%, rgba(5,5,5,0.4) 100%);
				backdrop-filter: blur(20px);
				border-bottom: 1px solid rgba(255, 255, 255, 0.05);
				padding: 1rem 2rem;
				display: flex;
				align-items: center;
				justify-content: space-between;
				animation: slideDown 0.6s ease-out;
				box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
			}

			@keyframes slideDown {
				from {
					transform: translateY(-100%);
					opacity: 0;
				}
				to {
					transform: translateY(0);
					opacity: 1;
				}
			}

			.nav-logo {
				font-family: var(--font-display);
				font-weight: 900;
				font-size: 1.3rem;
				color: var(--accent);
				text-decoration: none;
				text-shadow: 0 0 10px var(--accent-glow);
			}

			.nav-links {
				display: flex;
				gap: 1rem;
				list-style: none;
			}
			.nav-links a {
				color: #94a3b8;
				text-decoration: none;
				font-size: 0.9rem;
				font-weight: 600;
				letter-spacing: 0.05em;
				transition: all 0.3s ease;
				position: relative;
				padding: 0.5rem 1rem;
				border-radius: 8px;
			}
			.nav-links a:hover,
			.nav-links a.active {
				color: #fff;
				background: rgba(255, 255, 255, 0.05);
				text-shadow: 0 0 10px rgba(255, 255, 255, 0.5);
			}
			.nav-links a::after {
				content: '';
				position: absolute;
				bottom: 0;
				left: 50%;
				width: 0;
				height: 2px;
				background: var(--accent);
				box-shadow: 0 0 8px var(--accent-glow);
				transition: width 0.3s ease;
				transform: translateX(-50%);
			}
			.nav-links a:hover::after,
			.nav-links a.active::after {
				width: 60%;
			}
			.nav-links a.nav-terminal-btn::after {
				display: none;
			}
			.nav-links a.nav-terminal-btn:hover {
				background: rgba(249, 115, 22, 0.25);
				color: #fff;
				box-shadow: 0 0 15px var(--accent-glow);
				transform: translateY(-2px);
			}

			.hamburger {
				display: none;
				flex-direction: column;
				gap: 5px;
				cursor: pointer;
				background: none;
				border: none;
			}
			.hamburger span {
				display: block;
				width: 24px;
				height: 2px;
				background: #fff;
				border-radius: 2px;
				transition: 0.3s;
			}

			.mobile-menu {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(0, 0, 0, 0.95);
				backdrop-filter: blur(20px);
				z-index: 200;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				gap: 2.5rem;
			}
			.mobile-menu.open {
				display: flex;
			}
			.mobile-menu a {
				color: #fff;
				text-decoration: none;
				font-family: var(--font-display);
				font-size: 1.5rem;
				font-weight: 700;
				transition: color 0.2s;
			}
			.mobile-menu a:hover {
				color: var(--accent);
			}
			.mobile-close {
				position: absolute;
				top: 1.5rem;
				right: 2rem;
				background: none;
				border: none;
				color: #fff;
				font-size: 2rem;
				cursor: pointer;
			}

			@media (max-width: 768px) {
				.nav-links {
					display: none;
				}
				.hamburger {
					display: flex;
				}
			}

			/* SECTIONS */
			section {
				padding: 6rem 2rem;
				max-width: 1100px;
				margin: 0 auto;
			}

			.section-title {
				font-family: var(--font-display);
				font-size: clamp(1.8rem, 4vw, 2.8rem);
				font-weight: 800;
				margin-bottom: 0.5rem;
				letter-spacing: -0.02em;
			}
			.section-title span {
				color: var(--accent);
			}

			.title-bar {
				width: 60px;
				height: 3px;
				background: var(--accent);
				border-radius: 2px;
				margin-bottom: 3rem;
				box-shadow: 0 0 10px var(--accent-glow);
			}

			/* HERO */
			#home {
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				text-align: center;
				flex-direction: column;
				padding: 2rem;
				max-width: 100%;
				position: relative;
			}

			/* Floating HUD Decorators */
			.hero-hud-decorator {
				position: absolute;
				top: 2.5rem;
				display: flex;
				flex-direction: column;
				font-family: var(--font-tech);
				font-size: 0.65rem;
				letter-spacing: 0.2em;
				color: #64748b;
				pointer-events: none;
				opacity: 0;
			}
			.hero-hud-decorator.top-left {
				left: 2.5rem;
				text-align: left;
				border-left: 1px solid rgba(249, 115, 22, 0.3);
				padding-left: 0.8rem;
				gap: 0.3rem;
			}
			.hero-hud-decorator.top-right {
				right: 2.5rem;
				text-align: right;
				border-right: 1px solid rgba(249, 115, 22, 0.3);
				padding-right: 0.8rem;
				gap: 0.3rem;
			}
			.hud-pulse-status {
				display: inline-flex;
				align-items: center;
				justify-content: flex-end;
				gap: 0.4rem;
				color: var(--accent);
			}
			.hud-status-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--accent);
				box-shadow: 0 0 10px var(--accent);
				animation: dot-pulse-fast 1.5s infinite alternate;
			}

			@media (max-width: 1024px) {
				.hero-hud-decorator { display: none; }
			}

			/* Core Avatar Display */
			.hero-avatar-container {
				position: relative;
				width: 200px;
				height: 200px;
				margin: 0 auto 2.5rem;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.hero-avatar-wrap {
				position: relative;
				width: 150px;
				height: 150px;
				opacity: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				cursor: pointer;
			}
			.hero-avatar-glow-bg {
				position: absolute;
				inset: -20px;
				background: radial-gradient(circle at center, rgba(249, 115, 22, 0.25) 0%, transparent 70%);
				border-radius: 50%;
				filter: blur(15px);
				transition: all 0.5s ease;
			}
			.hero-avatar-wrap:hover .hero-avatar-glow-bg {
				background: radial-gradient(circle at center, rgba(249, 115, 22, 0.45) 0%, transparent 75%);
				filter: blur(20px);
				transform: scale(1.1);
			}
			.hero-avatar-ring {
				position: absolute;
				inset: -8px;
				border-radius: 50%;
				background: conic-gradient(from 0deg, transparent 0%, rgba(249, 115, 22, 0.8) 25%, transparent 50%);
				animation: spin-slow 4s linear infinite;
				z-index: 0;
				transition: inset 0.4s ease;
			}
			.hero-avatar-ring::before {
				content: '';
				position: absolute;
				inset: 2px;
				border-radius: 50%;
				background: #050505;
			}
			.hero-avatar-ring-2 {
				position: absolute;
				inset: -18px;
				border-radius: 50%;
				border: 1px dashed rgba(249, 115, 22, 0.35);
				animation: spin-slow 15s linear infinite reverse;
				z-index: 0;
				transition: inset 0.4s ease, border-color 0.4s ease;
			}
			.hero-avatar-ring-3 {
				position: absolute;
				inset: -28px;
				border-radius: 50%;
				border: 1px solid rgba(255, 255, 255, 0.05);
				animation: spin-slow 25s linear infinite;
				z-index: 0;
				transition: inset 0.4s ease;
			}
			.hero-avatar-wrap:hover .hero-avatar-ring { inset: -12px; }
			.hero-avatar-wrap:hover .hero-avatar-ring-2 { inset: -24px; border-color: rgba(249, 115, 22, 0.6); }
			.hero-avatar-wrap:hover .hero-avatar-ring-3 { inset: -36px; border-color: rgba(255, 255, 255, 0.15); }

			.hero-avatar {
				position: relative;
				width: 100%;
				height: 100%;
				border-radius: 50%;
				overflow: hidden;
				z-index: 2;
				box-shadow: 0 0 30px rgba(249, 115, 22, 0.3), inset 0 0 20px rgba(0,0,0,0.5);
				border: 2px solid rgba(255, 255, 255, 0.15);
				transition: border-color 0.4s ease, transform 0.4s ease;
			}
			.hero-avatar-wrap:hover .hero-avatar {
				border-color: var(--accent);
				transform: scale(1.03);
			}

			/* Orbital Trackers */
			.orbit-tracker {
				position: absolute;
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: var(--accent);
				box-shadow: 0 0 10px var(--accent);
				z-index: 3;
			}
			.tracker-1 {
				top: 10px;
				left: 50%;
				transform-origin: 0 90px;
				animation: spin-slow 8s linear infinite;
			}
			.tracker-2 {
				bottom: 10px;
				right: 50%;
				transform-origin: 0 -90px;
				animation: spin-slow 12s linear infinite reverse;
			}

			@keyframes spin-slow {
				100% { transform: rotate(360deg); }
			}

			/* Status Badge */
			.hero-greeting-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.6rem;
				padding: 0.45rem 1.4rem;
				background: rgba(249, 115, 22, 0.08);
				border: 1px solid rgba(249, 115, 22, 0.3);
				border-radius: 30px;
				color: var(--accent);
				font-family: var(--font-tech);
				font-size: 0.8rem;
				font-weight: 700;
				letter-spacing: 0.25em;
				text-transform: uppercase;
				margin-bottom: 1.5rem;
				opacity: 0;
				backdrop-filter: blur(12px);
				box-shadow: 0 0 20px rgba(249, 115, 22, 0.15);
				position: relative;
				overflow: hidden;
			}
			.badge-scanner {
				position: absolute;
				top: 0;
				bottom: 0;
				width: 20px;
				background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
				animation: badge-scan 3s ease-in-out infinite;
				transform: skewX(-20deg);
			}
			@keyframes badge-scan {
				0% { left: -30%; }
				100% { left: 130%; }
			}
			.pulse-dot-inner {
				width: 6px;
				height: 6px;
				background: var(--accent);
				border-radius: 50%;
				box-shadow: 0 0 10px var(--accent);
				animation: dot-pulse-fast 1.5s infinite alternate;
			}
			@keyframes dot-pulse-fast {
				0% { opacity: 0.4; box-shadow: 0 0 4px var(--accent); }
				100% { opacity: 1; box-shadow: 0 0 12px var(--accent), 0 0 20px rgba(249, 115, 22, 0.5); }
			}

			/* Hero Name */
			.hero-name {
				font-family: var(--font-display);
				font-size: clamp(3.2rem, 8.5vw, 7rem);
				font-weight: 900;
				line-height: 1.1;
				margin-bottom: 1.5rem;
				opacity: 0;
				letter-spacing: -0.03em;
				position: relative;
			}
			.hero-name .gradient {
				background: linear-gradient(135deg, #ffffff 0%, #f97316 50%, #fbbf24 100%);
				background-size: 200% auto;
				animation: textShine 5s linear infinite;
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				filter: drop-shadow(0 0 35px rgba(249, 115, 22, 0.3));
			}
			@keyframes textShine {
				to { background-position: 200% center; }
			}

			/* Typewriter Box */
			.hero-typewriter-box {
				display: inline-flex;
				align-items: center;
				gap: 0.6rem;
				background: rgba(0, 0, 0, 0.4);
				border: 1px solid rgba(255, 255, 255, 0.1);
				padding: 0.6rem 1.5rem;
				border-radius: 12px;
				font-family: var(--font-tech);
				font-size: clamp(1.1rem, 3vw, 1.5rem);
				color: #f1f5f9;
				margin-bottom: 1.8rem;
				min-height: 3rem;
				opacity: 0;
				font-weight: 500;
				box-shadow: 0 10px 30px rgba(0,0,0,0.5), inset 0 1px 1px rgba(255,255,255,0.05);
				backdrop-filter: blur(12px);
				letter-spacing: 0.02em;
			}
			.typewriter-prefix {
				color: var(--accent);
				font-weight: 700;
			}

			/* Hero Subtitle */
			.hero-sub {
				color: #94a3b8;
				font-size: 1.15rem;
				line-height: 1.8;
				max-width: 650px;
				margin: 0 auto 3.5rem;
				opacity: 0;
				font-weight: 400;
			}

			/* Hero Buttons */
			.hero-btns {
				display: flex;
				gap: 1.2rem;
				flex-wrap: wrap;
				justify-content: center;
				align-items: center;
				margin-bottom: 3rem;
				opacity: 0;
			}

			.btn-primary {
				padding: 0.9rem 2.5rem;
				border: 1px solid rgba(249, 115, 22, 0.6);
				background: linear-gradient(135deg, rgba(249, 115, 22, 0.3), rgba(249, 115, 22, 0.1));
				color: #fff;
				border-radius: 14px;
				text-decoration: none;
				font-family: var(--font-sans);
				font-weight: 600;
				letter-spacing: 0.05em;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				box-shadow: inset 0 1px 1px rgba(255,255,255,0.2), 0 0 25px rgba(249, 115, 22, 0.2);
				backdrop-filter: blur(12px);
				cursor: pointer;
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 0.6rem;
			}
			.btn-arrow {
				transition: transform 0.3s ease;
			}
			.btn-primary:hover {
				background: linear-gradient(135deg, rgba(249, 115, 22, 0.5), rgba(249, 115, 22, 0.2));
				box-shadow: inset 0 1px 1px rgba(255,255,255,0.3), 0 0 35px rgba(249, 115, 22, 0.4);
				transform: translateY(-3px) scale(1.02);
				border-color: rgba(249, 115, 22, 0.9);
			}
			.btn-primary:hover .btn-arrow {
				transform: translateX(4px);
			}

			.btn-secondary {
				padding: 0.9rem 2.2rem;
				border: 1px solid rgba(255, 255, 255, 0.15);
				background: rgba(255, 255, 255, 0.03);
				color: #e2e8f0;
				border-radius: 14px;
				text-decoration: none;
				font-family: var(--font-sans);
				font-weight: 600;
				letter-spacing: 0.05em;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				backdrop-filter: blur(12px);
				display: flex;
				align-items: center;
				gap: 0.6rem;
				box-shadow: inset 0 1px 1px rgba(255,255,255,0.05);
			}
			.btn-secondary:hover {
				border-color: rgba(249, 115, 22, 0.5);
				background: rgba(249, 115, 22, 0.1);
				color: var(--accent);
				transform: translateY(-3px);
				box-shadow: 0 10px 25px rgba(0,0,0,0.5), inset 0 1px 1px rgba(255,255,255,0.1);
			}

			.social-group {
				display: flex;
				gap: 0.8rem;
				align-items: center;
			}

			.btn-ghost {
				width: 48px;
				height: 48px;
				border: 1px solid rgba(255, 255, 255, 0.12);
				background: rgba(255, 255, 255, 0.03);
				color: #94a3b8;
				border-radius: 50%;
				text-decoration: none;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				backdrop-filter: blur(12px);
				display: flex;
				align-items: center;
				justify-content: center;
				box-shadow: inset 0 1px 1px rgba(255,255,255,0.05);
			}
			.btn-ghost:hover {
				border-color: rgba(249, 115, 22, 0.5);
				background: rgba(249, 115, 22, 0.15);
				color: var(--accent);
				transform: translateY(-4px) scale(1.08);
				box-shadow: 0 10px 25px rgba(249, 115, 22, 0.25), inset 0 1px 1px rgba(255,255,255,0.1);
			}
			.btn-ghost svg {
				width: 1.3rem;
				height: 1.3rem;
				fill: currentColor;
				transition: fill 0.3s ease;
			}

			/* Sleek Scroll Indicator */
			.scroll-indicator-wrap {
				position: absolute;
				bottom: 2rem;
				left: 50%;
				transform: translateX(-50%);
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.5rem;
				opacity: 0;
				pointer-events: none;
			}
			.mouse-frame {
				width: 22px;
				height: 36px;
				border: 2px solid rgba(255, 255, 255, 0.2);
				border-radius: 12px;
				display: flex;
				justify-content: center;
				padding-top: 6px;
				box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
			}
			.mouse-wheel {
				width: 4px;
				height: 8px;
				background: var(--accent);
				border-radius: 2px;
				animation: scroll-wheel 2s cubic-bezier(0.15, 0.41, 0.69, 0.94) infinite;
				box-shadow: 0 0 8px var(--accent);
			}
			.scroll-text {
				font-family: var(--font-tech);
				font-size: 0.65rem;
				letter-spacing: 0.25em;
				color: #64748b;
				text-transform: uppercase;
			}

			@keyframes scroll-wheel {
				0% { transform: translateY(0); opacity: 1; }
				50% { transform: translateY(10px); opacity: 0; }
				51% { transform: translateY(-5px); opacity: 0; }
				100% { transform: translateY(0); opacity: 1; }
			}

			/* fadeUp keyframes removed in favor of GSAP timelines */

			/* ABOUT */
			.about-grid {
				display: grid;
				grid-template-columns: 1fr 2fr;
				gap: 4rem;
				align-items: start;
			}

			.about-avatar-wrap {
				text-align: center;
				display: flex;
				flex-direction: column;
				align-items: center;
			}

			.about-avatar-container {
				position: relative;
				width: 200px;
				height: 200px;
				margin: 0 auto 2.5rem;
				display: flex;
				align-items: center;
				justify-content: center;
			}
			.about-avatar-inner {
				position: relative;
				width: 150px;
				height: 150px;
				display: flex;
				align-items: center;
				justify-content: center;
				cursor: pointer;
			}
			.about-avatar-glow {
				position: absolute;
				inset: -20px;
				background: radial-gradient(circle at center, rgba(249, 115, 22, 0.25) 0%, transparent 70%);
				border-radius: 50%;
				filter: blur(15px);
				transition: all 0.5s ease;
			}
			.about-avatar-inner:hover .about-avatar-glow {
				background: radial-gradient(circle at center, rgba(249, 115, 22, 0.45) 0%, transparent 75%);
				filter: blur(20px);
				transform: scale(1.1);
			}
			.about-avatar-ring-1 {
				position: absolute;
				inset: -8px;
				border-radius: 50%;
				background: conic-gradient(from 0deg, transparent 0%, rgba(249, 115, 22, 0.8) 25%, transparent 50%);
				animation: spin-slow 5s linear infinite;
				z-index: 0;
				transition: inset 0.4s ease;
			}
			.about-avatar-ring-1::before {
				content: '';
				position: absolute;
				inset: 2px;
				border-radius: 50%;
				background: #050505;
			}
			.about-avatar-ring-2 {
				position: absolute;
				inset: -18px;
				border-radius: 50%;
				border: 1px dashed rgba(249, 115, 22, 0.35);
				animation: spin-slow 12s linear infinite reverse;
				z-index: 0;
				transition: inset 0.4s ease, border-color 0.4s ease;
			}
			.about-avatar-ring-3 {
				position: absolute;
				inset: -28px;
				border-radius: 50%;
				border: 1px solid rgba(255, 255, 255, 0.05);
				animation: spin-slow 20s linear infinite;
				z-index: 0;
				transition: inset 0.4s ease;
			}
			.about-avatar-inner:hover .about-avatar-ring-1 { inset: -12px; }
			.about-avatar-inner:hover .about-avatar-ring-2 { inset: -24px; border-color: rgba(249, 115, 22, 0.6); }
			.about-avatar-inner:hover .about-avatar-ring-3 { inset: -36px; border-color: rgba(255, 255, 255, 0.15); }

			.about-avatar {
				position: relative;
				width: 100%;
				height: 100%;
				border-radius: 50%;
				overflow: hidden;
				z-index: 2;
				box-shadow: 0 0 30px rgba(249, 115, 22, 0.3), inset 0 0 20px rgba(0,0,0,0.5);
				border: 2px solid rgba(255, 255, 255, 0.15);
				transition: border-color 0.4s ease, transform 0.4s ease;
			}
			.about-avatar-inner:hover .about-avatar {
				border-color: var(--accent);
				transform: scale(1.03);
			}

			.about-name {
				font-family: var(--font-display);
				font-weight: 700;
				font-size: 1.5rem;
				margin-bottom: 0.4rem;
				letter-spacing: -0.01em;
				text-shadow: 0 0 10px rgba(255, 255, 255, 0.2);
			}

			.about-role {
				color: var(--accent);
				font-size: 0.95rem;
				margin-bottom: 0.8rem;
				font-weight: 600;
				font-family: var(--font-tech);
				letter-spacing: 0.05em;
			}
			.about-loc {
				color: #888;
				font-size: 0.85rem;
				display: flex;
				align-items: center;
				gap: 0.4rem;
				background: rgba(255, 255, 255, 0.03);
				padding: 0.4rem 0.9rem;
				border-radius: 20px;
				border: 1px solid rgba(255, 255, 255, 0.08);
			}

			/* About Content Box */
			.about-content-wrapper {
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}

			.about-status-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.6rem;
				padding: 0.45rem 1.4rem;
				background: rgba(249, 115, 22, 0.08);
				border: 1px solid rgba(249, 115, 22, 0.3);
				border-radius: 30px;
				color: var(--accent);
				font-family: var(--font-tech);
				font-size: 0.8rem;
				font-weight: 700;
				letter-spacing: 0.25em;
				text-transform: uppercase;
				backdrop-filter: blur(12px);
				box-shadow: 0 0 20px rgba(249, 115, 22, 0.15);
				position: relative;
				overflow: hidden;
				align-self: flex-start;
			}

			.about-bio-card {
				position: relative;
				background: linear-gradient(145deg, rgba(20,20,20,0.6), rgba(10,10,10,0.8));
				backdrop-filter: blur(20px);
				border: 1px solid rgba(255, 255, 255, 0.08);
				border-radius: 20px;
				padding: 2.5rem;
				box-shadow: 0 20px 40px rgba(0,0,0,0.6), inset 0 1px 1px rgba(255,255,255,0.05);
				transition: border-color 0.4s ease, box-shadow 0.4s ease;
			}
			.about-bio-card:hover {
				border-color: rgba(249, 115, 22, 0.4);
				box-shadow: 0 25px 50px rgba(0,0,0,0.8), 0 0 30px rgba(249, 115, 22, 0.1), inset 0 1px 1px rgba(255,255,255,0.1);
			}
			.about-bio-accent {
				position: absolute;
				top: 0;
				left: 2.5rem;
				width: 60px;
				height: 3px;
				background: var(--accent);
				box-shadow: 0 0 15px var(--accent-glow);
				border-radius: 0 0 3px 3px;
			}

			.about-bio {
				line-height: 2;
				color: #e2e8f0;
				font-size: 1.05rem;
				letter-spacing: 0.01em;
			}

			.stats-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.2rem;
			}

			.stat-card {
				position: relative;
				padding: 1.8rem 1.2rem;
				text-align: center;
				border-radius: 16px;
				background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
				border: 1px solid rgba(255,255,255,0.05);
				backdrop-filter: blur(10px);
				transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
				overflow: hidden;
			}
			.stat-card:hover {
				transform: translateY(-5px);
				border-color: rgba(249, 115, 22, 0.5);
				box-shadow: 0 15px 35px rgba(0,0,0,0.5), inset 0 0 20px rgba(249, 115, 22, 0.1);
			}

			.stat-number {
				font-family: var(--font-tech);
				font-size: 2.5rem;
				font-weight: 800;
				color: var(--accent);
				display: block;
				letter-spacing: -0.02em;
				margin-bottom: 0.4rem;
				text-shadow: 0 0 15px var(--accent-glow);
			}

			.stat-label {
				font-size: 0.8rem;
				color: #94a3b8;
				font-weight: 600;
				letter-spacing: 0.05em;
				text-transform: uppercase;
				font-family: var(--font-sans);
			}

			@media (max-width: 768px) {
				.about-grid {
					grid-template-columns: 1fr;
					gap: 3rem;
				}
				.stats-grid {
					grid-template-columns: repeat(3, 1fr);
					gap: 0.8rem;
				}
				.stat-card {
					padding: 1.2rem 0.8rem;
				}
				.stat-number {
					font-size: 1.8rem;
				}
				.stat-label {
					font-size: 0.7rem;
				}
			}

			/* PROJECTS - INTERACTIVE SYSTEMS GALLERY */
			#projects {
				position: relative;
				overflow: visible;
			}

			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(330px, 1fr));
				gap: 2.5rem;
			}

			/* Project Card as a Dynamic System Module */
			.project-card {
				position: relative;
				padding: 2.2rem;
				background: linear-gradient(145deg, rgba(20,20,20,0.8), rgba(5,5,5,0.9));
				backdrop-filter: blur(20px);
				border: 1px solid rgba(255,255,255,0.05);
				border-radius: 20px;
				transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
				overflow: hidden;
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				transform-style: preserve-3d;
				perspective: 1000px;
				cursor: default;
			}

			.project-card::before {
				content: '';
				position: absolute;
				inset: 0;
				background: linear-gradient(135deg, rgba(249, 115, 22, 0.1) 0%, transparent 100%);
				opacity: 0;
				transition: opacity 0.5s ease;
				z-index: 0;
				pointer-events: none;
			}

			.project-card:hover {
				border-color: rgba(249, 115, 22, 0.5);
				box-shadow: 
					0 25px 50px rgba(0, 0, 0, 0.8),
					0 0 40px rgba(249, 115, 22, 0.15),
					inset 0 0 0 1px rgba(249, 115, 22, 0.1);
				transform: translateY(-8px) scale(1.02);
			}

			.project-card:hover::before {
				opacity: 1;
			}

			/* Surrounding Dimming Effects */
			.projects-grid:has(.project-card:hover) .project-card:not(:hover) {
				opacity: 0.28;
				filter: blur(2.5px) grayscale(0.2);
				transform: scale(0.96) translateY(2px);
				transition: var(--transition-slow);
			}

			/* System Status Header */
			.system-status-bar {
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-family: var(--font-tech);
				font-size: 0.72rem;
				letter-spacing: 0.12em;
				color: #666;
				border-bottom: 1px solid rgba(255, 255, 255, 0.05);
				padding-bottom: 0.8rem;
				z-index: 1;
			}

			.status-tag {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				font-weight: 700;
			}

			.status-dot {
				width: 6px;
				height: 6px;
				border-radius: 50%;
				background: #10b981;
				box-shadow: 0 0 8px #10b981;
				animation: statusPulse 1.8s infinite alternate;
			}

			.project-card:hover .status-dot {
				background: var(--accent);
				box-shadow: 0 0 10px var(--accent);
				animation: statusPulseFast 0.8s infinite alternate;
			}

			@keyframes statusPulse {
				0% { opacity: 0.4; }
				100% { opacity: 1; }
			}
			@keyframes statusPulseFast {
				0% { opacity: 0.5; transform: scale(0.9); }
				100% { opacity: 1; transform: scale(1.2); }
			}

			/* Card Details Layout */
			.project-info-wrap {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
				z-index: 1;
			}

			.project-top {
				display: flex;
				align-items: center;
				gap: 0.8rem;
			}

			.project-icon {
				font-size: 1.8rem;
				filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.1));
				transition: transform var(--motion-duration-medium) var(--motion-ease-cinematic);
			}
			.project-card:hover .project-icon {
				transform: scale(1.15) rotate(5deg);
			}

			.project-name {
				font-family: var(--font-display);
				font-size: 1.5rem;
				font-weight: 800;
				color: #fff;
				letter-spacing: -0.01em;
				text-shadow: 0 2px 10px rgba(0,0,0,0.5);
			}

			.project-badge {
				background: rgba(249, 115, 22, 0.15);
				border: 1px solid rgba(249, 115, 22, 0.4);
				color: var(--accent);
				font-size: 0.68rem;
				padding: 0.3rem 0.8rem;
				border-radius: 6px;
				font-weight: 700;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				font-family: var(--font-tech);
				margin-left: auto;
				box-shadow: 0 0 10px rgba(249, 115, 22, 0.1);
			}

			.project-fullname {
				color: #cbd5e1;
				font-size: 0.85rem;
				font-weight: 500;
			}

			.project-desc {
				color: #94a3b8;
				font-size: 0.95rem;
				line-height: 1.7;
				z-index: 1;
			}

			/* Visual System Blueprint Preview */
			.system-blueprint {
				position: relative;
				height: 110px;
				width: 100%;
				background: rgba(0, 0, 0, 0.4);
				border: 1px solid rgba(255, 255, 255, 0.05);
				border-radius: 12px;
				overflow: hidden;
				display: flex;
				align-items: center;
				justify-content: center;
				z-index: 1;
				transition: border-color 0.4s ease;
			}

			.project-card:hover .system-blueprint {
				border-color: rgba(249, 115, 22, 0.25);
				box-shadow: inset 0 0 20px rgba(249, 115, 22, 0.05);
			}

			.grid-bg {
				position: absolute;
				inset: 0;
				background-image: 
					linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
				background-size: 15px 15px;
				pointer-events: none;
			}

			.blueprint-svg {
				width: 90%;
				height: 80%;
				overflow: visible;
			}

			.connection-path {
				fill: none;
				stroke: rgba(255, 255, 255, 0.08);
				stroke-width: 1.5;
				transition: stroke 0.4s ease;
			}

			.project-card:hover .connection-path {
				stroke: rgba(249, 115, 22, 0.3);
			}

			.signal-pulse {
				fill: none;
				stroke: var(--accent);
				stroke-width: 2.5;
				stroke-linecap: round;
				stroke-dasharray: 8 35;
				stroke-dashoffset: 0;
				animation: signalFlow 2s infinite linear;
				opacity: 0.4;
				transition: opacity 0.4s ease;
			}

			.project-card:hover .signal-pulse {
				opacity: 1;
				animation-duration: 1.2s;
			}

			@keyframes signalFlow {
				to {
					stroke-dashoffset: -43;
				}
			}

			.blueprint-node {
				transition: all 0.4s ease;
			}

			.node-dot {
				fill: #1a1a1a;
				stroke: rgba(255, 255, 255, 0.3);
				stroke-width: 1.5;
				transition: all 0.4s ease;
			}

			.node-text {
				font-family: var(--font-tech);
				font-size: 8px;
				fill: #666;
				font-weight: 600;
				letter-spacing: 0.05em;
				transition: fill 0.4s ease;
			}

			.project-card:hover .node-dot {
				stroke: var(--accent);
				fill: rgba(249, 115, 22, 0.2);
				filter: drop-shadow(0 0 6px var(--accent-glow));
			}

			.project-card:hover .node-text {
				fill: #e2e8f0;
			}

			/* Tech Stack Badges */
			.tech-stack {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
				z-index: 1;
			}

			.tech-badge {
				background: rgba(255, 255, 255, 0.03);
				border: 1px solid rgba(255, 255, 255, 0.08);
				backdrop-filter: blur(5px);
				color: #cbd5e1;
				font-size: 0.75rem;
				padding: 0.35rem 0.9rem;
				border-radius: 8px;
				transition: all 0.3s ease;
				font-weight: 600;
			}

			.tech-badge:hover {
				border-color: rgba(249, 115, 22, 0.4);
				background: rgba(249, 115, 22, 0.1);
				color: #fff;
				transform: translateY(-2px);
				box-shadow: 0 4px 10px rgba(0,0,0,0.3);
			}

			/* Controls / Action Buttons */
			.card-actions {
				display: flex;
				gap: 0.8rem;
				margin-top: auto;
				z-index: 1;
			}

			.btn-action {
				flex: 1;
				padding: 0.6rem 1rem;
				border: 1px solid var(--glass-border);
				border-radius: 8px;
				color: #bbb;
				text-decoration: none;
				font-family: var(--font-tech);
				font-size: 0.75rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-align: center;
				transition: var(--transition-medium);
				cursor: pointer;
				background: transparent;
			}

			.btn-action:hover {
				border-color: var(--accent);
				color: var(--accent);
				box-shadow: 0 0 15px var(--accent-glow);
				transform: translateY(-2px);
			}

			/* SKILLS */
			.skills-categories {
				display: flex;
				flex-direction: column;
				gap: 2.5rem;
			}

			.skill-category-card {
				position: relative;
				background: linear-gradient(145deg, rgba(20,20,20,0.6), rgba(10,10,10,0.8));
				backdrop-filter: blur(20px);
				border: 1px solid rgba(255, 255, 255, 0.08);
				border-radius: 20px;
				padding: 2.2rem;
				box-shadow: 0 20px 40px rgba(0,0,0,0.6), inset 0 1px 1px rgba(255,255,255,0.05);
				transition: border-color 0.4s ease, box-shadow 0.4s ease;
				overflow: hidden;
			}
			.skill-category-card:hover {
				border-color: rgba(249, 115, 22, 0.35);
				box-shadow: 0 25px 50px rgba(0,0,0,0.8), 0 0 30px rgba(249, 115, 22, 0.08), inset 0 1px 1px rgba(255,255,255,0.1);
			}

			.skill-cat-label {
				font-family: var(--font-tech);
				font-size: 0.85rem;
				font-weight: 700;
				color: var(--accent);
				text-transform: uppercase;
				letter-spacing: 0.2em;
				margin-bottom: 1.5rem;
				display: flex;
				align-items: center;
				gap: 1rem;
				position: relative;
				z-index: 1;
			}
			.skill-cat-label::after {
				content: "";
				flex: 1;
				height: 1px;
				background: rgba(255, 255, 255, 0.08);
			}

			.skill-badges {
				display: flex;
				flex-wrap: wrap;
				gap: 0.8rem;
				position: relative;
				z-index: 1;
			}

			.skill-badge {
				background: rgba(255, 255, 255, 0.03);
				border: 1px solid rgba(255, 255, 255, 0.08);
				padding: 0.6rem 1.2rem;
				border-radius: 12px;
				font-family: var(--font-tech);
				font-size: 0.85rem;
				font-weight: 600;
				color: #cbd5e1;
				display: inline-flex;
				align-items: center;
				gap: 0.6rem;
				transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				backdrop-filter: blur(10px);
				box-shadow: inset 0 1px 1px rgba(255,255,255,0.05);
				text-decoration: none;
				cursor: default;
			}
			.skill-badge:hover {
				transform: translateY(-3px) scale(1.05);
				border-color: var(--accent);
				background: rgba(249, 115, 22, 0.12);
				color: #fff;
				box-shadow: 0 10px 25px rgba(249, 115, 22, 0.25), inset 0 1px 1px rgba(255,255,255,0.1);
			}
			.skill-badge.major-mastery {
				background: linear-gradient(135deg, rgba(249, 115, 22, 0.25), rgba(249, 115, 22, 0.08));
				border: 1px solid rgba(249, 115, 22, 0.6);
				color: #fff;
				box-shadow: 0 0 20px rgba(249, 115, 22, 0.2), inset 0 1px 1px rgba(255,255,255,0.2);
				font-weight: 800;
				letter-spacing: 0.05em;
			}
			.skill-badge.major-mastery:hover {
				background: linear-gradient(135deg, rgba(249, 115, 22, 0.4), rgba(249, 115, 22, 0.15));
				border-color: rgba(249, 115, 22, 0.9);
				box-shadow: 0 0 30px rgba(249, 115, 22, 0.4), inset 0 1px 1px rgba(255,255,255,0.3);
			}
			.mastery-tag {
				font-size: 0.65rem;
				background: var(--accent);
				color: #000;
				padding: 0.15rem 0.5rem;
				border-radius: 4px;
				font-weight: 800;
				letter-spacing: 0.1em;
				text-transform: uppercase;
				margin-left: 0.2rem;
				box-shadow: 0 0 10px var(--accent);
			}

			/* CONTACT */
			#contact {
				text-align: center;
			}

			.contact-heading {
				font-family: var(--font-display);
				font-size: clamp(1.4rem, 3.5vw, 2.2rem);
				font-weight: 800;
				margin-bottom: 1rem;
				letter-spacing: -0.02em;
			}

			.contact-sub {
				color: #888;
				max-width: 550px;
				margin: 0 auto 3rem;
				line-height: 1.7;
				font-size: 0.95rem;
			}

			.contact-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
				gap: 1.5rem;
				max-width: 800px;
				margin: 0 auto 2.5rem;
			}

			.contact-card {
				padding: 2rem 1.5rem;
				text-align: center;
				text-decoration: none;
				color: inherit;
				background: linear-gradient(135deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
				border: 1px solid rgba(255,255,255,0.05);
				border-radius: 20px;
				backdrop-filter: blur(12px);
				transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.8rem;
			}
			.contact-card:hover {
				border-color: rgba(249, 115, 22, 0.5);
				box-shadow: 0 15px 35px rgba(0,0,0,0.5), inset 0 0 20px rgba(249, 115, 22, 0.1);
				transform: translateY(-6px);
			}

			.contact-icon {
				font-size: 2.5rem;
				color: #cbd5e1;
				transition: all 0.4s ease;
				display: flex;
				align-items: center;
				justify-content: center;
				filter: drop-shadow(0 0 5px rgba(255,255,255,0.1));
			}
			.contact-card:hover .contact-icon {
				color: var(--accent);
				transform: scale(1.15) translateY(-2px);
				filter: drop-shadow(0 0 15px var(--accent-glow));
			}
			.contact-label {
				font-family: var(--font-display);
				font-size: 0.95rem;
				font-weight: 700;
			}
			.contact-sub-label {
				color: #666;
				font-size: 0.75rem;
			}

			.contact-location {
				color: #666;
				font-size: 0.85rem;
				line-height: 1.8;
			}

			.contact-form-container {
				max-width: 600px;
				margin: 0 auto 3rem;
			}
			.contact-form {
				padding: 2.5rem;
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				text-align: left;
				background: linear-gradient(145deg, rgba(20,20,20,0.6), rgba(10,10,10,0.8));
				border: 1px solid rgba(255, 255, 255, 0.08);
				border-radius: 20px;
				backdrop-filter: blur(20px);
				box-shadow: 0 20px 40px rgba(0,0,0,0.6), inset 0 1px 1px rgba(255,255,255,0.05);
			}
			.form-group {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
			}
			.form-label {
				font-family: var(--font-tech);
				font-size: 0.85rem;
				color: #cbd5e1;
				font-weight: 600;
				letter-spacing: 0.05em;
				text-transform: uppercase;
			}
			.form-input, .form-textarea {
				background: rgba(0, 0, 0, 0.4);
				border: 1px solid rgba(255, 255, 255, 0.1);
				border-radius: 12px;
				padding: 1rem 1.2rem;
				color: #fff;
				font-family: var(--font-sans);
				font-size: 1rem;
				transition: all 0.3s ease;
				outline: none;
			}
			.form-input:focus, .form-textarea:focus {
				border-color: var(--accent);
				box-shadow: 0 0 15px rgba(249, 115, 22, 0.2);
				background: rgba(0, 0, 0, 0.6);
			}
			.form-input::placeholder, .form-textarea::placeholder {
				color: #64748b;
			}
			.form-textarea {
				resize: vertical;
				min-height: 120px;
			}

			/* FOOTER */
			footer {
				text-align: center;
				padding: 2.5rem 2rem;
				border-top: 1px solid var(--glass-border);
				color: #555;
				font-size: 0.85rem;
			}
			footer .footer-name {
				color: var(--accent);
			}
			footer .footer-stack {
				margin-top: 0.4rem;
				font-size: 0.75rem;
			}
			footer .footer-copy {
				margin-top: 1rem;
				font-size: 0.75rem;
				color: #444;
			}

			/* SCROLL REVEAL */
			.reveal {
				opacity: 0;
				transform: translateY(45px) translateZ(-50px);
				transform-style: preserve-3d;
				will-change: transform, opacity;
			}
			#main-content {
				perspective: 1200px;
				transform-style: preserve-3d;
			}



			/* DOM Elements Spatial Proximity Styling */
			.project-card, .skill-badge, .btn-primary, .btn-ghost, .contact-card, .achievement-card {
				--mouse-x: 50%;
				--mouse-y: 50%;
				--proximity: 0;
				position: relative;
			}

			/* Dynamic border glow on cards relative to cursor proximity */
			.project-card, .contact-card, .achievement-card {
				transition: border-color var(--motion-duration-medium) var(--motion-ease-cinematic), box-shadow var(--motion-duration-medium) var(--motion-ease-cinematic), transform var(--motion-duration-medium) var(--motion-ease-cinematic);
			}

			.project-card::after, .contact-card::after, .achievement-card::after {
				content: '';
				position: absolute;
				inset: -1px;
				border-radius: inherit;
				padding: 1px;
				background: radial-gradient(
					circle 120px at var(--mouse-x) var(--mouse-y), 
					rgba(249, 115, 22, calc(var(--proximity) * 0.45)), 
					transparent 70%
				);
				-webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
				mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
				-webkit-mask-composite: xor;
				mask-composite: exclude;
				pointer-events: none;
				z-index: 2;
				opacity: calc(0.3 + 0.7 * var(--proximity));
				transition: opacity var(--motion-duration-fast) var(--motion-ease-standard);
			}

			.project-card::before {
				background: radial-gradient(
					circle 180px at var(--mouse-x) var(--mouse-y), 
					rgba(249, 115, 22, calc(var(--proximity) * 0.08)), 
					transparent 70%
				) !important;
				opacity: 1 !important;
			}

			
		</style>
	</head>

	<body>
		<!-- Unified Spatial Ecosystem Canvas Layer (Modular and Persistent) -->
		<PersistentEnvironment />

		<!-- World-Class Cinematic Preloader Overlay -->
		<div id="cinematic-loader" class="loader-active">
			<div class="loader-overlay-gradient"></div>
			<div class="loader-grid-overlay"></div>
			<div class="loader-scanline"></div>
			
			<!-- Perfect Symmetric Screen Border Frame -->
			<div class="loader-viewport-frame">
				<div class="loader-frame-bottom-left">[DIAGNOSTICS_ACTIVE]</div>
				<div class="loader-frame-bottom-right" id="loader-hud-encryption">AUTH_STAGES: OK</div>
			</div>
			
			<!-- Spacious Central Console Card -->
			<div id="loader-ui" class="loader-ui">
				<div class="holo-ring-container">
					<svg class="holo-ring" viewBox="0 0 200 200">
						<!-- Deep Outer Glow Ring -->
						<circle class="ring-glow-back" cx="100" cy="100" r="95"></circle>
						<!-- Concentric Circular Ticks -->
						<circle class="ring-outer" cx="100" cy="100" r="90"></circle>
						<!-- Central Progress Indicator -->
						<circle class="ring-progress" cx="100" cy="100" r="80"></circle>
						<circle class="ring-core" cx="100" cy="100" r="12"></circle>
						<!-- Active Orbit Nodes -->
						<circle class="ring-orbit-1" cx="100" cy="100" r="50"></circle>
						<circle class="ring-orbit-2" cx="100" cy="100" r="30"></circle>
						<!-- Intricate Inner Technical Ring -->
						<circle class="ring-tech-inner" cx="100" cy="100" r="65" stroke-dasharray="2 10"></circle>
					</svg>
					<!-- High-Tech Percentage Display -->
					<div class="holo-percentage" id="loader-percent">00</div>
				</div>

				<div class="status-panel">
					<div class="status-header">
						<span class="status-indicator-dot"></span>
						<span class="status-title" id="loader-status-title">SYSTEM INIT</span>
					</div>
					<!-- Clean, single-line typing ticker -->
					<div class="status-ticker" id="loader-status-ticker">INITIATING DIAGNOSTIC HANDSHAKE...</div>
					
					<!-- Sleek Edge-to-Edge Oscilloscope Wave at bottom -->
					<div class="loader-wave-container">
						<svg viewBox="0 0 100 20" class="loader-wave-svg" preserveAspectRatio="none">
							<path id="loader-wave-path" d="M 0,10 Q 25,10 50,10 T 100,10" fill="none" stroke="rgba(249, 115, 22, 0.4)" stroke-width="1"></path>
						</svg>
					</div>
				</div>
			</div>
		</div>

		<!-- MAIN CONTENT WRAPPER -->
		<div id="main-content" style="opacity: 0; pointer-events: none; transition: opacity var(--motion-duration-cinematic) var(--motion-ease-cinematic), transform var(--motion-duration-cinematic) var(--motion-ease-cinematic), filter var(--motion-duration-cinematic) var(--motion-ease-cinematic); transform: translateY(30px); filter: blur(20px);">

		<!-- Mobile Menu -->
		<div class="mobile-menu" id="mobileMenu">
			<button class="mobile-close" onclick="closeMobileMenu()">✕</button>
			<a href="#home" onclick="closeMobileMenu()">Home</a>
			<a href="#about" onclick="closeMobileMenu()">About</a>
			<a href="#projects" onclick="closeMobileMenu()">Projects</a>
			<a href="#skills" onclick="closeMobileMenu()">Skills</a>
			<a href="#contact" onclick="closeMobileMenu()">Contact</a>
			<a href="/terminal" onclick="closeMobileMenu()" style="color: var(--accent); display: flex; align-items: center; gap: 0.5rem;"><span style="font-family: monospace;">>_</span> Terminal</a>
		</div>

		<!-- NAVBAR -->
		<nav>
			<a href="#home" class="nav-logo" style="display: flex; align-items: center;">
				<img src="https://github.com/YathinTHEBUILDER.png" alt="YG" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid var(--accent);" />
			</a>
			<ul class="nav-links">
				<li><a href="#about">About</a></li>
				<li><a href="#projects">Projects</a></li>
				<li><a href="#skills">Skills</a></li>
				<li><a href="#contact">Contact</a></li>
