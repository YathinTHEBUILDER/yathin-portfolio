---
// Yathin — Terminal Web Application
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Terminal | Interactive Terminal - Advanced CLI Environment</title>
		<meta
			name="description"
			content="Interactive Portfolio Terminal environment exploring system commands, AI capabilities, and developer portfolio."
		/>
		<meta name="theme-color" content="#0a0a0a" />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=Outfit:wght@400;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>

		<style is:global>
			*, *::before, *::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
				user-select: none !important;
				-webkit-user-select: none !important;
				-webkit-user-drag: none !important;
				-webkit-touch-callout: none !important;
			}

			input, textarea {
				user-select: auto !important;
				-webkit-user-select: auto !important;
				-webkit-user-drag: auto !important;
			}

			:root {
				--font-display: 'Outfit', sans-serif;
				--font-tech: 'Space Grotesk', sans-serif;
				--font-mono: 'Fira Code', monospace;

				--bg-desktop: #050505;
				--bg-panel: #0f0f0f;
				--bg-terminal: rgba(10, 10, 10, 0.88);
				--bg-header: #161616;
				
				--core-blue: #38bdf8;
				--core-blue-dark: #0284c7;
				--text-main: #e2e8f0;
				--text-muted: #94a3b8;
				--accent-orange: #f97316;

				--color-green: #10b981;
				--color-yellow: #eab308;
				--color-red: #ef4444;
				--color-purple: #a855f7;
			}

			html, body {
				width: 100%;
				height: 100%;
				overflow: hidden;
				background: var(--bg-desktop);
				font-family: var(--font-tech);
				color: var(--text-main);
			}

			/* Desktop Environment */
			#desktop {
				position: relative;
				width: 100vw;
				height: 100vh;
				display: flex;
				flex-direction: column;
				overflow: hidden;
				background-image: 
					radial-gradient(circle at 50% 50%, rgba(56, 189, 248, 0.05) 0%, transparent 60%),
					linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
				background-size: 100% 100%, 40px 40px, 40px 40px;
				background-position: center;
			}

			/* Top Panel */
			#top-panel {
				height: 40px;
				background: var(--bg-panel);
				border-bottom: 1px solid rgba(255, 255, 255, 0.08);
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 0 1.5rem;
				z-index: 100;
				backdrop-filter: blur(10px);
				-webkit-backdrop-filter: blur(10px);
			}

			.panel-left {
				display: flex;
				align-items: center;
				gap: 1rem;
			}

			.core-brand {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-weight: 800;
				font-family: var(--font-display);
				font-size: 1.1rem;
				color: var(--core-blue);
				text-decoration: none;
				text-shadow: 0 0 10px rgba(56, 189, 248, 0.4);
			}

			.panel-title {
				font-size: 0.85rem;
				color: var(--text-muted);
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.panel-title::before {
				content: '';
				width: 4px;
				height: 4px;
				background: var(--color-green);
				border-radius: 50%;
				box-shadow: 0 0 8px var(--color-green);
			}

			.panel-right {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				font-size: 0.85rem;
				color: var(--text-muted);
			}

			.panel-btn {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				background: rgba(249, 115, 22, 0.15);
				border: 1px solid rgba(249, 115, 22, 0.4);
				color: var(--accent-orange);
				padding: 0.3rem 0.8rem;
				border-radius: 6px;
				text-decoration: none;
				font-weight: 700;
				font-size: 0.8rem;
				transition: all 0.3s ease;
				box-shadow: 0 0 10px rgba(249, 115, 22, 0.1);
			}
			.panel-btn:hover {
				background: rgba(249, 115, 22, 0.3);
				box-shadow: 0 0 15px rgba(249, 115, 22, 0.3);
				transform: translateY(-1px);
				color: #fff;
			}

			.sys-stats {
				display: flex;
				align-items: center;
				gap: 1rem;
			}

			/* Main Workspace Area */
			#workspace {
				flex: 1;
				position: relative;
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 1.5rem;
			}

			/* Terminal Window Container */
			#terminal-window {
				width: 100%;
				max-width: 1050px;
				height: 100%;
				max-height: 680px;
				background: var(--bg-terminal);
				backdrop-filter: blur(25px);
				-webkit-backdrop-filter: blur(25px);
				border: 1px solid rgba(255, 255, 255, 0.12);
				border-radius: 12px;
				box-shadow: 0 30px 70px rgba(0, 0, 0, 0.9), inset 0 1px 2px rgba(255, 255, 255, 0.1);
				display: flex;
				flex-direction: column;
				overflow: hidden;
				animation: windowOpen 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
				transform-origin: center;
			}

			@keyframes windowOpen {
				from { opacity: 0; transform: scale(0.95) translateY(10px); }
				to { opacity: 1; transform: scale(1) translateY(0); }
			}

			/* Terminal Title Bar */
			#window-header {
				height: 38px;
				background: var(--bg-header);
				border-bottom: 1px solid rgba(255, 255, 255, 0.08);
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 0 1rem;
				user-select: none;
			}

			.window-controls {
				display: flex;
				align-items: center;
				gap: 8px;
			}
			.win-dot {
				width: 12px;
				height: 12px;
				border-radius: 50%;
				cursor: pointer;
				transition: opacity 0.2s;
			}
			.win-dot:hover { opacity: 0.8; }
			.win-dot.close { background: #ff5f56; box-shadow: 0 0 6px #ff5f56; }
			.win-dot.min { background: #ffbd2e; box-shadow: 0 0 6px #ffbd2e; }
			.win-dot.max { background: #27c93f; box-shadow: 0 0 6px #27c93f; }

			.window-title {
				font-family: var(--font-mono);
				font-size: 0.85rem;
				color: var(--text-muted);
				font-weight: 500;
			}

			.window-actions {
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.win-action-btn {
				background: none;
				border: none;
				color: var(--text-muted);
				cursor: pointer;
				padding: 0.2rem 0.5rem;
				border-radius: 4px;
				transition: all 0.2s;
			}
			.win-action-btn:hover {
				background: rgba(255, 255, 255, 0.1);
				color: #fff;
			}

			/* CRT Scanline Overlay */
			.scanlines {
				position: absolute;
				inset: 0;
				background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
				background-size: 100% 4px, 6px 100%;
				pointer-events: none;
				z-index: 10;
				opacity: 0.6;
			}

			/* Terminal Body */
			#terminal-body {
				flex: 1;
				padding: 1.5rem;
				overflow-y: auto;
				font-family: var(--font-mono);
				font-size: 0.95rem;
				line-height: 1.6;
				color: var(--text-main);
				position: relative;
				cursor: text;
			}

			/* Scrollbar */
			#terminal-body::-webkit-scrollbar { width: 6px; }
			#terminal-body::-webkit-scrollbar-track { background: rgba(0,0,0,0.2); }
			#terminal-body::-webkit-scrollbar-thumb { background: rgba(56, 189, 248, 0.3); border-radius: 3px; }
			#terminal-body::-webkit-scrollbar-thumb:hover { background: rgba(56, 189, 248, 0.6); }

			::selection {
				background: var(--core-blue);
				color: #000;
			}

			/* Output Blocks */
			.output-block {
				margin-bottom: 0.8rem;
				word-break: break-word;
				white-space: pre-wrap;
			}

			/* Active & Static Prompt Lines */
			.prompt-line {
				display: flex;
				align-items: flex-start;
				gap: 0;
				margin-bottom: 0.8rem;
				flex-wrap: wrap;
			}
			.prompt-header {
				display: flex;
				align-items: center;
				white-space: nowrap;
				margin-right: 0.6rem;
			}
			.prompt-p1 { color: var(--core-blue); font-weight: 600; }
			.prompt-user { color: var(--core-blue); font-weight: 700; }
			.prompt-p2 { color: var(--core-blue); font-weight: 600; }
			.prompt-dir { color: #f1f5f9; font-weight: 600; }
			.prompt-p3 { color: var(--core-blue); font-weight: 600; }
			
			.prompt-arrow-wrap {
				display: flex;
				align-items: center;
				width: 100%;
				gap: 0.6rem;
				margin-top: 0.2rem;
			}
			.prompt-arrow { color: var(--core-blue); font-weight: 700; }

			.cmd-input {
				background: transparent;
				border: none;
				outline: none;
				color: #fff;
				font-family: var(--font-mono);
				font-size: 0.95rem;
				flex: 1;
				min-width: 200px;
				caret-color: var(--core-blue);
				font-weight: 500;
			}

			.cmd-text {
				color: #fff;
				font-weight: 500;
			}

			/* Utility Colors for Terminal Output */
			.c-blue { color: var(--core-blue); }
			.c-green { color: var(--color-green); }
			.c-yellow { color: var(--color-yellow); }
			.c-red { color: var(--color-red); }
			.c-purple { color: var(--color-purple); }
			.c-gray { color: var(--text-muted); }
			.c-white { color: #fff; }

			/* ASCII Art & Tables */
			.ascii-art {
				font-family: var(--font-mono);
				line-height: 1.15;
				color: var(--core-blue);
				margin-bottom: 1rem;
				text-shadow: 0 0 10px rgba(56, 189, 248, 0.3);
				overflow-x: auto;
			}

			.neofetch-container {
				display: flex;
				flex-wrap: wrap;
				gap: 2.5rem;
				margin-bottom: 1.5rem;
				background: rgba(0, 0, 0, 0.3);
				padding: 1.5rem;
				border-radius: 8px;
				border: 1px solid rgba(255,255,255,0.05);
			}

			.neofetch-ascii {
				font-family: var(--font-mono);
				line-height: 1.15;
				color: var(--core-blue);
				font-weight: 600;
			}

			.neofetch-info {
				display: flex;
				flex-direction: column;
				gap: 0.4rem;
				min-width: 280px;
			}
			.neofetch-title {
				color: var(--core-blue);
				font-weight: 700;
				border-bottom: 1px solid rgba(255,255,255,0.1);
				padding-bottom: 0.4rem;
				margin-bottom: 0.4rem;
			}

			.help-table {
				width: 100%;
				border-collapse: collapse;
				margin: 1rem 0;
			}
			.help-table td {
				padding: 0.4rem 1rem 0.4rem 0;
				vertical-align: top;
			}
			.help-cmd {
				color: var(--core-blue);
				font-weight: 600;
				width: 140px;
			}
			.help-desc {
				color: var(--text-muted);
			}

			.ls-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
				gap: 0.8rem;
				margin: 0.8rem 0;
			}
			.ls-item {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-weight: 500;
			}
			.ls-dir { color: var(--core-blue); font-weight: 700; }
			.ls-file { color: var(--text-main); }
			.ls-exec { color: var(--color-green); font-weight: 700; }

			/* Portfolio Info Tables */
			.info-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.5rem;
				margin: 1rem 0;
			}
			.info-card {
				background: rgba(255, 255, 255, 0.03);
				border: 1px solid rgba(255, 255, 255, 0.08);
				padding: 1.2rem;
				border-radius: 8px;
			}
			.info-card-title {
				color: var(--core-blue);
				font-weight: 700;
				margin-bottom: 0.5rem;
				border-bottom: 1px solid rgba(255, 255, 255, 0.1);
				padding-bottom: 0.4rem;
			}

			@media (max-width: 768px) {
				#workspace { padding: 0.5rem; }
				#terminal-window { border-radius: 8px; }
				.neofetch-container { gap: 1.5rem; padding: 1rem; }
				.panel-right { gap: 0.8rem; }
			}
		</style>
	</head>
	<body>
		<div id="desktop">
			<!-- Top Panel -->
			<div id="top-panel">
				<div class="panel-left">
					<a href="/" class="core-brand">
						<svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
						YATHIN TERMINAL
					</a>
					<span class="panel-title">Terminal Workspace // SYS-01</span>
				</div>
				<div class="panel-right">
					<div class="sys-stats">
						<span id="clock" style="font-family: var(--font-mono); font-weight: 600;">12:00:00</span>
					</div>
					<a href="/" class="panel-btn">← Exit Terminal</a>
				</div>
			</div>

			<!-- Workspace Area -->
			<div id="workspace">
				<div id="terminal-window">
					<div id="window-header">
						<div class="window-controls">
							<div class="win-dot close" onclick="window.location.href='/'" title="Close"></div>
							<div class="win-dot min" title="Minimize"></div>
							<div class="win-dot max" id="btnMaximize" title="Maximize"></div>
						</div>
						<div class="window-title">yathin@terminal: ~</div>
						<div class="window-actions">
							<button class="win-action-btn" onclick="clearTerminal()" title="Clear Terminal">
								<svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" stroke-width="2" fill="none"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
							</button>
						</div>
					</div>

					<div class="scanlines"></div>

					<div id="terminal-body" onclick="focusInput()">
						<!-- Initial Welcome Banner -->
						<div class="output-block">
							<div class="ascii-art">
██╗   ██╗ █████╗ ████████╗██╗  ██╗██╗███╗   ██╗    ████████╗███████╗██████╗ ███╗   ███╗
╚██╗ ██╔╝██╔══██╗╚══██╔══╝██║  ██║██║████╗  ██║    ╚══██╔══╝██╔════╝██╔══██╗████╗ ████║
 ╚████╔╝ ███████║   ██║   ███████║██║██╔██╗ ██║       ██║   █████╗  ██████╔╝██╔████╔██║
  ╚██╔╝  ██╔══██║   ██║   ██╔══██║██║██║╚██╗██║       ██║   ██╔══╝  ██╔══██╗██║╚██╔╝██║
   ██║   ██║  ██║   ██║   ██║  ██║██║██║ ╚████║       ██║   ███████╗██║  ██║██║ ╚═╝ ██║
   ╚═╝   ╚═╝  ╚═╝   ╚═╝   ╚═╝  ╚═╝╚═╝╚═╝  ╚═══╝       ╚═╝   ╚══════╝╚═╝  ╚═╝╚═╝     ╚═╝
							</div>
							<p class="c-gray" style="margin-bottom: 0.5rem;">Welcome to the interactive Yathin Terminal Advanced AI & Full Stack Environment.</p>
							<p class="c-gray" style="margin-bottom: 1.2rem;">Type <span class="c-green">help</span> to view available system commands and portfolio information.</p>
						</div>

						<!-- Dynamic Output Container -->
						<div id="terminal-output"></div>

						<!-- Active Prompt Line -->
						<div class="prompt-line" id="active-prompt">
							<div class="prompt-header">
								<span class="prompt-p1">┌──(</span><span class="prompt-user">yathin㉿terminal</span><span class="prompt-p2">)-[</span><span class="prompt-dir">~</span><span class="prompt-p3">]</span>
							</div>
							<div class="prompt-arrow-wrap">
								<span class="prompt-arrow">└─$</span>
								<input type="text" class="cmd-input" id="cmdInput" autocomplete="off" spellcheck="false" autofocus />
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<script>
			// ── GLOBAL PROJECT PROTECTION: DISABLE RIGHT CLICK & SELECTION ──
			document.addEventListener("contextmenu", (e) => e.preventDefault());
			document.addEventListener("dragstart", (e) => e.preventDefault());

			// --- STATE & DATA ---
			const cmdHistory: string[] = [];
			let historyIndex = -1;

			const availableCommands = [
				'help', 'neofetch', 'whoami', 'pwd', 'ls', 'cat', 
				'nmap', 'aircrack-ng', 'sqlmap', 'dirb', 'msfconsole', 
				'sysinfo', 'about', 'skills', 'projects', 'achievements', 
				'contact', 'bio', 'history', 'date', 'echo', 'clear', 
				'cls', 'sudo', 'exit'
			];

			const files = {
				'flag.txt': '<span class="c-green" style="font-size:1.1rem;font-weight:700;">FLAG{yathin_fullstack_ai_architect_2026}</span>\n\nCongratulations! You found the secret root flag.',
				'notes.txt': '=== RESEARCH & DEVELOPMENT NOTES ===\n1. Upgrade multimodal pipeline for F.R.I.D.A.Y using Gemini 1.5 Pro.\n2. Scale InvoiceFlow co-financing settlement engine.\n3. Deploy low-latency WebRTC audio streams for J.A.R.V.I.S.',
				'wordlist.txt': 'admin\npassword\n123456\nqwerty\nroot\nyathin\ntoor\nsupersecret\nyathin2026\nmasterkey',
				'target_ips.txt': '192.168.1.105 - Vulnerable Web Server (Apache 2.4.49)\n10.0.0.42 - Active Directory Domain Controller\n172.16.5.18 - Staging API Gateway'
			};

			// --- DOM ELEMENTS ---
			const terminalBody = document.getElementById('terminal-body');
			const terminalOutput = document.getElementById('terminal-output');
			const cmdInput = document.getElementById('cmdInput') as HTMLInputElement;
			const btnMaximize = document.getElementById('btnMaximize');
			const terminalWindow = document.getElementById('terminal-window');
			const clockEl = document.getElementById('clock');

			// --- CLOCK ---
			function updateClock() {
				if (!clockEl) return;
				const now = new Date();
				clockEl.textContent = now.toTimeString().split(' ')[0];
			}
			setInterval(updateClock, 1000);
			updateClock();

			// --- WINDOW CONTROLS ---
			let isMaximized = false;
			if (btnMaximize && terminalWindow) {
				btnMaximize.addEventListener('click', () => {
					isMaximized = !isMaximized;
					if (isMaximized) {
						terminalWindow.style.maxWidth = '100vw';
						terminalWindow.style.maxHeight = 'calc(100vh - 40px)';
						terminalWindow.style.borderRadius = '0';
					} else {
						terminalWindow.style.maxWidth = '1050px';
						terminalWindow.style.maxHeight = '680px';
						terminalWindow.style.borderRadius = '12px';
					}
				});
			}

			// --- FOCUS INPUT ---
			function focusInput() {
				if (cmdInput) cmdInput.focus();
			}
			(window as any).focusInput = focusInput;

			// --- CLEAR TERMINAL ---
			function clearTerminal() {
				if (terminalOutput) terminalOutput.innerHTML = '';
				focusInput();
			}
			(window as any).clearTerminal = clearTerminal;

			// --- EVENT LISTENERS ---
			if (cmdInput) {
				cmdInput.addEventListener('keydown', (e) => {
					if (e.key === 'Enter') {
						const commandText = cmdInput.value.trim();
						if (commandText) {
							cmdHistory.push(commandText);
							historyIndex = cmdHistory.length;
						}
						executeCommand(commandText);
						cmdInput.value = '';
					} else if (e.key === 'ArrowUp') {
						e.preventDefault();
						if (historyIndex > 0) {
							historyIndex--;
							cmdInput.value = cmdHistory[historyIndex];
						}
					} else if (e.key === 'ArrowDown') {
						e.preventDefault();
						if (historyIndex < cmdHistory.length - 1) {
							historyIndex++;
							cmdInput.value = cmdHistory[historyIndex];
						} else {
							historyIndex = cmdHistory.length;
							cmdInput.value = '';
						}
					} else if (e.key === 'Tab') {
						e.preventDefault();
						const current = cmdInput.value.trim();
						if (!current) return;
						const matches = availableCommands.filter(c => c.startsWith(current.toLowerCase()));
						if (matches.length === 1) {
							cmdInput.value = matches[0] + ' ';
						} else if (matches.length > 1) {
							appendStaticPrompt(current);
							appendOutput(`<div class="c-blue">${matches.join('    ')}</div>`);
							resetPrompt();
						}
					} else if (e.ctrlKey && e.key === 'l') {
						e.preventDefault();
						clearTerminal();
					} else if (e.ctrlKey && e.key === 'c') {
						e.preventDefault();
						appendStaticPrompt(cmdInput.value + '^C');
						cmdInput.value = '';
						resetPrompt();
					}
				});
			}

			// --- EXECUTION ENGINE ---
			function appendStaticPrompt(cmdText: string) {
				if (!terminalOutput) return;
				const promptHtml = `
					<div class="prompt-line">
						<div class="prompt-header">
							<span class="prompt-p1">┌──(</span><span class="prompt-user">yathin㉿terminal</span><span class="prompt-p2">)-[</span><span class="prompt-dir">~</span><span class="prompt-p3">]</span>
						</div>
						<div class="prompt-arrow-wrap">
							<span class="prompt-arrow">└─$</span>
							<span class="cmd-text">${escapeHtml(cmdText)}</span>
						</div>
					</div>
				`;
				terminalOutput.insertAdjacentHTML('beforeend', promptHtml);
			}

			function appendOutput(htmlContent: string) {
				if (!terminalOutput) return;
				const outputHtml = `<div class="output-block">${htmlContent}</div>`;
				terminalOutput.insertAdjacentHTML('beforeend', outputHtml);
			}

			function resetPrompt() {
				if (!terminalBody) return;
				terminalBody.scrollTop = terminalBody.scrollHeight;
				focusInput();
			}

			function escapeHtml(str: string): string {
				return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
			}

